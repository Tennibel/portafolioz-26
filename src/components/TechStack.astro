---
/**
 * TechStack.astro - Tecnologías en carrusel infinito
 * Solo tecnologías de desarrollo, sin partners/herramientas de marketing
 */
const technologies = [
  { name: 'Astro', abbr: 'As', color: '#ff5d01' },
  { name: 'React', abbr: 'Re', color: '#61dafb' },
  { name: 'Tailwind CSS', abbr: 'Tw', color: '#38bdf8' },
  { name: 'WordPress', abbr: 'Wp', color: '#21759b' },
  { name: 'WooCommerce', abbr: 'Wc', color: '#96588a' },
  { name: 'Shopify', abbr: 'Sh', color: '#96bf48' },
  { name: 'Figma', abbr: 'Fi', color: '#a259ff' },
  { name: 'Cloudflare', abbr: 'Cf', color: '#f48120' },
  { name: 'Docker', abbr: 'Dk', color: '#2496ed' },
  { name: 'Node.js', abbr: 'Nj', color: '#339933' },
  { name: 'TypeScript', abbr: 'Ts', color: '#3178c6' },
  { name: 'PostgreSQL', abbr: 'Pg', color: '#4169e1' },
];

// Duplicamos para crear el efecto de loop infinito
const doubled = [...technologies, ...technologies];
---

<section class="bg-dark-900 py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <p class="text-cyan-400 font-medium text-sm uppercase tracking-widest mb-3">Tecnologías</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        Herramientas que <span class="gradient-text">potencian tu proyecto</span>
      </h2>
    </div>
  </div>

  <!-- Carrusel infinito -->
  <div class="tech-carousel" data-animate>
    <div class="tech-track">
      {doubled.map((tech) => (
        <div class="tech-item group">
          <div class="w-14 h-14 rounded-xl flex items-center justify-center mb-3 transition-all duration-300"
            style={`background:${tech.color}20;border:1px solid ${tech.color}30;`}>
            <span class="text-sm font-bold transition-colors duration-300" style={`color:${tech.color};`}>{tech.abbr}</span>
          </div>
          <p class="text-white/60 text-xs font-medium group-hover:text-white/90 transition-colors whitespace-nowrap">{tech.name}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Boton WA verde -->
  <div class="text-center mt-12 px-4">
    <a href="https://wa.me/5215647215472?text=Hola%2C%20me%20gustar%C3%ADa%20saber%20qu%C3%A9%20tecnolog%C3%ADas%20recomiendan%20para%20mi%20proyecto." target="_blank" rel="noopener"
      class="wa-lead inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#20bd5a] text-white font-semibold px-8 py-4 rounded-full text-lg transition-all hover:scale-105 shadow-lg shadow-[#25D366]/25"
      data-plan="Consulta Tecnologías" data-price="" data-category="TechStack">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Consultar mi proyecto
    </a>
  </div>
</section>

<style>
  .tech-carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
  .tech-track {
    display: flex;
    gap: 2rem;
    animation: scroll-loop 30s linear infinite;
    width: max-content;
  }
  .tech-track:hover {
    animation-play-state: paused;
  }
  .tech-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 1.5rem;
    cursor: default;
    flex-shrink: 0;
  }
  @keyframes scroll-loop {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
