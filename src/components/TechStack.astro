---
const technologies = [
  'Google Analytics', 'Google Ads', 'Bunny CDN', 'Namecheap',
  'WordPress', 'WooCommerce', 'Shopify', 'Astro',
  'Tailwind CSS', 'React', 'Cloudflare', 'Figma',
];
---

<section class="bg-dark-900 py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <p class="text-cyan-400 font-medium text-sm uppercase tracking-widest mb-3">Tecnologías</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        Herramientas que <span class="gradient-text">potencian tu proyecto</span>
      </h2>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4" data-animate>
      {technologies.map((tech) => (
        <div class="glass-card p-4 text-center hover:bg-white/10 transition-all duration-300 group cursor-default">
          <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-gradient-to-br from-cyan-500/20 to-accent-500/20 flex items-center justify-center">
            <span class="text-white/60 text-xs font-bold group-hover:text-white transition-colors">{tech.slice(0, 2).toUpperCase()}</span>
          </div>
          <p class="text-white/60 text-xs font-medium group-hover:text-white/90 transition-colors">{tech}</p>
        </div>
      ))}
    </div>
  </div>
</section>
