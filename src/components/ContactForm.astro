<section id="contacto" class="bg-dark-900 py-24 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-96 h-96 bg-accent-500/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div data-animate>
        <p class="text-cyan-400 font-medium text-sm uppercase tracking-widest mb-3">Contacto</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">¿Listo para hacer crecer <span class="gradient-text">tu negocio?</span></h2>
        <p class="text-white/60 text-lg leading-relaxed mb-8">Cuéntanos sobre tu proyecto o negocio y te responderemos en menos de 24 horas con una propuesta personalizada.</p>
        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full glass flex items-center justify-center"><svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg></div>
            <span class="text-white/70">hola@portafolioz.com</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full glass flex items-center justify-center"><svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg></div>
            <div><span class="text-white/70 block">55 6195 9724</span><span class="text-white/70 block">56 4721 5472</span></div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full glass flex items-center justify-center"><svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg></div>
            <span class="text-white/70 text-sm">Dr. José María Vértiz 84BIS, Doctores,<br/>Cuauhtémoc, 06720 CDMX</span>
          </div>
        </div>
      </div>
      <div data-animate>
        <form id="contact-form" class="glass-card p-8 space-y-5">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-white/60 text-sm mb-2" for="contact-form-nombre">Nombre</label>
              <input
                id="contact-form-nombre"
                name="nombre"
                type="text"
                required
                autocomplete="name"
                placeholder="Tu nombre"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-colors"
              />
            </div>
            <div>
              <label class="block text-white/60 text-sm mb-2" for="contact-form-email">Email</label>
              <input
                id="contact-form-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder="tu@email.com"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-colors"
              />
            </div>
          </div>
          <div>
            <label class="block text-white/60 text-sm mb-2" for="contact-form-telefono">Teléfono</label>
            <input
              id="contact-form-telefono"
              name="telefono"
              type="tel"
              autocomplete="tel"
              placeholder="55 1234 5678"
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-colors"
            />
          </div>
          <div>
            <label class="block text-white/60 text-sm mb-2" for="contact-form-proyecto">Cuéntanos tu proyecto</label>
            <textarea
              id="contact-form-proyecto"
              name="proyecto"
              rows="4"
              placeholder="Describe brevemente qué necesitas..."
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-colors resize-none"
            ></textarea>
          </div>
          <button type="submit" id="contact-submit-btn" class="w-full gradient-bg text-white font-semibold py-4 rounded-full text-lg hover:opacity-90 transition-all hover:scale-[1.02]">Enviar Mensaje</button>
          <p class="text-white/30 text-xs text-center">Al enviar aceptas nuestro aviso de privacidad.</p>
        </form>
        <div id="contact-success" class="hidden glass-card p-8 text-center">
          <div class="w-16 h-16 rounded-full gradient-bg mx-auto flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Mensaje enviado</h3>
          <p class="text-white/60 mb-4">Te contactaremos en menos de 24 horas.</p>
          <a href="https://wa.me/5215647215472?text=Hola%2C%20acabo%20de%20enviar%20un%20mensaje%20desde%20su%20web." target="_blank" rel="noopener"
            class="inline-flex items-center gap-2 bg-green-500 text-white font-semibold px-6 py-3 rounded-full hover:bg-green-600 transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.316 0-4.458-.764-6.182-2.054l-.432-.338-2.844.953.953-2.844-.338-.432A9.96 9.96 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            O escribenos por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
function initContactForm() {
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successEl = document.getElementById('contact-success');
  const submitBtn = document.getElementById('contact-submit-btn') as HTMLButtonElement;
  if (!form || !successEl || !submitBtn) return;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const nombre = (form.querySelector('[name="nombre"]') as HTMLInputElement)?.value;
    const email = (form.querySelector('[name="email"]') as HTMLInputElement)?.value;
    const telefono = (form.querySelector('[name="telefono"]') as HTMLInputElement)?.value;
    const proyecto = (form.querySelector('[name="proyecto"]') as HTMLTextAreaElement)?.value;

    if (!nombre || !email) { alert('Nombre y email son requeridos'); return; }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nombre, email, telefono, proyecto }),
      });
      const data = await res.json();
      if (data.ok) {
        form.classList.add('hidden');
        successEl.classList.remove('hidden');
        const contactEventParams = {
          form_name: 'contact_form',
          lead_channel: 'form',
          page_path: window.location.pathname
        };
        if (typeof window.pzTrackEvent === 'function') {
          window.pzTrackEvent('contact_form_submit_success', contactEventParams);
        } else if (typeof window.gtag === 'function') {
          window.gtag('event', 'contact_form_submit_success', contactEventParams);
        }
      } else {
        alert(data.error || 'Error al enviar');
      }
    } catch {
      alert('Error de conexion. Intenta de nuevo.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar Mensaje';
    }
  });
}
initContactForm();
document.addEventListener('astro:page-load', initContactForm);
</script>
