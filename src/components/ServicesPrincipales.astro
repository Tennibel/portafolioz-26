---
/**
 * ServicesPrincipales.astro - Cards con links a paginas de servicio
 */
const servicios = [
  { href: '/web-sales-machine', icon: '🌐', title: 'Diseño y Desarrollo Web', desc: 'Sitios web rápidos, modernos y optimizados para convertir visitantes en clientes.', badge: 'Desde $3,800 MXN' },
  { href: '/posicionamiento-web-seo', icon: '🔍', title: 'Posicionamiento SEO', desc: 'Aparece en los primeros resultados de Google y atrae tráfico orgánico de calidad.', badge: 'Desde $4,900/mes' },
  { href: '/growth-marketing', icon: '📈', title: 'Growth Marketing', desc: 'Estrategias de crecimiento basadas en datos para escalar tu negocio rápidamente.', badge: 'Desde $6,400/mes' },
  { href: '/leadboost-z', icon: '🤖', title: 'LeadBoost Z', desc: 'Automatización inteligente con IA para captar y nutrir leads 24/7.', badge: 'Desde $6,900/mes' },
  { href: '/branding-and-launch-kit', icon: '🎨', title: 'Branding & Launch Kit', desc: 'Identidad visual completa y kit de lanzamiento para destacar desde el día uno.', badge: 'Desde $4,200 MXN' },
  { href: '/social-media-marketing', icon: '📱', title: 'Social Media', desc: 'Gestión profesional de redes sociales para construir comunidad y generar ventas.', badge: 'Desde $6,400/mes' },
];
---

<section id="servicios-principales" class="sp-section">
  <div class="sp-container">
    <h2 class="sp-title">Nuestros Servicios Principales</h2>
    <p class="sp-subtitle">Soluciones integrales de marketing digital y desarrollo web para hacer crecer tu negocio</p>
    <div class="sp-grid">
      {servicios.map((s) => (
        <a href={s.href} class="sp-card">
          <span class="sp-icon">{s.icon}</span>
          <h3 class="sp-card-title">{s.title}</h3>
          <p class="sp-card-desc">{s.desc}</p>
          <span class="sp-badge">{s.badge}</span>
          <span class="sp-link">Ver más →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .sp-section {
    background: #0a0a0f;
    padding: 5rem 1.5rem;
    position: relative;
    overflow: hidden;
  }
  .sp-section::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(ellipse at 30% 50%, rgba(139, 92, 246, 0.06) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 50%, rgba(236, 72, 153, 0.04) 0%, transparent 60%);
    pointer-events: none;
  }
  .sp-container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .sp-title {
    text-align: center;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    background: linear-gradient(135deg, #fff 0%, #c4b5fd 50%, #f9a8d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.75rem;
  }
  .sp-subtitle {
    text-align: center;
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.05rem;
    max-width: 600px;
    margin: 0 auto 3rem;
  }
  .sp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .sp-card {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    text-decoration: none;
    color: #fff;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  .sp-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(236, 72, 153, 0.08) 100%);
    opacity: 0;
    transition: opacity 0.35s ease;
    border-radius: 1rem;
  }
  .sp-card:hover {
    transform: translateY(-6px);
    border-color: rgba(139, 92, 246, 0.3);
    box-shadow: 0 20px 40px rgba(139, 92, 246, 0.15), 0 0 60px rgba(139, 92, 246, 0.05);
  }
  .sp-card:hover::before {
    opacity: 1;
  }
  .sp-card > * {
    position: relative;
    z-index: 1;
  }
  .sp-icon {
    font-size: 2.25rem;
    margin-bottom: 0.75rem;
    display: block;
  }
  .sp-card-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #fff;
  }
  .sp-card-desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.5;
    margin-bottom: 1rem;
    flex-grow: 1;
  }
  .sp-badge {
    display: inline-block;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(236, 72, 153, 0.2));
    border: 1px solid rgba(139, 92, 246, 0.25);
    color: #c4b5fd;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    margin-bottom: 0.75rem;
    width: fit-content;
  }
  .sp-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: #a78bfa;
    transition: color 0.3s ease;
  }
  .sp-card:hover .sp-link {
    color: #f9a8d4;
  }
  @media (max-width: 900px) {
    .sp-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 550px) {
    .sp-grid {
      grid-template-columns: 1fr;
    }
    .sp-section {
      padding: 3.5rem 1rem;
    }
  }
</style>
