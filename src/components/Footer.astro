---
const socialLinks = [
  { name: 'Facebook', href: 'https://facebook.com/portafolioz' },
  { name: 'Instagram', href: 'https://instagram.com/portafolio.z' },
  { name: 'Twitter', href: 'https://x.com/PortafolioZ' },
  { name: 'TikTok', href: 'https://tiktok.com/@portafolioz' },
];
---

<footer class="relative bg-gradient-to-b from-indigo-950 via-[#1a0a3e] to-[#0f0628] pt-20 pb-8 overflow-hidden">
  <!-- Subtle glow effects -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-indigo-600/8 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 right-1/4 w-64 h-64 bg-purple-600/8 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-12 lg:gap-16 pb-16">

      <!-- Col 1: CTA -->
      <div>
        <p class="text-pink-500 font-semibold text-sm uppercase tracking-wider mb-4">¡HOLA! QUEREMOS AYUDARTE</p>
        <h3 class="text-3xl md:text-4xl font-bold text-white leading-none">Cuéntanos sobre</h3>
        <h3 class="text-3xl md:text-4xl font-bold mb-8 leading-none">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400 italic">tu proyecto o negocio</span>
        </h3>
        <a href="/contacto" class="inline-flex items-center gap-2 text-pink-400 hover:text-pink-300 text-sm font-semibold uppercase tracking-wider transition-colors group">
          ¿Suena bien? Contáctanos
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <!-- Col 2: Contacto + Suscribete -->
      <div>
        <div class="inline-flex items-center bg-indigo-800/50 border border-indigo-600/30 text-white text-xs font-semibold px-4 py-1.5 rounded-full mb-6">
          Contáctanos
        </div>
        <div class="space-y-4 mb-10">
          <a href="mailto:hola@portafolioz.com" class="flex items-center gap-3 text-white/70 hover:text-white text-sm transition-colors">
            <span class="text-lg">📧</span>
            hola@portafolioz.com
          </a>
          <a href="tel:+525561959724" class="flex items-center gap-3 text-white/70 hover:text-white text-sm transition-colors">
            <span class="text-lg">💬</span>
            55 6195 9724
          </a>
          <a href="tel:+525647215472" class="flex items-center gap-3 text-white/70 hover:text-white text-sm transition-colors">
            <span class="text-lg">💬</span>
            56 4721 5472
          </a>
        </div>

        <div class="inline-flex items-center bg-indigo-800/50 border border-indigo-600/30 text-white text-xs font-semibold px-4 py-1.5 rounded-full mb-5">
          Suscríbete
        </div>
        <form class="space-y-3">
          <input
            type="text"
            placeholder="Nombre"
            class="w-full bg-transparent border-b border-white/15 text-white text-sm py-2.5 placeholder-white/30 outline-none focus:border-pink-500 transition-colors"
          />
          <div class="flex items-center gap-2">
            <input
              type="email"
              placeholder="Email"
              class="flex-1 bg-transparent border-b border-white/15 text-white text-sm py-2.5 placeholder-white/30 outline-none focus:border-pink-500 transition-colors"
            />
            <button type="submit" class="text-pink-400 hover:text-pink-300 transition-colors p-1">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </button>
          </div>
        </form>
      </div>

      <!-- Col 3: Direccion + Siguenos -->
      <div>
        <div class="inline-flex items-center bg-indigo-800/50 border border-indigo-600/30 text-white text-xs font-semibold px-4 py-1.5 rounded-full mb-6">
          Dirección
        </div>
        <div class="space-y-4 mb-10">
          <div class="flex items-start gap-3">
            <span class="text-lg flex-shrink-0 mt-0.5">🌍</span>
            <p class="text-white/70 text-sm leading-relaxed">Dr. José María Vértiz 84BIS, Doctores, Cuauhtémoc, 06720 Ciudad de México, CDMX</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-lg">🕐</span>
            <p class="text-white/70 text-sm">Lunes a Viernes 8:00 am - 6:00 pm</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-lg">🕐</span>
            <p class="text-white/70 text-sm">Sábado 9:00 am a 2:00 pm</p>
          </div>
        </div>

        <div class="inline-flex items-center bg-indigo-800/50 border border-indigo-600/30 text-white text-xs font-semibold px-4 py-1.5 rounded-full mb-5">
          Síguenos
        </div>
        <div class="grid grid-cols-2 gap-3">
          {socialLinks.map((link) => (
            <a href={link.href} class="text-pink-400 hover:text-pink-300 text-sm font-medium transition-colors" target="_blank" rel="noopener">
              {link.name}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-white/10"></div>

    <!-- Bottom footer -->
    <div class="flex flex-col md:flex-row items-center justify-between pt-8 gap-6">
      <div class="flex items-center gap-2">
        <img src="/img/logo/logo-light.png" alt="Portafolio Z" class="h-12 w-auto" />
        <span class="text-white/30 text-xs">Increíbles Sitios Web</span>
      </div>
      <div class="flex flex-wrap justify-center gap-6 text-sm">
        <a href="/aviso-de-privacidad" class="text-white/50 hover:text-white transition-colors">Aviso de Privacidad</a>
        <a href="/aviso-legal" class="text-white/50 hover:text-white transition-colors">Aviso Legal</a>
        <a href="/politica-de-cookies" class="text-white/50 hover:text-white transition-colors">Política de Cookies</a>
      </div>
      <p class="text-white/40 text-xs">
        Copyright &copy; 2026 | Powered by Portafolio Z
      </p>
    </div>
  </div>
</footer>
