---
/**
 * Services.astro - Servicios de Diseño Web
 * Seccion #3: Solo servicios de diseño/desarrollo web
 */
const services = [
  { title: 'Diseño Web de Alto Impacto', desc: 'Desarrollamos el sitio web de tus sueños, nos adaptamos 100% a los requerimientos de cada proyecto.', gradient: 'from-cyan-500 to-primary-500', icon: '🎨', href: '/diseno-paginas-web' },
  { title: 'Hospedaje y Dominios', desc: '¿No sabes cómo registrar tu dominio? Nosotros lo hacemos por ti. Almacenamos tu información en nuestro hosting web.', gradient: 'from-primary-500 to-accent-500', icon: '🌐', href: '/servicios-web' },
  { title: 'Tienda en Línea', desc: 'E-commerce profesional con carrito de compras, pasarelas de pago y catálogo de productos administrable.', gradient: 'from-accent-500 to-pink-500', icon: '🛒', href: '/tienda-en-linea-e-commerce' },
  { title: 'Soporte y Capacitación', desc: 'Soporte en fallas técnicas y capacitaciones de gestión de sitios o tiendas e-commerce.', gradient: 'from-pink-500 to-coral-500', icon: '🛟', href: '/administrador-de-contenidos' },
  { title: 'Optimización en Buscadores', desc: 'SEO básico en todos nuestros planes, también contamos con servicios más avanzados para posicionarte.', gradient: 'from-coral-500 to-amber-500', icon: '🔍', href: '/posicionamiento-web-seo' },
  { title: 'Asesoramiento en Branding', desc: 'Te asesoramos con la identidad de tu marca para lograr un impacto visual y eficiente en la web.', gradient: 'from-amber-500 to-cyan-500', icon: '✨', href: '/branding-and-launch-kit' },
];
---

<section id="servicios" class="bg-dark-900 py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <p class="text-cyan-400 font-medium text-sm uppercase tracking-widest mb-3">Nuestros Servicios</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        Soluciones completas para tu <span class="gradient-text">presencia digital</span>
      </h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5" data-animate>
      {services.map((service) => (
        <a href={service.href} class="group relative glass-card p-6 hover:scale-105 hover:-translate-y-2 transition-all duration-500 cursor-pointer overflow-hidden block no-underline">
          <div class={`absolute inset-0 bg-gradient-to-br ${service.gradient} opacity-0 group-hover:opacity-15 transition-opacity duration-500 rounded-2xl`}></div>
          <div class="relative z-10">
            <span class="text-3xl mb-3 block">{service.icon}</span>
            <h3 class="text-lg font-bold text-white mb-2">{service.title}</h3>
            <p class="text-white/50 text-sm leading-relaxed">{service.desc}</p>
            <div class="flex items-center gap-2 mt-4 text-cyan-400 text-sm font-medium">
              <span>Ver más</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
