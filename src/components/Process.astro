---
const steps = [
  {
    num: '01',
    title: 'Cotización',
    desc: 'Cuéntanos tu proyecto y te enviamos una propuesta personalizada con el mejor precio.',
  },
  {
    num: '02',
    title: 'Diseño',
    desc: 'Creamos prototipos y diseños que reflejan tu marca y optimizan la conversión de visitantes.',
  },
  {
    num: '03',
    title: 'Desarrollo',
    desc: 'Construimos tu sitio con las mejores tecnologías, rápido, seguro y responsivo.',
  },
  {
    num: '04',
    title: 'Lanzamiento',
    desc: 'Publicamos, optimizamos y te acompañamos con soporte y capacitación continua.',
  },
];
---

<section class="bg-white py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <p class="text-accent-600 font-medium text-sm uppercase tracking-widest mb-3">Nuestro Proceso</p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
        Cómo <span class="gradient-text">trabajamos</span>
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8" data-animate>
      {steps.map((step, i) => (
        <div class="relative group">
          <div class="bg-gray-50 rounded-2xl p-8 hover:-translate-y-2 hover:shadow-xl transition-all duration-300 text-center">
            <span class="text-5xl font-extrabold gradient-text block mb-4">{step.num}</span>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{step.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{step.desc}</p>
          </div>
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-1/2 -right-4 -translate-y-1/2 z-10">
              <svg class="w-8 h-8 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
