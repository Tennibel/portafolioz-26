---
/**
 * Process.astro - Nuestro proceso de trabajo en 4 pasos
 *
 * Seccion #9: Proceso (fondo degradado indigo -> purpura)
 * 4 pasos con glass-card y numeracion gradient.
 * Flechas conectoras entre pasos en desktop.
 */
const steps = [
  {
    num: '01',
    title: 'Cotización',
    desc: 'Cuéntanos tu proyecto y te enviamos una propuesta personalizada con el mejor precio.',
    icon: '💬',
  },
  {
    num: '02',
    title: 'Diseño',
    desc: 'Creamos prototipos y diseños que reflejan tu marca y optimizan la conversión de visitantes.',
    icon: '🎨',
  },
  {
    num: '03',
    title: 'Desarrollo',
    desc: 'Construimos tu sitio con las mejores tecnologías, rápido, seguro y responsivo.',
    icon: '⚡',
  },
  {
    num: '04',
    title: 'Lanzamiento',
    desc: 'Publicamos, optimizamos y te acompañamos con soporte y capacitación continua.',
    icon: '🚀',
  },
];
---

<section class="relative py-24 overflow-hidden">
  <!-- Fondo degradado -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary-600 via-accent-600 to-pink-600"></div>
  <div class="absolute top-10 left-20 w-72 h-72 bg-cyan-400/15 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 right-20 w-80 h-80 bg-pink-400/15 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <p class="text-cyan-300 font-medium text-sm uppercase tracking-widest mb-3">Nuestro Proceso</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        ¿Cómo <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 to-white">trabajamos</span>?
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6" data-animate>
      {steps.map((step, i) => (
        <div class="relative group">
          <div class="glass-card p-8 hover:bg-white/15 transition-all duration-300 text-center h-full">
            <span class="text-3xl mb-3 block group-hover:scale-110 transition-transform">{step.icon}</span>
            <span class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 to-white block mb-3">{step.num}</span>
            <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
            <p class="text-white/60 text-sm leading-relaxed">{step.desc}</p>
          </div>
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-1/2 -right-3 -translate-y-1/2 z-10">
              <svg class="w-6 h-6 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
