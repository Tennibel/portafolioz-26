---
/**
 * Projects.astro - Carrusel de proyectos en el home
 *
 * Muestra los 6 últimos proyectos en un carrusel horizontal draggable.
 * Nombre, categoría y descripción siempre visibles.
 */
import { getVisibleProjects } from '../lib/db';

const categoriaLabels: Record<string, string> = {
  'landing': 'Landing Page',
  'sitio-web': 'Sitio Web',
  'ecommerce': 'E-commerce',
  'corporativo': 'Corporativo',
  'bienes-raices': 'Bienes Raices',
  'profesional': 'Profesional',
  'restaurante': 'Restaurante',
  'otro': 'Otro',
};

const colors = [
  'from-cyan-500 to-blue-600',
  'from-purple-500 to-pink-500',
  'from-pink-500 to-rose-600',
  'from-amber-500 to-orange-600',
  'from-emerald-500 to-teal-600',
  'from-violet-500 to-indigo-600',
];

interface Project {
  title: string;
  category: string;
  description: string;
  image: string | null;
  url: string | null;
  color: string;
}

let projects: Project[] = [];

try {
  const { projects: dbProjects } = getVisibleProjects({ page: 1, perPage: 6 });
  if (dbProjects.length > 0) {
    projects = dbProjects.map((p, i) => ({
      title: p.nombre,
      category: categoriaLabels[p.categoria] || p.categoria,
      description: p.descripcion || '',
      image: p.imagen,
      url: p.url,
      color: colors[i % colors.length],
    }));
  }
} catch {
  // BD no disponible
}

// Fallback si no hay proyectos en la BD
if (projects.length === 0) {
  projects = [
    { title: 'Hotel Boutique', category: 'Diseño Web', description: 'Sitio web para hotel boutique con reservaciones en línea.', image: null, url: null, color: colors[0] },
    { title: 'E-Commerce Moda', category: 'Tienda Online', description: 'Tienda online con checkout optimizado.', image: null, url: null, color: colors[1] },
    { title: 'Clínica Dental', category: 'Landing Page', description: 'Landing enfocada a captación de pacientes.', image: null, url: null, color: colors[2] },
    { title: 'App Fintech', category: 'Desarrollo', description: 'Plataforma financiera con dashboard interactivo.', image: null, url: null, color: colors[3] },
    { title: 'Restaurant Gourmet', category: 'Diseño Web', description: 'Menú digital y reservaciones online.', image: null, url: null, color: colors[4] },
    { title: 'Agencia Inmobiliaria', category: 'Sitio Corporativo', description: 'Catálogo de propiedades con búsqueda avanzada.', image: null, url: null, color: colors[5] },
  ];
}
---

<section id="proyectos" class="bg-white py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Encabezado -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-12 gap-4" data-animate>
      <div>
        <p class="text-accent-600 font-medium text-sm uppercase tracking-widest mb-3">Portafolio</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
          Proyectos que <span class="gradient-text">hablan por sí solos</span>
        </h2>
      </div>
      <a href="/proyectos-desarrollo-web" class="inline-flex items-center gap-2 text-accent-600 hover:text-accent-700 font-semibold transition-colors whitespace-nowrap group">
        Ver todos
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>

    <!-- Carrusel -->
    <div class="relative" data-animate>
      <!-- Botones nav (solo desktop) -->
      <button id="proj-prev" class="hidden lg:flex absolute -left-5 top-1/2 -translate-y-1/2 z-10 w-12 h-12 rounded-full bg-white shadow-lg border border-gray-200 items-center justify-center text-gray-600 hover:text-accent-600 hover:border-accent-300 transition-all hover:scale-110 cursor-pointer" aria-label="Anterior">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      </button>
      <button id="proj-next" class="hidden lg:flex absolute -right-5 top-1/2 -translate-y-1/2 z-10 w-12 h-12 rounded-full bg-white shadow-lg border border-gray-200 items-center justify-center text-gray-600 hover:text-accent-600 hover:border-accent-300 transition-all hover:scale-110 cursor-pointer" aria-label="Siguiente">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </button>

      <!-- Track del carrusel -->
      <div id="proj-carousel" class="flex gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4 -mx-4 px-4 lg:mx-0 lg:px-0 cursor-grab active:cursor-grabbing" style="scrollbar-width: none; -ms-overflow-style: none;">
        {projects.map((p, i) => (
          <a
            href={p.url || '/proyectos-desarrollo-web'}
            target={p.url ? '_blank' : '_self'}
            rel={p.url ? 'noopener' : undefined}
            class="project-slide flex-shrink-0 w-[85vw] sm:w-[60vw] md:w-[45vw] lg:w-[calc(33.333%-1rem)] snap-start group block"
          >
            <div class="rounded-2xl overflow-hidden bg-white border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
              <!-- Imagen -->
              <div class="relative aspect-[16/10] overflow-hidden">
                {p.image ? (
                  <img
                    src={p.image}
                    alt={p.title}
                    class="absolute inset-0 w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700"
                    loading="lazy"
                    width="600"
                    height="375"
                  />
                ) : (
                  <div class={`absolute inset-0 bg-gradient-to-br ${p.color} flex items-center justify-center`}>
                    <span class="text-white/30 text-7xl font-bold">{p.title.charAt(0)}</span>
                  </div>
                )}
                <!-- Badge categoría -->
                <div class="absolute top-3 left-3">
                  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-white/90 text-gray-700 backdrop-blur-sm shadow-sm">
                    {p.category}
                  </span>
                </div>
                <!-- Overlay hover sutil -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </div>

              <!-- Info siempre visible -->
              <div class="p-5">
                <h3 class="text-lg font-bold text-gray-900 group-hover:text-accent-600 transition-colors line-clamp-1">{p.title}</h3>
                {p.description && (
                  <p class="text-sm text-gray-500 mt-1 line-clamp-2">{p.description}</p>
                )}
                <span class="inline-flex items-center gap-1 text-accent-600 text-sm font-medium mt-3 group-hover:gap-2 transition-all">
                  Ver proyecto
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Dots indicadores (mobile) -->
      <div class="flex justify-center gap-2 mt-6 lg:hidden" id="proj-dots">
        {projects.map((_, i) => (
          <button class={`w-2.5 h-2.5 rounded-full transition-all ${i === 0 ? 'bg-accent-500 w-6' : 'bg-gray-300'}`} data-dot={i} aria-label={`Proyecto ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  #proj-carousel::-webkit-scrollbar {
    display: none;
  }
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
function initProjectCarousel() {
  const carousel = document.getElementById('proj-carousel');
  const prevBtn = document.getElementById('proj-prev');
  const nextBtn = document.getElementById('proj-next');
  const dots = document.querySelectorAll<HTMLButtonElement>('#proj-dots button');
  if (!carousel) return;

  const slides = carousel.querySelectorAll('.project-slide');
  if (slides.length === 0) return;

  // Nav buttons
  prevBtn?.addEventListener('click', () => {
    const slideWidth = (slides[0] as HTMLElement).offsetWidth + 24; // gap-6 = 24px
    carousel.scrollBy({ left: -slideWidth, behavior: 'smooth' });
  });

  nextBtn?.addEventListener('click', () => {
    const slideWidth = (slides[0] as HTMLElement).offsetWidth + 24;
    carousel.scrollBy({ left: slideWidth, behavior: 'smooth' });
  });

  // Update dots on scroll
  carousel.addEventListener('scroll', () => {
    const slideWidth = (slides[0] as HTMLElement).offsetWidth + 24;
    const activeIndex = Math.round(carousel.scrollLeft / slideWidth);
    dots.forEach((dot, i) => {
      if (i === activeIndex) {
        dot.classList.add('bg-accent-500', 'w-6');
        dot.classList.remove('bg-gray-300');
      } else {
        dot.classList.remove('bg-accent-500', 'w-6');
        dot.classList.add('bg-gray-300');
      }
    });
  });

  // Dot click
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const index = Number(dot.dataset.dot);
      const slideWidth = (slides[0] as HTMLElement).offsetWidth + 24;
      carousel.scrollTo({ left: slideWidth * index, behavior: 'smooth' });
    });
  });

  // Drag to scroll (desktop)
  let isDown = false;
  let startX: number;
  let scrollLeft: number;

  carousel.addEventListener('mousedown', (e) => {
    isDown = true;
    carousel.classList.add('active');
    startX = e.pageX - carousel.offsetLeft;
    scrollLeft = carousel.scrollLeft;
  });

  carousel.addEventListener('mouseleave', () => { isDown = false; });
  carousel.addEventListener('mouseup', () => { isDown = false; });

  carousel.addEventListener('mousemove', (e) => {
    if (!isDown) return;
    e.preventDefault();
    const x = e.pageX - carousel.offsetLeft;
    const walk = (x - startX) * 1.5;
    carousel.scrollLeft = scrollLeft - walk;
  });
}

initProjectCarousel();
document.addEventListener('astro:page-load', initProjectCarousel);
</script>
