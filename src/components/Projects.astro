---
/**
 * Projects.astro - Galeria de proyectos realizados
 *
 * Seccion #7: Proyectos (fondo blanco)
 * Lee proyectos destacados de la BD. Fallback a placeholders si no hay datos.
 */
import { getVisibleProjects } from '../lib/db';

const categoriaLabels: Record<string, string> = {
  'landing': 'Landing Page',
  'sitio-web': 'Sitio Web',
  'ecommerce': 'E-commerce',
  'corporativo': 'Corporativo',
  'bienes-raices': 'Bienes Raices',
  'profesional': 'Profesional',
  'restaurante': 'Restaurante',
  'otro': 'Otro',
};

const colors = [
  'from-primary-500 to-accent-500',
  'from-accent-500 to-pink-500',
  'from-pink-500 to-primary-500',
  'from-primary-500 to-pink-500',
  'from-accent-500 to-primary-500',
  'from-pink-500 to-accent-500',
];

let projects: Array<{ title: string; category: string; image: string | null; url: string | null; color: string }> = [];

try {
  const { projects: dbProjects } = getVisibleProjects({ page: 1, perPage: 6 });
  if (dbProjects.length > 0) {
    projects = dbProjects.map((p, i) => ({
      title: p.nombre,
      category: categoriaLabels[p.categoria] || p.categoria,
      image: p.imagen,
      url: p.url,
      color: colors[i % colors.length],
    }));
  }
} catch {
  // BD no disponible
}

// Fallback si no hay proyectos en la BD
if (projects.length === 0) {
  projects = [
    { title: 'Hotel Boutique', category: 'Diseno Web', image: null, url: null, color: 'from-primary-500 to-accent-500' },
    { title: 'E-Commerce Moda', category: 'Tienda Online', image: null, url: null, color: 'from-accent-500 to-pink-500' },
    { title: 'Clinica Dental', category: 'Landing Page', image: null, url: null, color: 'from-pink-500 to-primary-500' },
    { title: 'App Fintech', category: 'Desarrollo', image: null, url: null, color: 'from-primary-500 to-pink-500' },
    { title: 'Restaurant Gourmet', category: 'Diseno Web', image: null, url: null, color: 'from-accent-500 to-primary-500' },
    { title: 'Agencia Inmobiliaria', category: 'Sitio Corporativo', image: null, url: null, color: 'from-pink-500 to-accent-500' },
  ];
}
---

<section id="proyectos" class="bg-white py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Encabezado -->
    <div class="text-center mb-16" data-animate>
      <p class="text-accent-600 font-medium text-sm uppercase tracking-widest mb-3">Portafolio</p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
        Proyectos que <span class="gradient-text">hablan por si solos</span>
      </h2>
    </div>

    <!-- Grid de proyectos -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-animate>
      {projects.map((p) => (
        <a href={p.url || '/proyectos-desarrollo-web'} target={p.url ? '_blank' : '_self'} rel={p.url ? 'noopener' : undefined}
          class="group relative rounded-2xl overflow-hidden cursor-pointer aspect-[4/3] block">
          {p.image ? (
            <img src={p.image} alt={p.title} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
          ) : (
            <div class={`absolute inset-0 bg-gradient-to-br ${p.color} opacity-80`}></div>
          )}

          <!-- Overlay al hover -->
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-500 flex items-end p-6">
            <div class="translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
              <span class="text-xs font-medium text-accent-400 uppercase tracking-wider">{p.category}</span>
              <h3 class="text-xl font-bold text-white mt-1">{p.title}</h3>
            </div>
          </div>

          <!-- Label siempre visible -->
          <div class="absolute bottom-4 left-4 group-hover:opacity-0 transition-opacity">
            <span class="bg-white/20 backdrop-blur-sm text-white text-sm font-medium px-3 py-1 rounded-full">{p.title}</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Ver todos -->
    <div class="text-center mt-12" data-animate>
      <a href="/proyectos-desarrollo-web" class="inline-flex items-center gap-2 text-accent-600 hover:text-accent-700 font-semibold transition-colors">
        Ver todos los proyectos
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </div>
</section>
