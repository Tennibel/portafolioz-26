---
/**
 * LeadMagnetPopup.astro - Popup exit-intent para captar leads
 * Ofrece pack gratuito de textos legales para sitio web
 * Se activa al mover el mouse fuera de la ventana (exit intent)
 * Solo aparece en paginas de diseno web
 */
---

<!-- Overlay -->
<div id="lm-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[9999] hidden opacity-0 transition-opacity duration-300">
  <!-- Popup -->
  <div id="lm-popup" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90vw] max-w-lg z-[10000] scale-95 opacity-0 transition-all duration-300">
    <div class="relative rounded-2xl overflow-hidden shadow-2xl">
      <!-- Header con gradiente -->
      <div class="bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-500 px-8 pt-8 pb-6 text-center">
        <button id="lm-close" class="absolute top-4 right-4 w-8 h-8 rounded-full bg-white/20 hover:bg-white/30 flex items-center justify-center text-white transition-colors" aria-label="Cerrar">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
        <div class="text-4xl mb-3">📄</div>
        <h3 class="text-2xl font-bold text-white leading-tight">Descarga Gratis el pack de<br/>Textos Legales para tu Sitio Web</h3>
      </div>

      <!-- Formulario -->
      <div class="bg-white px-8 py-6">
        <form id="lm-form" class="space-y-4">
          <input type="text" name="nombre" required placeholder="Nombre"
            class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 outline-none transition-all" />
          <input type="email" name="email" required placeholder="Email"
            class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 outline-none transition-all" />
          <label class="flex items-start gap-2 cursor-pointer">
            <input type="checkbox" name="acepto" required class="mt-1 accent-indigo-600" />
            <span class="text-sm text-gray-500">Acepto el <a href="/aviso-de-privacidad" target="_blank" class="text-indigo-600 hover:underline">aviso de privacidad</a> de esta web.</span>
          </label>
          <button type="submit" id="lm-submit" class="w-full bg-gradient-to-r from-pink-500 to-rose-500 text-white font-bold py-3.5 rounded-xl text-lg hover:opacity-90 transition-all hover:scale-[1.02] shadow-lg shadow-pink-500/30">
            Consigue aqui el pack
          </button>
        </form>

        <!-- Exito -->
        <div id="lm-success" class="hidden text-center py-4">
          <div class="text-4xl mb-3">🎉</div>
          <h4 class="text-xl font-bold text-gray-900 mb-2">Listo, revisa tu email</h4>
          <p class="text-gray-500 text-sm">Te enviamos el pack de textos legales a tu correo. Revisa tu bandeja de entrada (y spam).</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function initLeadMagnetPopup() {
  const overlay = document.getElementById('lm-overlay');
  const popup = document.getElementById('lm-popup');
  const closeBtn = document.getElementById('lm-close');
  const form = document.getElementById('lm-form') as HTMLFormElement;
  const successEl = document.getElementById('lm-success');
  const submitBtn = document.getElementById('lm-submit') as HTMLButtonElement;
  if (!overlay || !popup || !form) return;

  // No mostrar si ya se vio o ya se registro
  if (localStorage.getItem('lm-textos-legales-seen')) return;

  let shown = false;

  function showPopup() {
    if (shown) return;
    shown = true;
    overlay.classList.remove('hidden');
    requestAnimationFrame(() => {
      overlay.style.opacity = '1';
      popup.style.opacity = '1';
      popup.style.transform = 'translate(-50%, -50%) scale(1)';
    });
  }

  function hidePopup() {
    overlay.style.opacity = '0';
    popup.style.opacity = '0';
    popup.style.transform = 'translate(-50%, -50%) scale(0.95)';
    setTimeout(() => overlay.classList.add('hidden'), 300);
    localStorage.setItem('lm-textos-legales-seen', '1');
  }

  // Exit intent: mouse sale por arriba de la ventana
  document.addEventListener('mouseout', (e) => {
    if (e.clientY <= 0 && !shown) {
      showPopup();
    }
  });

  // Fallback mobile: mostrar despues de 30 segundos
  if ('ontouchstart' in window) {
    setTimeout(() => {
      if (!shown) showPopup();
    }, 30000);
  }

  closeBtn?.addEventListener('click', hidePopup);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) hidePopup();
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const nombre = (form.querySelector('[name="nombre"]') as HTMLInputElement)?.value;
    const email = (form.querySelector('[name="email"]') as HTMLInputElement)?.value;
    if (!nombre || !email) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';

    try {
      const res = await fetch('/api/lead-magnet', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nombre, email }),
      });
      const data = await res.json();
      if (data.ok) {
        form.classList.add('hidden');
        successEl?.classList.remove('hidden');
        if (typeof window.pzTrackEvent === 'function') {
          window.pzTrackEvent('form_submit_success', {
            form_name: 'lead_magnet_form',
            lead_channel: 'form',
            page_path: window.location.pathname
          });
        }
        localStorage.setItem('lm-textos-legales-seen', '1');
        setTimeout(hidePopup, 4000);
      } else {
        alert(data.error || 'Error al enviar');
      }
    } catch {
      alert('Error de conexion');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Consigue aqui el pack';
    }
  });
}
initLeadMagnetPopup();
document.addEventListener('astro:page-load', initLeadMagnetPopup);
</script>
