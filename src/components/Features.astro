---
/**
 * Features.astro - Caracteristicas incluidas en todos los planes
 *
 * Seccion #6: Features (fondo degradado rosa -> coral)
 * 6 features con iconos emoji en grid de 3 columnas.
 * Glassmorphism cards con hover effect.
 * Contenido real de portafolioz.com.
 */
const features = [
  { title: 'Hosting y Dominio', desc: 'Registro de dominio y hospedaje incluido con asistencia técnica.', icon: '🌐' },
  { title: 'Diseño Responsivo', desc: 'Se adapta perfectamente a móviles, tablets y escritorio.', icon: '📱' },
  { title: 'Navegación Segura', desc: 'Certificado SSL y backups semanales en todos los planes.', icon: '🔒' },
  { title: 'SEO Incluido', desc: 'Posicionamiento básico en Google para que tus clientes te encuentren.', icon: '🔍' },
  { title: 'Velocidad', desc: 'Sitios optimizados que cargan rápido para mejor experiencia.', icon: '⚡' },
  { title: 'Banco de Imágenes', desc: 'Imágenes premium de los principales proveedores, sin costo adicional.', icon: '🖼️' },
];
---

<section class="relative py-24 overflow-hidden">
  <!-- Fondo degradado calido: rosa -> coral -->
  <div class="absolute inset-0 bg-gradient-to-br from-pink-500 via-pink-600 to-coral-500"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Encabezado -->
    <div class="text-center mb-16" data-animate>
      <p class="text-white/70 font-medium text-sm uppercase tracking-widest mb-3">Características</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">Todo incluido en <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 to-white">cada proyecto</span></h2>
    </div>
    <!-- Grid de features: 1 col mobile, 2 tablet, 3 desktop -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5" data-animate>
      {features.map((f) => (
        <div class="glass-card p-6 hover:bg-white/15 transition-all duration-300 group">
          <span class="text-3xl mb-3 block group-hover:scale-110 transition-transform">{f.icon}</span>
          <h3 class="text-lg font-semibold text-white mb-1">{f.title}</h3>
          <p class="text-white/60 text-sm">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
