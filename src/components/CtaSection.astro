<section class="relative py-24 overflow-hidden">
  <!-- Orange to amber gradient like PDF -->
  <div class="absolute inset-0 bg-gradient-to-br from-coral-500 via-coral-600 to-amber-500"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-animate>
    <div class="glass-card-light p-12 md:p-16">
      <h2 class="text-3xl md:text-4xl font-bold text-dark-900 mb-4">
        ¿Suena bien? <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-accent-600">Contáctanos</span>
      </h2>
      <p class="text-dark-700/70 text-lg mb-10 max-w-2xl mx-auto">
        Invierte en más que un diseño web. Tu próximo cliente está buscándote, no dejes que tu competencia te gane.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button data-open-cotizador class="gradient-bg text-white font-semibold px-8 py-4 rounded-full text-lg hover:opacity-90 transition-all hover:scale-105 cursor-pointer">
          ¡Quiero el Diseño de mi Web!
        </button>
        <a href="https://wa.me/5215561959724" target="_blank" rel="noopener" class="bg-dark-900 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-dark-800 transition-all">
          Hablar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>
