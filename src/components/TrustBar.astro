---
const brands = [
  'Google Analytics',
  'Google Ads',
  'Bunny CDN',
  'Namecheap',
  'WordPress',
  'Shopify',
];
---

<section class="bg-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm text-gray-400 uppercase tracking-widest mb-10" data-animate>
      Herramientas y plataformas que utilizamos
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-8 items-center" data-animate>
      {brands.map((brand) => (
        <div class="flex items-center justify-center h-12 px-4 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300">
          <div class="bg-gray-100 rounded-lg px-6 py-3 text-sm font-medium text-gray-500">
            {brand}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
