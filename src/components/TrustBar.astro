---
const brands = [
  { name: 'Google Analytics', logo: '/img/partners/logo-Analitycs.jpg' },
  { name: 'Google Ads', logo: '/img/partners/Logo-Ads-google.jpg' },
  { name: 'Bunny CDN', logo: '/img/partners/bunnynet-logo-dark.png' },
  { name: 'Namecheap', logo: '/img/partners/Logo-Namecheap.jpg' },
  { name: 'Cloudflare', logo: '/img/partners/Logo-Cloudflare.jpg' },
];
---

<section class="bg-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm text-gray-400 uppercase tracking-widest mb-10" data-animate>
      Herramientas y plataformas que utilizamos
    </p>
    <div class="flex flex-wrap justify-center items-center gap-10 md:gap-16" data-animate>
      {brands.map((brand) => (
        <div class="transition-all duration-300 hover:drop-shadow-[0_0_12px_rgba(6,182,212,0.7)] hover:scale-105">
          <img src={brand.logo} alt={brand.name} class="h-10 md:h-12 w-auto object-contain" loading="lazy" width="120" height="48" />
        </div>
      ))}
    </div>
  </div>
</section>
