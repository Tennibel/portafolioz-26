---
/**
 * Plans.astro - Planes de precios
 *
 * Seccion #5: Paquetes (fondo blanco)
 * 4 planes con cards claras. El popular destaca con gradient.
 */
const plans = [
  { name: 'Landing Page', price: '$5,600', desc: '1-3 secciones', features: ['Diseño responsivo', '1-3 secciones', 'Formulario de contacto', 'SEO básico', 'Certificado SSL'], popular: false },
  { name: 'Sitio Básico', price: '$6,400', desc: '2-4 secciones', features: ['2-4 secciones', 'Diseño personalizado', 'SEO básico', 'Certificado SSL', 'Banco de imágenes'], popular: true },
  { name: 'Sitio Profesional', price: '$7,300', desc: '5-8 secciones', features: ['5-8 secciones', 'Diseño premium', 'Blog integrado', 'SEO avanzado', 'Banco de imágenes', 'Soporte 6 meses'], popular: false },
  { name: 'Sitio Empresarial', price: '$8,900', desc: '9-12 secciones', features: ['9-12 secciones', 'Diseño a medida', 'Blog + CRM', 'SEO avanzado', 'Banco de imágenes', 'Soporte 12 meses'], popular: false },
];
---

<section id="paquetes" class="bg-white py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <p class="text-accent-600 font-medium text-sm uppercase tracking-widest mb-3">Paquetes para Emprendedores</p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Elige el plan ideal para tu <span class="gradient-text">negocio</span></h2>
      <p class="text-gray-500 mt-4 max-w-2xl mx-auto">Todos los planes incluyen hosting, dominio, certificado SSL y banco de imágenes.</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6" data-animate>
      {plans.map((plan) => (
        <div class={`relative rounded-2xl p-7 transition-all duration-300 hover:-translate-y-2 ${plan.popular ? 'bg-gradient-to-br from-primary-600 via-accent-600 to-pink-600 text-white ring-2 ring-accent-400 shadow-2xl scale-105' : 'bg-gray-50 text-gray-900 border border-gray-200'}`}>
          {plan.popular && (<div class="absolute -top-4 left-1/2 -translate-x-1/2"><span class="bg-cyan-400 text-dark-900 text-xs font-bold px-4 py-1.5 rounded-full">Más Popular</span></div>)}
          <h3 class="text-lg font-bold mb-1">{plan.name}</h3>
          <p class={`text-xs mb-5 ${plan.popular ? 'text-white/60' : 'text-gray-500'}`}>{plan.desc}</p>
          <div class="mb-6"><span class="text-3xl font-extrabold">{plan.price}</span><span class={`text-xs ml-1 ${plan.popular ? 'text-white/50' : 'text-gray-400'}`}>MXN</span></div>
          <ul class="space-y-2.5 mb-6">
            {plan.features.map((f) => (
              <li class="flex items-center gap-2.5 text-sm">
                <svg class={`w-4 h-4 flex-shrink-0 ${plan.popular ? 'text-cyan-300' : 'text-accent-500'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span class={plan.popular ? 'text-white/80' : 'text-gray-600'}>{f}</span>
              </li>
            ))}
          </ul>
          <a href="/contacto" class={`block text-center font-semibold py-3 px-5 rounded-full transition-all text-sm ${plan.popular ? 'bg-white text-primary-600 hover:bg-white/90' : 'border-2 border-accent-500 text-accent-600 hover:bg-accent-500 hover:text-white'}`}>¡Quiero mi Web!</a>
        </div>
      ))}
    </div>
  </div>
</section>
