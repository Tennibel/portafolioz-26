---
/**
 * Navbar.astro - Mega menu con glassmorphism
 *
 * Comportamiento:
 * - Inicial: Glassmorphism sutil (blur + borde) flotante con margen superior
 * - Al scroll > 50px: Se expande a ancho completo, fondo mas solido, shadow elevada
 * - Desktop: Mega menu dropdown en "Servicios" con 3 columnas
 * - Mobile: Hamburguesa animada (X al abrir) + menu overlay fullscreen con acordeon
 */
const simpleLinks = [
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Proyectos', href: '/proyectos-desarrollo-web' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contacto', href: '/contacto' },
];

const megaMenu = {
  label: 'Servicios',
  columns: [
    {
      title: 'Diseño Web',
      color: 'cyan',
      items: [
        { label: 'Web Sales Machine', desc: 'Sitios web que generan clientes', href: '/web-sales-machine', icon: '🚀' },
      ],
    },
    {
      title: 'Marketing & Ads',
      color: 'amber',
      items: [
        { label: 'Growth Marketing', desc: 'Google Ads + Meta Ads profesional', href: '/growth-marketing', icon: '📈' },
        { label: 'LeadBoost Z', desc: 'Automatización de ventas con IA', href: '/leadboost-z', icon: '🤖' },
        { label: 'Consultoría Digital', desc: '30 min gratis de estrategia', href: '/consultoria-marketing-digital', icon: '💡' },
      ],
    },
    {
      title: 'Por Sector',
      color: 'violet',
      items: [
        { label: 'Médicos y Clínicas', desc: 'Citas online + perfil médico', href: '/sector/medicos', icon: '🏥' },
        { label: 'Inmobiliarias', desc: 'Catálogo de propiedades', href: '/sector/inmobiliarias', icon: '🏠' },
        { label: 'Hoteles', desc: 'Reservaciones directas', href: '/sector/hoteles', icon: '🏨' },
        { label: 'Restaurantes', desc: 'Menú digital + reservaciones', href: '/sector/restaurantes', icon: '🍽️' },
        { label: 'Escuelas', desc: 'Portal de inscripciones', href: '/sector/escuelas', icon: '🎓' },
      ],
    },
  ],
};

const colorMap: Record<string, { title: string; hover: string; icon: string }> = {
  cyan: { title: 'text-cyan-400', hover: 'hover:bg-cyan-500/10 hover:border-cyan-500/20', icon: 'bg-cyan-500/15' },
  amber: { title: 'text-amber-400', hover: 'hover:bg-amber-500/10 hover:border-amber-500/20', icon: 'bg-amber-500/15' },
  violet: { title: 'text-violet-400', hover: 'hover:bg-violet-500/10 hover:border-violet-500/20', icon: 'bg-violet-500/15' },
};

const columnsWithColors = megaMenu.columns.map((col) => ({
  ...col,
  colors: colorMap[col.color],
}));
---

<!-- Contenedor exterior: agrega padding top para el efecto "flotante" -->
<div class="fixed top-0 left-0 right-0 z-50 px-4 sm:px-6 pt-4 transition-all duration-400" id="navbar-wrapper">
  <nav
    class="max-w-6xl mx-auto rounded-2xl border border-white/15 bg-white/5 backdrop-blur-xl transition-all duration-400"
    id="navbar"
  >
    <div class="px-5 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group">
          <div class="w-9 h-9 rounded-xl gradient-bg flex items-center justify-center shadow-lg shadow-primary-500/30 group-hover:shadow-primary-500/50 transition-shadow">
            <span class="text-white font-black text-sm">PZ</span>
          </div>
          <span class="text-lg font-bold text-white hidden sm:block">
            Portafolio <span class="gradient-text">Z</span>
          </span>
        </a>

        <!-- Links desktop -->
        <div class="hidden lg:flex items-center gap-1">
          <a href="/nosotros" class="relative px-3.5 py-2 text-sm font-medium text-white/70 hover:text-white transition-colors rounded-lg hover:bg-white/10">
            Nosotros
          </a>

          <!-- Servicios con mega menu -->
          <div class="relative" id="mega-trigger">
            <button
              class="relative px-3.5 py-2 text-sm font-medium text-white/70 hover:text-white transition-colors rounded-lg hover:bg-white/10 flex items-center gap-1 cursor-pointer"
              id="mega-btn"
              aria-expanded="false"
              aria-haspopup="true"
            >
              Servicios
              <svg class="w-3.5 h-3.5 transition-transform duration-200" id="mega-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>

            <!-- Mega menu dropdown -->
            <div
              class="absolute top-full left-1/2 -translate-x-1/2 mt-3 w-[720px] opacity-0 invisible translate-y-2 transition-all duration-200 pointer-events-none"
              id="mega-dropdown"
            >
              <!-- Flecha -->
              <div class="flex justify-center mb-[-6px] relative z-10">
                <div class="w-3 h-3 bg-dark-800 border-l border-t border-white/15 rotate-45"></div>
              </div>
              <div class="bg-dark-800/95 backdrop-blur-2xl border border-white/15 rounded-2xl shadow-2xl shadow-black/40 p-6 overflow-hidden">
                <!-- Grid de 3 columnas -->
                <div class="grid grid-cols-3 gap-6">
                  {columnsWithColors.map((col) => (
                    <div>
                      <p class={`text-xs font-semibold uppercase tracking-widest ${col.colors.title} mb-3 px-2`}>{col.title}</p>
                      <div class="space-y-1">
                        {col.items.map((item) => (
                          <a
                            href={item.href}
                            class={`flex items-start gap-3 p-2.5 rounded-xl border border-transparent transition-all duration-200 group/item ${col.colors.hover}`}
                          >
                            <span class={`text-lg flex-shrink-0 mt-0.5 w-8 h-8 ${col.colors.icon} rounded-lg flex items-center justify-center group-hover/item:scale-110 transition-transform`}>{item.icon}</span>
                            <div>
                              <p class="text-sm font-semibold text-white group-hover/item:text-white">{item.label}</p>
                              <p class="text-xs text-white/40 leading-relaxed">{item.desc}</p>
                            </div>
                          </a>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
                <!-- Footer del mega menu -->
                <div class="mt-5 pt-4 border-t border-white/10 flex items-center justify-between">
                  <p class="text-xs text-white/30">Todos los servicios incluyen soporte y consultoría</p>
                  <a href="/paquetes-digitales" class="text-xs font-semibold text-cyan-400 hover:text-cyan-300 transition-colors flex items-center gap-1">
                    Ver todos los paquetes
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <a href="/paquetes-digitales" class="relative px-3.5 py-2 text-sm font-medium text-white/70 hover:text-white transition-colors rounded-lg hover:bg-white/10">
            Paquetes
          </a>
          <a href="/proyectos-desarrollo-web" class="relative px-3.5 py-2 text-sm font-medium text-white/70 hover:text-white transition-colors rounded-lg hover:bg-white/10">
            Proyectos
          </a>
          <a href="/blog" class="relative px-3.5 py-2 text-sm font-medium text-white/70 hover:text-white transition-colors rounded-lg hover:bg-white/10">
            Blog
          </a>
          <a href="/contacto" class="relative px-3.5 py-2 text-sm font-medium text-white/70 hover:text-white transition-colors rounded-lg hover:bg-white/10">
            Contacto
          </a>
        </div>

        <!-- CTA + Hamburguesa -->
        <div class="flex items-center gap-3">
          <button
            data-open-cotizador
            class="hidden md:inline-flex items-center gap-2 gradient-bg text-white text-sm font-semibold px-5 py-2 rounded-xl hover:shadow-lg hover:shadow-accent-500/30 hover:scale-105 transition-all duration-300 cursor-pointer"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            Cotiza Ahora
          </button>

          <button
            class="lg:hidden text-white p-2 rounded-xl hover:bg-white/10 transition-colors relative w-10 h-10 flex items-center justify-center"
            id="mobile-toggle"
            aria-label="Abrir menú"
            aria-controls="mobile-overlay"
            aria-expanded="false"
          >
            <span class="flex flex-col items-center justify-center gap-1.5">
              <span class="block w-5 h-[2px] bg-white rounded-full transition-all duration-300 origin-center" id="bar1"></span>
              <span class="block w-5 h-[2px] bg-white rounded-full transition-all duration-300" id="bar2"></span>
              <span class="block w-3.5 h-[2px] bg-white rounded-full transition-all duration-300 origin-center self-start ml-[3px]" id="bar3"></span>
            </span>
          </button>
        </div>
      </div>
    </div>
  </nav>
</div>

<!-- Menu mobile: overlay fullscreen con mega menu acordeon -->
<div class="fixed inset-0 z-40 hidden" id="mobile-overlay" role="dialog" aria-modal="true" aria-label="Menú móvil">
  <div class="absolute inset-0 bg-dark-900/80 backdrop-blur-md" id="mobile-backdrop"></div>
  <div class="relative z-10 pt-24 px-6 pb-8 h-full flex flex-col overflow-y-auto">
    <div class="space-y-1">
      <a href="/nosotros" class="mobile-link block text-white/80 hover:text-white text-xl font-semibold py-2.5 px-4 rounded-xl hover:bg-white/10 transition-all" style="transition-delay: 0ms">
        Nosotros
      </a>

      <!-- Servicios acordeon mobile -->
      <div class="mobile-link" style="transition-delay: 50ms">
        <button
          class="w-full flex items-center justify-between text-white/80 hover:text-white text-xl font-semibold py-2.5 px-4 rounded-xl hover:bg-white/10 transition-all cursor-pointer"
          id="mobile-servicios-btn"
        >
          Servicios
          <svg class="w-5 h-5 transition-transform duration-200" id="mobile-servicios-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="hidden pl-4 pb-2 space-y-4 mt-2" id="mobile-servicios-panel">
          <!-- Diseño Web -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-cyan-400 mb-2 px-4">Diseño Web</p>
            <a href="/web-sales-machine" class="flex items-center gap-3 py-2 px-4 rounded-xl hover:bg-white/10 transition-all">
              <span class="text-lg">🚀</span>
              <div>
                <p class="text-sm font-semibold text-white">Web Sales Machine</p>
                <p class="text-xs text-white/40">Sitios web que generan clientes</p>
              </div>
            </a>
          </div>
          <!-- Marketing & Ads -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-amber-400 mb-2 px-4">Marketing & Ads</p>
            <a href="/growth-marketing" class="flex items-center gap-3 py-2 px-4 rounded-xl hover:bg-white/10 transition-all">
              <span class="text-lg">📈</span>
              <div>
                <p class="text-sm font-semibold text-white">Growth Marketing</p>
                <p class="text-xs text-white/40">Google Ads + Meta Ads profesional</p>
              </div>
            </a>
            <a href="/leadboost-z" class="flex items-center gap-3 py-2 px-4 rounded-xl hover:bg-white/10 transition-all">
              <span class="text-lg">🤖</span>
              <div>
                <p class="text-sm font-semibold text-white">LeadBoost Z</p>
                <p class="text-xs text-white/40">Automatización de ventas con IA</p>
              </div>
            </a>
            <a href="/consultoria-marketing-digital" class="flex items-center gap-3 py-2 px-4 rounded-xl hover:bg-white/10 transition-all">
              <span class="text-lg">💡</span>
              <div>
                <p class="text-sm font-semibold text-white">Consultoría Digital</p>
                <p class="text-xs text-white/40">30 min gratis de estrategia</p>
              </div>
            </a>
          </div>
          <!-- Por Sector -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-violet-400 mb-2 px-4">Por Sector</p>
            <a href="/sector/medicos" class="flex items-center gap-3 py-2 px-4 rounded-xl hover:bg-white/10 transition-all">
              <span class="text-lg">🏥</span>
              <span class="text-sm font-medium text-white/70">Médicos y Clínicas</span>
            </a>
            <a href="/sector/inmobiliarias" class="flex items-center gap-3 py-2 px-4 rounded-xl hover:bg-white/10 transition-all">
              <span class="text-lg">🏠</span>
              <span class="text-sm font-medium text-white/70">Inmobiliarias</span>
            </a>
            <a href="/sector/hoteles" class="flex items-center gap-3 py-2 px-4 rounded-xl hover:bg-white/10 transition-all">
              <span class="text-lg">🏨</span>
              <span class="text-sm font-medium text-white/70">Hoteles</span>
            </a>
            <a href="/sector/restaurantes" class="flex items-center gap-3 py-2 px-4 rounded-xl hover:bg-white/10 transition-all">
              <span class="text-lg">🍽️</span>
              <span class="text-sm font-medium text-white/70">Restaurantes</span>
            </a>
            <a href="/sector/escuelas" class="flex items-center gap-3 py-2 px-4 rounded-xl hover:bg-white/10 transition-all">
              <span class="text-lg">🎓</span>
              <span class="text-sm font-medium text-white/70">Escuelas</span>
            </a>
          </div>
        </div>
      </div>

      <a href="/paquetes-digitales" class="mobile-link block text-white/80 hover:text-white text-xl font-semibold py-2.5 px-4 rounded-xl hover:bg-white/10 transition-all" style="transition-delay: 100ms">
        Paquetes
      </a>
      <a href="/proyectos-desarrollo-web" class="mobile-link block text-white/80 hover:text-white text-xl font-semibold py-2.5 px-4 rounded-xl hover:bg-white/10 transition-all" style="transition-delay: 150ms">
        Proyectos
      </a>
      <a href="/blog" class="mobile-link block text-white/80 hover:text-white text-xl font-semibold py-2.5 px-4 rounded-xl hover:bg-white/10 transition-all" style="transition-delay: 200ms">
        Blog
      </a>
      <a href="/contacto" class="mobile-link block text-white/80 hover:text-white text-xl font-semibold py-2.5 px-4 rounded-xl hover:bg-white/10 transition-all" style="transition-delay: 250ms">
        Contacto
