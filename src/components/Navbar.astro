    </div>

    <!-- CTA mobile -->
    <div class="mt-8 pt-6 border-t border-white/10">
      <button
        data-open-cotizador
        class="mobile-link block w-full gradient-bg text-white text-lg font-semibold px-6 py-4 rounded-2xl text-center shadow-lg shadow-accent-500/25 cursor-pointer"
        style="transition-delay: 300ms"
      >
        Cotiza Ahora
      </button>
      <div class="mobile-link mt-5 flex items-center justify-center gap-4 text-white/50 text-sm" style="transition-delay: 350ms">
        <a href="tel:+525561959724" class="hover:text-white transition-colors">55 6195 9724</a>
        <span>•</span>
        <a href="mailto:hola@portafolioz.com" class="hover:text-white transition-colors">hola@portafolioz.com</a>
      </div>
    </div>
  </div>
</div>

<style>
  .mobile-link {
    opacity: 0;
    transform: translateX(-20px);
    transition: opacity 0.3s ease, transform 0.3s ease, background-color 0.2s ease, color 0.2s ease;
  }
  #mobile-overlay.open .mobile-link {
    opacity: 1;
    transform: translateX(0);
  }
  /* Mega menu visible state */
  #mega-dropdown.mega-open {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }
</style>

<script>
  function initNavbar() {
    const wrapper = document.getElementById('navbar-wrapper');
    const navbar = document.getElementById('navbar');
    const toggle = document.getElementById('mobile-toggle');
    const overlay = document.getElementById('mobile-overlay');
    const backdrop = document.getElementById('mobile-backdrop');
    const bar1 = document.getElementById('bar1');
    const bar2 = document.getElementById('bar2');
    const bar3 = document.getElementById('bar3');

    toggle?.setAttribute('aria-expanded', 'false');

    // Scroll behavior
    function updateNavbar() {
      if (!wrapper || !navbar) return;
      if (window.scrollY > 50) {
        wrapper.classList.add('px-0', 'sm:px-0', 'pt-0');
        wrapper.classList.remove('px-4', 'sm:px-6', 'pt-4');
        navbar.classList.add('bg-dark-900/90', 'shadow-2xl', 'shadow-black/20', 'border-transparent');
        navbar.classList.remove('bg-white/5', 'border-white/15');
      } else {
        wrapper.classList.remove('px-0', 'sm:px-0', 'pt-0');
        wrapper.classList.add('px-4', 'sm:px-6', 'pt-4');
        navbar.classList.remove('bg-dark-900/90', 'shadow-2xl', 'shadow-black/20', 'border-transparent');
        navbar.classList.add('bg-white/5', 'border-white/15');
      }
    }
    updateNavbar();
    window.addEventListener('scroll', updateNavbar);

    // === MEGA MENU (desktop) ===
    const megaTrigger = document.getElementById('mega-trigger');
    const megaBtn = document.getElementById('mega-btn');
    const megaDropdown = document.getElementById('mega-dropdown');
    const megaChevron = document.getElementById('mega-chevron');
    let megaTimeout: ReturnType<typeof setTimeout>;

    function openMega() {
      clearTimeout(megaTimeout);
      megaDropdown?.classList.add('mega-open');
      megaBtn?.setAttribute('aria-expanded', 'true');
      if (megaChevron) megaChevron.style.transform = 'rotate(180deg)';
    }

    function closeMega() {
      megaTimeout = setTimeout(() => {
        megaDropdown?.classList.remove('mega-open');
        megaBtn?.setAttribute('aria-expanded', 'false');
        if (megaChevron) megaChevron.style.transform = '';
      }, 150);
    }

    megaTrigger?.addEventListener('mouseenter', openMega);
    megaTrigger?.addEventListener('mouseleave', closeMega);
    megaDropdown?.addEventListener('mouseenter', openMega);
    megaDropdown?.addEventListener('mouseleave', closeMega);

    // Click also toggles for accessibility
    megaBtn?.addEventListener('click', () => {
      const isOpen = megaDropdown?.classList.contains('mega-open');
      if (isOpen) {
        megaDropdown?.classList.remove('mega-open');
        megaBtn?.setAttribute('aria-expanded', 'false');
        if (megaChevron) megaChevron.style.transform = '';
      } else {
        openMega();
      }
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        megaDropdown?.classList.remove('mega-open');
        megaBtn?.setAttribute('aria-expanded', 'false');
        if (megaChevron) megaChevron.style.transform = '';
      }
    });

    // === MOBILE SERVICIOS ACCORDION ===
    const mobileServiciosBtn = document.getElementById('mobile-servicios-btn');
    const mobileServiciosPanel = document.getElementById('mobile-servicios-panel');
    const mobileServiciosChevron = document.getElementById('mobile-servicios-chevron');
    let serviciosOpen = false;

    mobileServiciosBtn?.addEventListener('click', () => {
      serviciosOpen = !serviciosOpen;
      if (serviciosOpen) {
        mobileServiciosPanel?.classList.remove('hidden');
        if (mobileServiciosChevron) mobileServiciosChevron.style.transform = 'rotate(180deg)';
      } else {
        mobileServiciosPanel?.classList.add('hidden');
        if (mobileServiciosChevron) mobileServiciosChevron.style.transform = '';
      }
    });

    // === MOBILE MENU ===
    let menuOpen = false;

    function closeMenu() {
      if (!overlay) return;
      overlay.classList.remove('open');
      setTimeout(() => overlay.classList.add('hidden'), 300);
      menuOpen = false;
      serviciosOpen = false;
      mobileServiciosPanel?.classList.add('hidden');
      if (mobileServiciosChevron) mobileServiciosChevron.style.transform = '';
      document.body.style.overflow = '';
      toggle?.setAttribute('aria-expanded', 'false');
      if (bar1) { bar1.style.transform = ''; bar1.style.width = ''; }
      if (bar2) bar2.style.opacity = '';
      if (bar3) { bar3.style.transform = ''; bar3.style.width = ''; bar3.style.marginLeft = ''; }
    }

    function openMenu() {
      if (!overlay) return;
      overlay.classList.remove('hidden');
      overlay.offsetHeight;
      overlay.classList.add('open');
      menuOpen = true;
      document.body.style.overflow = 'hidden';
      toggle?.setAttribute('aria-expanded', 'true');
      if (bar1) { bar1.style.transform = 'rotate(45deg) translate(4px, 6px)'; bar1.style.width = '1.25rem'; }
      if (bar2) bar2.style.opacity = '0';
      if (bar3) { bar3.style.transform = 'rotate(-45deg) translate(4px, -6px)'; bar3.style.width = '1.25rem'; bar3.style.marginLeft = '0'; }
    }

    toggle?.addEventListener('click', () => {
      if (menuOpen) closeMenu(); else openMenu();
    });

    backdrop?.addEventListener('click', closeMenu);

    overlay?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuOpen) closeMenu();
    });
  }

  initNavbar();
  document.addEventListener('astro:page-load', initNavbar);
</script>
