---
/**
 * Navbar.astro - Barra de navegacion fija con glassmorphism
 *
 * Comportamiento:
 * - Inicial: Glassmorphism sutil (blur + borde) flotante con margen superior
 * - Al scroll > 50px: Se expande a ancho completo, fondo mas solido, shadow elevada
 * - Transicion suave de 400ms entre estados
 * - Desktop: Links con dot indicator al hover + CTA con glow
 * - Mobile: Hamburguesa animada (X al abrir) + menu overlay fullscreen
 */
const links = [
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Servicios', href: '/servicios' },
  { label: 'Paquetes', href: '/#paquetes' },
  { label: 'Proyectos', href: '/#proyectos' },
  { label: 'Blog', href: '/#blog' },
  { label: 'Contacto', href: '/contacto' },
];
---

<!-- Contenedor exterior: agrega padding top para el efecto "flotante" -->
<div class="fixed top-0 left-0 right-0 z-50 px-4 sm:px-6 pt-4 transition-all duration-400" id="navbar-wrapper">
  <nav
    class="max-w-6xl mx-auto rounded-2xl border border-white/15 bg-white/5 backdrop-blur-xl transition-all duration-400"
    id="navbar"
  >
    <div class="px-5 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <!-- Logo: icono + texto -->
        <a href="/" class="flex items-center gap-2.5 group">
          <div class="w-9 h-9 rounded-xl gradient-bg flex items-center justify-center shadow-lg shadow-primary-500/30 group-hover:shadow-primary-500/50 transition-shadow">
            <span class="text-white font-black text-sm">PZ</span>
          </div>
          <span class="text-lg font-bold text-white hidden sm:block">
            Portafolio <span class="gradient-text">Z</span>
          </span>
        </a>

        <!-- Links de navegacion (desktop) -->
        <div class="hidden lg:flex items-center gap-1">
          {links.map((link) => (
            <a
              href={link.href}
              class="relative px-3.5 py-2 text-sm font-medium text-white/70 hover:text-white transition-colors rounded-lg hover:bg-white/10"
            >
              {link.label}
            </a>
          ))}
        </div>

        <!-- CTA + Hamburguesa -->
        <div class="flex items-center gap-3">
          <!-- CTA principal con borde glow -->
          <button
            data-open-cotizador
            class="hidden md:inline-flex items-center gap-2 gradient-bg text-white text-sm font-semibold px-5 py-2 rounded-xl hover:shadow-lg hover:shadow-accent-500/30 hover:scale-105 transition-all duration-300 cursor-pointer"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            Cotiza Ahora
          </button>

          <!-- Boton hamburguesa (mobile/tablet) -->
          <button
            class="lg:hidden text-white p-2 rounded-xl hover:bg-white/10 transition-colors relative w-10 h-10 flex items-center justify-center"
            id="mobile-toggle"
            aria-label="Abrir menú"
          >
            <span class="flex flex-col items-center justify-center gap-1.5">
              <span class="block w-5 h-[2px] bg-white rounded-full transition-all duration-300 origin-center" id="bar1"></span>
              <span class="block w-5 h-[2px] bg-white rounded-full transition-all duration-300" id="bar2"></span>
              <span class="block w-3.5 h-[2px] bg-white rounded-full transition-all duration-300 origin-center self-start ml-[3px]" id="bar3"></span>
            </span>
          </button>
        </div>
      </div>
    </div>
  </nav>
</div>

<!-- Menu mobile: overlay fullscreen con glassmorphism -->
<div class="fixed inset-0 z-40 hidden" id="mobile-overlay">
  <!-- Backdrop oscuro -->
  <div class="absolute inset-0 bg-dark-900/80 backdrop-blur-md" id="mobile-backdrop"></div>
  <!-- Panel de menu -->
  <div class="relative z-10 pt-24 px-6 pb-8 h-full flex flex-col overflow-y-auto">
    <div class="space-y-1">
      {links.map((link, i) => (
        <a
          href={link.href}
          class="mobile-link block text-white/80 hover:text-white text-xl font-semibold py-2.5 px-4 rounded-xl hover:bg-white/10 transition-all"
          style={`transition-delay: ${i * 50}ms`}
        >
          {link.label}
        </a>
      ))}
    </div>
    <!-- CTA mobile -->
    <div class="mt-8 pt-6 border-t border-white/10">
      <button
        data-open-cotizador
        class="mobile-link block w-full gradient-bg text-white text-lg font-semibold px-6 py-4 rounded-2xl text-center shadow-lg shadow-accent-500/25 cursor-pointer"
        style="transition-delay: 300ms"
      >
        Cotiza Ahora
      </button>
      <!-- Info de contacto rapido -->
      <div class="mobile-link mt-5 flex items-center justify-center gap-4 text-white/50 text-sm" style="transition-delay: 350ms">
        <a href="tel:+525561959724" class="hover:text-white transition-colors">55 6195 9724</a>
        <span>•</span>
        <a href="mailto:hola@portafolioz.com" class="hover:text-white transition-colors">hola@portafolioz.com</a>
      </div>
    </div>
  </div>
</div>

<style>
  /* Animacion de entrada de los links mobile */
  .mobile-link {
    opacity: 0;
    transform: translateX(-20px);
    transition: opacity 0.3s ease, transform 0.3s ease, background-color 0.2s ease, color 0.2s ease;
  }
  #mobile-overlay.open .mobile-link {
    opacity: 1;
    transform: translateX(0);
  }
</style>

<script>
  // Navbar init - compatible con ClientRouter (astro:page-load)
  function initNavbar() {
    const wrapper = document.getElementById('navbar-wrapper');
    const navbar = document.getElementById('navbar');
    const toggle = document.getElementById('mobile-toggle');
    const overlay = document.getElementById('mobile-overlay');
    const backdrop = document.getElementById('mobile-backdrop');
    const bar1 = document.getElementById('bar1');
    const bar2 = document.getElementById('bar2');
    const bar3 = document.getElementById('bar3');

    // Estado scrolled: navbar se expande a ancho completo y se solidifica
    function updateNavbar() {
      if (!wrapper || !navbar) return;
      if (window.scrollY > 50) {
        wrapper.classList.add('px-0', 'sm:px-0', 'pt-0');
        wrapper.classList.remove('px-4', 'sm:px-6', 'pt-4');
        navbar.classList.add('bg-dark-900/90', 'shadow-2xl', 'shadow-black/20', 'border-transparent');
        navbar.classList.remove('bg-white/5', 'border-white/15');
      } else {
        wrapper.classList.remove('px-0', 'sm:px-0', 'pt-0');
        wrapper.classList.add('px-4', 'sm:px-6', 'pt-4');
        navbar.classList.remove('bg-dark-900/90', 'shadow-2xl', 'shadow-black/20', 'border-transparent');
        navbar.classList.add('bg-white/5', 'border-white/15');
      }
    }
    updateNavbar();
    window.addEventListener('scroll', updateNavbar);

    // Mobile menu toggle
    let menuOpen = false;

    function closeMenu() {
      if (!overlay) return;
      overlay.classList.remove('open');
      // Esperar animacion antes de ocultar
      setTimeout(() => {
        overlay.classList.add('hidden');
      }, 300);
      menuOpen = false;
      document.body.style.overflow = '';
      // Reset hamburguesa
      if (bar1) { bar1.style.transform = ''; bar1.style.width = ''; }
      if (bar2) bar2.style.opacity = '';
      if (bar3) { bar3.style.transform = ''; bar3.style.width = ''; bar3.style.marginLeft = ''; }
    }

    function openMenu() {
      if (!overlay) return;
      overlay.classList.remove('hidden');
      // Forzar reflow para que la animacion se active
      overlay.offsetHeight;
      overlay.classList.add('open');
      menuOpen = true;
      document.body.style.overflow = 'hidden';
      // Animar hamburguesa -> X
      if (bar1) { bar1.style.transform = 'rotate(45deg) translate(4px, 6px)'; bar1.style.width = '1.25rem'; }
      if (bar2) bar2.style.opacity = '0';
      if (bar3) { bar3.style.transform = 'rotate(-45deg) translate(4px, -6px)'; bar3.style.width = '1.25rem'; bar3.style.marginLeft = '0'; }
    }

    toggle?.addEventListener('click', () => {
      if (menuOpen) closeMenu();
      else openMenu();
    });

    // Cerrar al click en backdrop
    backdrop?.addEventListener('click', closeMenu);

    // Cerrar al click en link
    overlay?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Cerrar con Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuOpen) closeMenu();
    });
  }

  // Ejecutar en carga inicial y en cada navegacion con ClientRouter
  initNavbar();
  document.addEventListener('astro:page-load', initNavbar);
</script>
