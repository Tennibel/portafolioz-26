---

---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <img
    src="/img/hero/hero-mockup.webp"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover object-center contrast-115 saturate-115 brightness-105"
    width="1920"
    height="1080"
    loading="eager"
  />
  <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/35 via-primary-500/30 to-accent-600/35"></div>
  <div class="absolute inset-0 bg-black/20"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/45 to-black/20"></div>
  <div class="absolute top-20 right-20 w-96 h-96 bg-pink-500/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 left-10 w-80 h-80 bg-cyan-400/20 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
    <p class="text-cyan-100 font-medium text-sm uppercase tracking-widest mb-6" data-animate>
      Agencia de Diseño Web
    </p>
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-6" data-animate>
      Diseñamos Sitios Web<br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 via-white to-pink-300">para Vender Más</span>
    </h1>
    <p class="text-lg md:text-xl text-white/95 max-w-3xl mx-auto mb-10" data-animate>
      Convertimos empresas sin presencia online, en marcas con autoridad en internet, incrementando ventas y generando posicionamiento en cada sector.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate>
      <button data-open-cotizador class="bg-white text-primary-600 font-bold px-8 py-4 rounded-full text-lg hover:bg-white/90 transition-all hover:scale-105 shadow-xl cursor-pointer">
        Cotiza Ahora
      </button>
      <a href="#proyectos" class="border-2 border-white/40 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all">
        Ver Proyectos
      </a>
    </div>
    <div class="grid grid-cols-3 gap-4 mt-16 max-w-xl mx-auto" data-animate>
      <div class="p-5 text-center rounded-2xl border border-cyan-100/55 bg-cyan-500/50 backdrop-blur-md shadow-lg shadow-cyan-900/35 hover:bg-cyan-500/60 transition-colors">
        <p class="text-3xl font-bold text-white">30+</p>
        <p class="text-white/90 text-sm mt-1">Clientes</p>
      </div>
      <div class="p-5 text-center rounded-2xl border border-sky-100/55 bg-sky-500/50 backdrop-blur-md shadow-lg shadow-sky-900/35 hover:bg-sky-500/60 transition-colors">
        <p class="text-3xl font-bold text-white">3</p>
        <p class="text-white/90 text-sm mt-1">Países</p>
      </div>
      <div class="p-5 text-center rounded-2xl border border-indigo-100/55 bg-indigo-500/50 backdrop-blur-md shadow-lg shadow-indigo-900/35 hover:bg-indigo-500/60 transition-colors">
        <p class="text-3xl font-bold text-white">+12</p>
        <p class="text-white/90 text-sm mt-1">Años</p>
      </div>
    </div>

  </div>
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
