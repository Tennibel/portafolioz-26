---
/**
 * sector/medicos.astro - Landing page: Páginas Web para Médicos y Clínicas
 *
 * Secciones:
 * 1. Hero con breadcrumb (split layout con imagen)
 * 2. Features especializados (grid + imagen)
 * 3. Caso real (before/after + imagen)
 * 4. Planes recomendados (3 columnas)
 * 5. CTA Final
 */
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppWidget from '../../components/WhatsAppWidget.astro';

const features = [
  {
    icon: '🩺',
    title: 'Perfil médico profesional',
    desc: 'Foto profesional, especialidades, cédula profesional y certificaciones visibles para generar confianza desde el primer clic.',
  },
  {
    icon: '📅',
    title: 'Sistema de citas online',
    desc: 'Integración con Calendly o Google Calendar para que tus pacientes agenden cita las 24 horas sin llamar.',
  },
  {
    icon: '📸',
    title: 'Galería antes/después',
    desc: 'Ideal para dentistas, dermatólogos y cirujanos. Muestra resultados reales que convencen a nuevos pacientes.',
  },
  {
    icon: '📍',
    title: 'Mapa de ubicación',
    desc: 'Google Maps integrado con indicaciones precisas para que tus pacientes lleguen sin problema a tu consultorio.',
  },
  {
    icon: '💬',
    title: 'WhatsApp pre-configurado',
    desc: 'Botón de WhatsApp con mensaje listo: "Hola, quiero agendar una cita con el Dr..." para maximizar conversiones.',
  },
  {
    icon: '🔍',
    title: 'SEO local optimizado',
    desc: 'Posicionamiento para búsquedas como "dentista en [colonia/ciudad]" para atraer pacientes de tu zona.',
  },
  {
    icon: '🏥',
    title: 'Schema markup médico',
    desc: 'Marcado estructurado Physician, MedicalClinic y LocalBusiness para destacar en los resultados de Google.',
  },
  {
    icon: '✅',
    title: 'Cumplimiento normativo',
    desc: 'Diseño alineado con las normativas de publicidad médica vigentes para evitar problemas legales.',
  },
];

const planes = [
  {
    name: 'Landing Performance',
    price: '$3,800',
    renewal: '$1,840',
    delivery: '7 días',
    desc: 'Ideal para consultorios nuevos',
    accent: 'cyan',
    popular: false,
    features: [
      'Hosting y Dominio incluido',
      'Certificado SSL',
      'Landing page de alta conversión',
      'Perfil médico profesional',
      'Botón WhatsApp con mensaje pre-configurado',
      'Formulario de contacto',
      'Google Analytics 4',
      'Responsive (móvil + desktop)',
      'SEO básico on-page',
      '1 ronda de revisiones',
    ],
  },
  {
    name: 'Web Corporativa',
    price: '$6,400',
    renewal: '$2,450',
    delivery: '15 días',
    desc: 'Para clínicas establecidas',
    accent: 'teal',
    popular: true,
    features: [
      'Hosting y Dominio incluido',
      'Certificado SSL',
      'Hasta 6 secciones personalizadas',
      'Perfil médico + equipo',
      'Sistema de citas online (Calendly)',
      'Galería antes/después',
      'Google Maps con indicaciones',
      'WhatsApp CTA en cada página',
      'SEO técnico + local',
      'Core Web Vitals score 90+',
      '2 rondas de revisiones',
    ],
  },
  {
    name: 'Web SEO Performance',
    price: '$8,900',
    renewal: '$3,140',
    delivery: '20 días',
    desc: 'Para dominar Google en tu zona',
    accent: 'indigo',
    popular: false,
    features: [
      'Hosting y Dominio incluido',
      'Certificado SSL',
      'Hasta 10 páginas optimizadas',
      'Schema markup: Physician + MedicalClinic',
      'Keyword research médico',
      'Contenido SEO por especialidad',
      'Google Search Console',
      'Google Analytics 4 + eventos',
      'Sitemap XML + robots.txt',
      'Velocidad score 95+',
      'Cumplimiento normativo',
      '2 rondas de revisiones',
    ],
  },
];

const accentColors: Record<string, { border: string; check: string; badge: string; btn: string }> = {
  cyan: { border: 'border-cyan-500/30', check: 'text-cyan-400', badge: 'bg-cyan-500/20 text-cyan-300', btn: 'border-cyan-500 text-cyan-400 hover:bg-cyan-500 hover:text-white' },
  teal: { border: 'border-teal-500/30', check: 'text-teal-400', badge: 'bg-teal-500/20 text-teal-300', btn: 'border-teal-500 text-teal-400 hover:bg-teal-500 hover:text-white' },
  indigo: { border: 'border-indigo-500/30', check: 'text-indigo-400', badge: 'bg-indigo-500/20 text-indigo-300', btn: 'border-indigo-500 text-indigo-400 hover:bg-indigo-500 hover:text-white' },
};

const plansWithColors = planes.map((plan) => ({
  ...plan,
  colors: accentColors[plan.accent],
  cardClass: plan.popular
    ? 'bg-gradient-to-br from-teal-600/20 via-cyan-600/20 to-indigo-600/20 text-white ring-2 ring-teal-400/50 shadow-2xl shadow-teal-500/20 scale-105 border border-teal-500/30'
    : 'bg-dark-800/80 backdrop-blur-sm text-white border ' + accentColors[plan.accent].border,
  btnClass: plan.popular
    ? 'bg-gradient-to-r from-teal-500 to-cyan-500 border-transparent text-white hover:opacity-90 shadow-lg shadow-teal-500/25'
    : accentColors[plan.accent].btn,
}));
---

<Layout title="Páginas Web para Médicos y Clínicas | Portafolio Z" description="Diseño web especializado para consultorios y clínicas. Sistema de citas online, perfil médico, especialidades. Desde $3,800 MXN.">
  <Navbar />

  <!-- SECCION 1: Hero con breadcrumb -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-teal-600 via-cyan-600 to-indigo-600"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-cyan-400/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-teal-400/20 rounded-full blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-white/60 mb-6" data-animate>
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <span>Sectores</span>
        <span>/</span>
        <span class="text-white">Médicos</span>
      </nav>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div data-animate>
          <h1 class="text-4xl sm:text-5xl lg:text-5xl font-bold text-white mb-6 leading-tight">
            Páginas Web para Médicos y Clínicas que <span class="text-cyan-300">Generan Pacientes</span>
          </h1>
          <p class="text-lg text-white/80 mb-8 leading-relaxed">
            Tu consultorio necesita más que una página bonita. Necesita un sistema que atraiga pacientes desde Google, los convierta por WhatsApp y <strong class="text-white">llene tu agenda.</strong>
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <button data-open-cotizador class="bg-white text-teal-600 font-bold px-8 py-4 rounded-full text-lg hover:bg-white/90 transition-all hover:scale-105 shadow-xl cursor-pointer">
              Cotiza Tu Sitio Médico
            </button>
            <a href="https://wa.me/525561959724" target="_blank" rel="noopener" class="border-2 border-white/40 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all text-center">
              Hablar por WhatsApp
            </a>
          </div>
          <div class="flex flex-wrap gap-6 text-white/70 text-sm">
            <span class="flex items-center gap-2"><span class="text-cyan-300 font-bold">Desde $3,800</span> MXN</span>
            <span class="hidden sm:block">|</span>
            <span class="flex items-center gap-2"><span class="text-cyan-300 font-bold">7-20 días</span> de entrega</span>
            <span class="hidden sm:block">|</span>
            <span class="flex items-center gap-2">SEO <span class="text-cyan-300 font-bold">local</span></span>
          </div>
        </div>
        <div class="hidden lg:block" data-animate>
          <div class="bg-gradient-to-br from-cyan-500/20 to-indigo-500/20 rounded-2xl overflow-hidden aspect-video flex items-center justify-center">
            <img src="/img/sectores/medicos-hero.webp" alt="Mockup de página web profesional para consultorio médico con sistema de citas online" class="rounded-2xl shadow-xl w-full h-auto object-cover" loading="eager" />
            <span class="text-white/40 text-sm absolute">Imagen: Mockup de sitio web médico</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION 2: Features especializados -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6" data-animate>
        <p class="text-sm font-semibold text-teal-500 tracking-wider uppercase mb-3">Funcionalidades médicas</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
          Todo Lo Que Tu Consultorio Necesita en una <span class="gradient-text">Página Web</span>
        </h2>
      </div>
      <p class="text-gray-600 text-center max-w-3xl mx-auto mb-16" data-animate>
        No es una página genérica adaptada. Es un sitio web diseñado específicamente para profesionales de la salud, con funcionalidades que tus pacientes esperan encontrar.
      </p>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {features.map((f) => (
            <div class="p-5 rounded-xl bg-gray-50 border border-gray-100 hover:shadow-lg transition-all group" data-animate>
              <div class="text-2xl mb-3 group-hover:scale-110 transition-transform">{f.icon}</div>
              <h3 class="text-base font-bold text-gray-900 mb-1">{f.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
        <div class="hidden lg:flex flex-col gap-6" data-animate>
          <div class="bg-gradient-to-br from-cyan-500/20 to-indigo-500/20 rounded-2xl overflow-hidden aspect-video flex items-center justify-center relative">
            <img src="/img/sectores/medicos-consultorio.webp" alt="Fotografía de consultorio médico moderno con doctor atendiendo pacientes" class="rounded-2xl shadow-xl w-full h-auto object-cover" loading="lazy" />
            <span class="text-white/40 text-sm absolute">Imagen: Consultorio médico profesional</span>
          </div>
          <div class="bg-gradient-to-br from-cyan-500/20 to-indigo-500/20 rounded-2xl overflow-hidden aspect-video flex items-center justify-center relative">
            <img src="/img/sectores/medicos-citas.webp" alt="Captura de pantalla del sistema de citas online integrado en página web médica" class="rounded-2xl shadow-xl w-full h-auto object-cover" loading="lazy" />
            <span class="text-white/40 text-sm absolute">Imagen: Sistema de citas online</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION 3: Caso real -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-teal-600 via-cyan-600 to-indigo-600"></div>
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-3xl -translate-y-1/2"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl translate-y-1/2"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6" data-animate>
        <p class="text-sm font-semibold text-cyan-300 tracking-wider uppercase mb-3">Caso de éxito</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">
          Clínica Dental Premium: <span class="text-cyan-300">+200% Consultas</span> en 60 Días
        </h2>
      </div>
      <p class="text-white/70 text-center max-w-3xl mx-auto mb-16" data-animate>
        Con el plan Web Corporativa, esta clínica dental triplicó sus consultas por WhatsApp en solo 2 meses.
      </p>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8" data-animate>
          <!-- Before -->
          <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-6">
            <div class="flex items-center gap-2 mb-4">
              <span class="bg-red-500/20 text-red-300 text-xs font-bold px-3 py-1 rounded-full">ANTES</span>
            </div>
            <ul class="space-y-3 text-white/80 text-sm">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                <span>Página web en Wix, lenta y sin diseño profesional</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                <span>Sin SEO local ni posicionamiento en Google</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                <span>Sin botón de WhatsApp ni sistema de citas</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                <span><strong class="text-white">8 consultas nuevas por mes</strong></span>
              </li>
            </ul>
          </div>
          <!-- After -->
          <div class="bg-white/10 backdrop-blur-md border border-cyan-400/30 rounded-2xl p-6">
            <div class="flex items-center gap-2 mb-4">
              <span class="bg-cyan-500/20 text-cyan-300 text-xs font-bold px-3 py-1 rounded-full">DESPUÉS</span>
            </div>
            <ul class="space-y-3 text-white/80 text-sm">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span><strong class="text-white">+200% consultas por WhatsApp</strong> en 60 días</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span><strong class="text-white">24 pacientes nuevos/mes</strong> (antes 8)</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Score PageSpeed: <strong class="text-white">de 35 a 97</strong></span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Primera página de Google para "dentista en su zona"</span>
              </li>
            </ul>
          </div>
          <!-- Stats -->
          <div class="grid grid-cols-3 gap-4">
            <div class="text-center bg-white/10 backdrop-blur-md rounded-xl p-4">
              <div class="text-3xl font-extrabold text-cyan-300">+200%</div>
              <div class="text-xs text-white/60 mt-1">Más consultas</div>
            </div>
            <div class="text-center bg-white/10 backdrop-blur-md rounded-xl p-4">
              <div class="text-3xl font-extrabold text-cyan-300">24</div>
              <div class="text-xs text-white/60 mt-1">Pacientes/mes</div>
            </div>
            <div class="text-center bg-white/10 backdrop-blur-md rounded-xl p-4">
              <div class="text-3xl font-extrabold text-cyan-300">97</div>
              <div class="text-xs text-white/60 mt-1">PageSpeed</div>
            </div>
          </div>
        </div>
        <div class="space-y-6" data-animate>
          <div class="bg-gradient-to-br from-cyan-500/20 to-indigo-500/20 rounded-2xl overflow-hidden aspect-video flex items-center justify-center relative">
            <img src="/img/sectores/medicos-consultorio.webp" alt="Antes y después de la página web de Clínica Dental Premium" class="rounded-2xl shadow-xl w-full h-auto object-cover" loading="lazy" />
            <span class="text-white/40 text-sm absolute">Imagen: Caso de éxito Clínica Dental</span>
          </div>
          <!-- Testimonial quote -->
          <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-6">
            <div class="flex gap-1 mb-3">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <p class="text-white/90 italic leading-relaxed mb-4">
              "Desde que tenemos nuestra nueva página web, recibimos 3 veces más consultas por WhatsApp. Los pacientes nos encuentran en Google y agendan cita el mismo día."
            </p>
            <div>
              <p class="font-semibold text-white">Dra. Claudia M.</p>
              <p class="text-sm text-cyan-300">Clínica Dental Premium, CDMX</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION 4: Planes recomendados -->
  <section class="relative bg-dark-900 py-24 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(20,184,166,0.15),transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,rgba(6,182,212,0.15),transparent_50%)]"></div>
    <div class="absolute top-10 left-1/4 w-64 h-64 bg-teal-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-1/4 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6" data-animate>
        <p class="text-cyan-400 font-medium text-sm uppercase tracking-widest mb-3">Planes para médicos</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          Elige el Plan Ideal para Tu <span class="gradient-text">Consultorio</span>
        </h2>
      </div>
      <p class="text-gray-400 text-center max-w-3xl mx-auto mb-16" data-animate>
        Todos los planes incluyen: hosting y dominio el primer año, certificado SSL, diseño a la medida, responsive, WhatsApp CTA, Google Analytics y soporte post-lanzamiento.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8" data-animate>
        {plansWithColors.map((plan) => (
          <div class={`relative rounded-2xl p-7 transition-all duration-300 hover:-translate-y-2 ${plan.cardClass}`}>
            {plan.popular && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                <span class="bg-gradient-to-r from-teal-500 to-cyan-500 text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-lg">Recomendado</span>
              </div>
            )}
            <div class={`inline-flex items-center gap-1.5 ${plan.colors.badge} text-xs font-medium px-3 py-1 rounded-full mb-4`}>
              <span>{plan.delivery}</span>
            </div>
            <h3 class="text-lg font-bold mb-1 text-white">{plan.name}</h3>
            <p class="text-xs mb-5 text-gray-400">{plan.desc}</p>
            <div class="mb-2">
              <span class="text-3xl font-extrabold text-white">{plan.price}</span>
              <span class="text-xs ml-1 text-gray-500">MXN + IVA</span>
            </div>
            <p class="text-[10px] text-gray-500 mb-5">Renovación anual: {plan.renewal} + IVA</p>
            <ul class="space-y-2.5 mb-6">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm">
                  <svg class={`w-4 h-4 flex-shrink-0 mt-0.5 ${plan.colors.check}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-gray-300">{f}</span>
                </li>
              ))}
            </ul>
            <button data-open-cotizador class={`w-full text-center font-semibold py-3 px-5 rounded-full transition-all text-sm border-2 cursor-pointer ${plan.btnClass}`}>
              Cotiza Este Plan
            </button>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCION 5: CTA Final -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-teal-600 via-cyan-600 to-indigo-600"></div>
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-0 left-0 w-96 h-96 bg-white/5 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-80 h-80 bg-cyan-400/10 rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center" data-animate>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Tu próximo paciente te está buscando en <span class="text-cyan-300">Google</span>
      </h2>
