---
/**
 * inmobiliarias.astro - Landing page: Sitios Web para Inmobiliarias
 *
 * Secciones:
 * 1. Hero con breadcrumb (split layout con imagen)
 * 2. Features especializados (grid con imagen)
 * 3. Planes (3 columnas)
 * 4. CTA Final
 */
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppWidget from '../../components/WhatsAppWidget.astro';

const features = [
  {
    icon: '🏠',
    title: 'Catálogo de propiedades',
    desc: 'Muestra cada propiedad con fotos profesionales, precio, ubicación, características y disponibilidad. Tu catálogo siempre actualizado y atractivo.',
  },
  {
    icon: '🔍',
    title: 'Búsqueda por filtros',
    desc: 'Tus prospectos filtran por tipo de propiedad, rango de precio, ubicación, número de recámaras y metros cuadrados para encontrar lo que buscan al instante.',
  },
  {
    icon: '🖼️',
    title: 'Ficha individual por propiedad',
    desc: 'Cada propiedad tiene su propia página con galería de fotos, mapa interactivo, descripción detallada y botón de contacto directo.',
  },
  {
    icon: '💬',
    title: 'WhatsApp con contexto',
    desc: 'Botón de WhatsApp inteligente: "Me interesa la propiedad [nombre] en [ubicación]". El prospecto llega con intención clara de compra.',
  },
  {
    icon: '🔗',
    title: 'Integración con portales',
    desc: 'Conecta tu sitio con portales inmobiliarios como Inmuebles24, Segundamano y Vivanuncios para sincronizar tu inventario (opcional).',
  },
  {
    icon: '📍',
    title: 'SEO local inmobiliario',
    desc: 'Posiciónate en búsquedas como "casas en venta en [colonia/ciudad]", "departamentos en renta en [zona]" y captura tráfico orgánico de alta intención.',
  },
  {
    icon: '🏷️',
    title: 'Schema markup especializado',
    desc: 'Implementamos datos estructurados RealEstateAgent, Product y Offer para que Google muestre rich snippets de tus propiedades en los resultados.',
  },
  {
    icon: '👤',
    title: 'Sección de agentes/asesores',
    desc: 'Presenta a tu equipo de asesores inmobiliarios con foto, especialidad y contacto directo. Genera confianza desde el primer clic.',
  },
];

const planes = [
  {
    name: 'Web Corporativa',
    price: '$6,400',
    renewal: '$2,450',
    delivery: '15 días',
    desc: 'Sitio con catálogo básico',
    accent: 'amber',
    popular: false,
    features: [
      'Hosting y Dominio incluido',
      'Certificado SSL',
      'Diseño personalizado multi-página',
      'Catálogo de propiedades básico',
      'Ficha individual por propiedad',
      'WhatsApp CTA en cada página',
      'SEO básico on-page',
      'Google Analytics 4 + GTM',
      'Google Maps integrado',
      'Responsive perfecto',
      '2 rondas de revisiones',
    ],
  },
  {
    name: 'Web SEO Performance',
    price: '$8,900',
    renewal: '$3,140',
    delivery: '20 días',
    desc: 'Posiciónate en Google',
    accent: 'orange',
    popular: true,
    features: [
      'Todo lo del plan Corporativa más:',
      'Arquitectura SEO completa',
      'Búsqueda por filtros avanzada',
      'Keyword research inmobiliario',
      'Contenido SEO optimizado',
      'Schema markup: RealEstateAgent, Offer',
      'SEO local por colonia/ciudad',
      'Google Search Console',
      'Sitemap XML + robots.txt',
      'Velocidad score 95+',
      '2 rondas de revisiones',
    ],
  },
  {
    name: 'Headless Premium',
    price: '$10,600',
    renewal: '$3,860',
    delivery: '25 días',
    desc: 'Catálogo autoadministrable',
    accent: 'amber',
    popular: false,
    features: [
      'Todo lo del plan SEO Performance más:',
      'WordPress como CMS headless',
      'Catálogo autoadministrable',
      'Agrega propiedades sin programar',
      'Sección de agentes con contacto',
      'Integración portales (opcional)',
      'Panel de administración personalizado',
      'Capacitación incluida',
      'SEO técnico avanzado',
      '3 rondas de revisiones',
    ],
  },
];

const accentColors: Record<string, { border: string; check: string; badge: string; btn: string }> = {
  amber: { border: 'border-amber-500/30', check: 'text-amber-400', badge: 'bg-amber-500/20 text-amber-300', btn: 'border-amber-500 text-amber-400 hover:bg-amber-500 hover:text-white' },
  orange: { border: 'border-orange-500/30', check: 'text-orange-400', badge: 'bg-orange-500/20 text-orange-300', btn: 'border-orange-500 text-orange-400 hover:bg-orange-500 hover:text-white' },
};

const plansWithColors = planes.map((plan) => ({
  ...plan,
  colors: accentColors[plan.accent],
  cardClass: plan.popular
    ? 'bg-gradient-to-br from-orange-600/20 via-amber-600/20 to-yellow-600/20 text-white ring-2 ring-orange-400/50 shadow-2xl shadow-orange-500/20 scale-105 border border-orange-500/30'
    : 'bg-dark-800/80 backdrop-blur-sm text-white border ' + accentColors[plan.accent].border,
  btnClass: plan.popular
    ? 'bg-gradient-to-r from-orange-500 to-amber-500 border-transparent text-white hover:opacity-90 shadow-lg shadow-orange-500/25'
    : accentColors[plan.accent].btn,
}));
---

<Layout title="Sitios Web para Inmobiliarias | Catálogo de Propiedades Online | Portafolio Z" description="Diseño web para inmobiliarias con catálogo de propiedades, búsqueda por filtros y WhatsApp directo. Desde $6,400 MXN.">
  <Navbar />

  <!-- SECCION 1: Hero con breadcrumb (split layout) -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-amber-600 via-orange-500 to-amber-500"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-orange-400/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-amber-400/20 rounded-full blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-white/60 mb-8" data-animate>
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <span>Sectores</span>
        <span>/</span>
        <span class="text-white">Inmobiliarias</span>
      </nav>
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div data-animate>
          <h1 class="text-4xl sm:text-5xl lg:text-5xl font-bold text-white mb-6 leading-tight">
            Sitios Web para Inmobiliarias que <span class="text-amber-200">Venden Propiedades</span>
          </h1>
          <p class="text-xl text-white/80 mb-8 leading-relaxed">
            Un catálogo de propiedades profesional, rápido y optimizado para Google. Tus prospectos encuentran la propiedad ideal y te contactan al instante.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="https://wa.me/5215564721547?text=Hola%2C%20me%20interesa%20un%20sitio%20web%20para%20mi%20*Inmobiliaria*.%20%C2%BFMe%20pueden%20dar%20m%C3%A1s%20informaci%C3%B3n%3F" target="_blank" rel="noopener" class="wa-lead bg-white text-orange-600 font-bold px-8 py-4 rounded-full text-lg hover:bg-white/90 transition-all hover:scale-105 shadow-xl" data-plan="General" data-price="Desde $6,400" data-category="Sector Inmobiliarias">
              Cotiza Tu Sitio Inmobiliario
            </a>
            <a href="https://wa.me/5215564721547?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20sitios%20web%20para%20*Inmobiliarias*." target="_blank" rel="noopener" class="wa-lead border-2 border-white/40 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all text-center" data-plan="General" data-price="Desde $6,400" data-category="Sector Inmobiliarias">
              Hablar por WhatsApp
            </a>
          </div>
          <div class="flex flex-wrap gap-6 text-white/70 text-sm">
            <span class="flex items-center gap-2">Desde <span class="text-amber-200 font-bold">$6,400 MXN</span></span>
            <span class="hidden sm:block">|</span>
            <span class="flex items-center gap-2"><span class="text-amber-200 font-bold">15 días</span> de entrega</span>
            <span class="hidden sm:block">|</span>
            <span class="flex items-center gap-2"><span class="text-amber-200 font-bold">SEO</span> inmobiliario</span>
          </div>
        </div>
        <div class="relative" data-animate>
          <div class="relative bg-gradient-to-br from-amber-500/20 to-orange-500/20 rounded-2xl overflow-hidden aspect-video flex items-center justify-center">
            <img src="/img/sectores/inmobiliarias-hero.webp" alt="Sitio web para inmobiliaria" class="rounded-2xl w-full h-auto object-cover" loading="lazy" />
            <span class="text-white/40 text-sm absolute">Imagen: Catálogo de propiedades online</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION 2: Features Especializados -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6" data-animate>
        <p class="text-sm font-semibold text-orange-500 tracking-wider uppercase mb-3">Funcionalidades clave</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
          Todo lo que Tu <span class="bg-gradient-to-r from-amber-500 to-orange-500 bg-clip-text text-transparent">Inmobiliaria Necesita</span> en la Web
        </h2>
      </div>
      <p class="text-gray-600 text-center max-w-3xl mx-auto mb-16" data-animate>
        Funcionalidades pensadas para el sector inmobiliario: desde catálogos con filtros hasta SEO local para que te encuentren quienes buscan comprar o rentar en tu zona.
      </p>
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {features.map((f) => (
            <div class="relative p-5 rounded-2xl bg-gray-50 border border-gray-100 hover:shadow-lg transition-all group" data-animate>
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-500 to-orange-500 flex items-center justify-center text-xl mb-4 group-hover:scale-110 transition-transform">
                {f.icon}
              </div>
              <h3 class="text-base font-bold text-gray-900 mb-1">{f.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
        <div class="space-y-6 lg:sticky lg:top-24">
          <div class="relative bg-gradient-to-br from-amber-500/20 to-orange-500/20 rounded-2xl overflow-hidden aspect-video flex items-center justify-center" data-animate>
            <img src="/img/sectores/inmobiliarias-catalogo.webp" alt="Catálogo de propiedades inmobiliarias" class="rounded-2xl w-full h-auto object-cover" loading="lazy" />
            <span class="text-white/40 text-sm absolute">Imagen: Catálogo de propiedades con filtros</span>
          </div>
          <div class="relative bg-gradient-to-br from-amber-500/20 to-orange-500/20 rounded-2xl overflow-hidden aspect-video flex items-center justify-center" data-animate>
            <img src="/img/sectores/inmobiliarias-ficha.webp" alt="Ficha de propiedad inmobiliaria" class="rounded-2xl w-full h-auto object-cover" loading="lazy" />
            <span class="text-white/40 text-sm absolute">Imagen: Ficha individual de propiedad</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION 3: Planes -->
  <section class="relative bg-dark-900 py-24 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(245,158,11,0.15),transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,rgba(249,115,22,0.15),transparent_50%)]"></div>
    <div class="absolute top-10 left-1/4 w-64 h-64 bg-amber-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-1/4 w-80 h-80 bg-orange-500/10 rounded-full blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6" data-animate>
        <p class="text-orange-400 font-medium text-sm uppercase tracking-widest mb-3">Paquetes para Inmobiliarias</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          Planes de Diseño Web para Tu <span class="bg-gradient-to-r from-amber-400 to-orange-400 bg-clip-text text-transparent">Inmobiliaria</span>
        </h2>
      </div>
      <p class="text-gray-400 text-center max-w-3xl mx-auto mb-16" data-animate>
        Todos los planes incluyen: hosting y dominio el primer año, certificado SSL, diseño a la medida, responsive, WhatsApp CTA, Google Analytics y soporte post-lanzamiento.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto" data-animate>
        {plansWithColors.map((plan) => (
          <div class={`relative rounded-2xl p-7 transition-all duration-300 hover:-translate-y-2 ${plan.cardClass}`}>
            {plan.popular && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                <span class="bg-gradient-to-r from-orange-500 to-amber-500 text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-lg">Recomendado</span>
              </div>
            )}
            <div class={`inline-flex items-center gap-1.5 ${plan.colors.badge} text-xs font-medium px-3 py-1 rounded-full mb-4`}>
              <span>{plan.delivery}</span>
            </div>
            <h3 class="text-lg font-bold mb-1 text-white">{plan.name}</h3>
            <p class="text-xs mb-5 text-gray-400">{plan.desc}</p>
            <div class="mb-2">
              <span class="text-3xl font-extrabold text-white">{plan.price}</span>
              <span class="text-xs ml-1 text-gray-500">MXN + IVA</span>
            </div>
            <p class="text-[10px] text-gray-500 mb-5">Renovación anual: {plan.renewal} + IVA</p>
            <ul class="space-y-2.5 mb-6">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm">
                  <svg class={`w-4 h-4 flex-shrink-0 mt-0.5 ${plan.colors.check}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-gray-300">{f}</span>
                </li>
              ))}
            </ul>
            <a href={`https://wa.me/5215564721547?text=Hola%2C%20me%20interesa%20el%20plan%20*${encodeURIComponent(plan.name)}*%20(${encodeURIComponent(plan.price)})%20para%20Inmobiliarias.%20%C2%BFMe%20pueden%20dar%20m%C3%A1s%20informaci%C3%B3n%3F`} target="_blank" rel="noopener" class={`wa-lead w-full text-center font-semibold py-3 px-5 rounded-full transition-all text-sm border-2 ${plan.btnClass}`} data-plan={plan.name} data-price={plan.price} data-category="Sector Inmobiliarias">
              Cotiza Tu Sitio Inmobiliario
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCION 4: CTA Final -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-amber-600 via-orange-500 to-amber-500"></div>
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-0 left-0 w-96 h-96 bg-white/5 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-80 h-80 bg-orange-400/10 rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4" data-animate>
        Tu próxima venta empieza con un <span class="text-amber-200">click</span>
      </h2>
      <p class="text-white/80 text-lg mb-8 max-w-2xl mx-auto" data-animate>
        Deja de perder prospectos que buscan propiedades en Google y no te encuentran. Con un sitio web profesional, tu catálogo trabaja 24/7 para generar leads calificados.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-6" data-animate>
        <a href="https://wa.me/5215564721547?text=Hola%2C%20vi%20su%20servicio%20de%20*sitios%20web%20para%20Inmobiliarias*%20y%20me%20gustar%C3%ADa%20cotizar.%20%C2%BFMe%20pueden%20asesorar%3F" target="_blank" rel="noopener" class="wa-lead bg-white text-orange-600 font-bold px-8 py-4 rounded-full text-lg hover:bg-white/90 transition-all hover:scale-105 shadow-xl" data-plan="CTA Final" data-price="Desde $6,400" data-category="Sector Inmobiliarias">
          Cotiza Tu Sitio Inmobiliario
        </a>
        <a href="https://wa.me/5215564721547?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20sitios%20web%20para%20*Inmobiliarias*." target="_blank" rel="noopener" class="wa-lead border-2 border-white text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all" data-plan="CTA Final" data-price="Desde $6,400" data-category="Sector Inmobiliarias">
          Hablar por WhatsApp
        </a>
      </div>
      <p class="text-white/50 text-sm" data-animate>Desde $6,400 MXN + IVA · Entrega en 15 días · Respuesta en menos de 2 horas</p>
    </div>
  </section>

  <Footer />
  <WhatsAppWidget />

  <script>
    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll('.wa-lead').forEach((btn) => {
        btn.addEventListener('click', () => {
          const el = btn as HTMLElement;
          if (typeof gtag === 'function') {
            gtag('event', 'generate_lead', {
              event_category: 'WhatsApp',
              plan_name: el.dataset.plan || '',
              plan_price: el.dataset.price || '',
              category: el.dataset.category || '',
              source_page: 'sector-inmobiliarias',
            });
          }
        });
      });
    });
  </script>
</Layout>
