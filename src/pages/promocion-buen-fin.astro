---
/**
 * promocion-buen-fin.astro - Landing campaña Buen Fin 2026
 *
 * Colores campaña: Negro + Rojo + Dorado (colores oficiales Buen Fin)
 * Descuento: 10% en todos los paquetes
 * Fecha: 20-23 de noviembre 2026
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';

const features = [
  { icon: '🌐', title: 'Hosting y Dominio Web', desc: 'Registro de dominio y hosting incluido por un ano. Asistencia tecnica garantizada.' },
  { icon: '🎨', title: 'Desarrollo Web a la Medida', desc: 'Diseno personalizado que captura la esencia de tu marca. 100% adaptado a tu proyecto.' },
  { icon: '🖼️', title: 'Banco de Imagenes', desc: 'Recursos de los principales bancos de imagenes mundiales incluidos sin costo adicional.' },
  { icon: '🔒', title: 'Navegacion Segura', desc: 'Certificado SSL, seguridad contra ataques y backups semanales incluidos.' },
  { icon: '🔍', title: 'Posicionamiento en Google', desc: 'SEO basico incluido en todos los planes. Posicionate en los primeros lugares.' },
  { icon: '🛟', title: 'Soporte y Capacitacion', desc: 'Soporte tecnico y capacitaciones para gestionar tu sitio web o tienda online.' },
];

const planes = [
  {
    name: 'Emprendedor',
    originalPrice: '$6,900',
    promoPrice: '$6,210',
    savings: '$690',
    desc: 'Para convertir tu idea en realidad.',
    features: ['Dominio y hospedaje anual', 'Landing informativa', 'Formulario de contacto', '3 cuentas de correo', '5 GB de espacio'],
    popular: false,
  },
  {
    name: 'Negocio Local',
    originalPrice: '$7,800',
    promoPrice: '$7,020',
    savings: '$780',
    desc: 'Digitaliza tu negocio y crece.',
    features: ['Dominio y hospedaje anual', '4 secciones web', 'Formulario de contacto', '6 cuentas de correo', '10 GB de espacio'],
    popular: false,
  },
  {
    name: 'PYME',
    originalPrice: '$8,900',
    promoPrice: '$8,010',
    savings: '$890',
    desc: 'Revoluciona tu negocio y vende mas.',
    features: ['Dominio y hospedaje anual', '6 secciones web', 'Formulario de contacto', 'Correos ilimitados', '32 GB de espacio'],
    popular: true,
  },
];

const faqs = [
  { q: 'Hasta cuando es valida la promocion?', a: 'La promocion del Buen Fin 2026 es valida del 20 al 23 de noviembre de 2026. Los precios con descuento aplican solo para proyectos contratados dentro de estas fechas.' },
  { q: 'Cuando tengo que pagar de nuevo?', a: 'La renovacion es anual. Emprendedor: $1,840 + IVA. Negocio Local: $2,450 + IVA. PYME: $3,140 + IVA.' },
  { q: 'Como se paga el diseno web?', a: '50% al iniciar el proyecto y 50% al entregar. Aceptamos transferencia, deposito y tarjeta de credito/debito.' },
  { q: 'Cuanto tiempo tarda el desarrollo?', a: '8-10 dias habiles. A los 3 dias recibiras un avance. Proyectos urgentes se pueden agilizar.' },
  { q: 'El descuento aplica sobre el precio total?', a: 'Si, el 10% de descuento se aplica directamente sobre el precio del paquete. No aplica sobre renovaciones ni servicios adicionales.' },
  { q: 'Puedo agregar funcionalidades adicionales?', a: 'Si, todos los paquetes son escalables. Podemos agregar tienda online, blog, sistema de citas y mas a tu plan.' },
];
---

<Layout title="Promocion Buen Fin 2026 | Portafolio Z - 10% de Descuento" description="Aprovecha el Buen Fin 2026 y obten tu sitio web profesional con 10% de descuento. Paquetes desde $6,210 + IVA. Solo del 20 al 23 de noviembre.">
  <Navbar />

  <!-- HERO - Buen Fin: Negro + Rojo + Dorado -->
  <section class="relative pt-32 pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-red-950 to-gray-900"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(220,38,38,0.15),transparent_60%)]"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-red-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-amber-500/10 rounded-full blur-3xl"></div>
    <!-- Decorative dots -->
    <div class="absolute top-32 right-20 w-2 h-2 rounded-full bg-amber-400/60"></div>
    <div class="absolute top-40 right-32 w-1.5 h-1.5 rounded-full bg-red-400/60"></div>
    <div class="absolute bottom-32 left-20 w-2 h-2 rounded-full bg-amber-400/40"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Campaign badge -->
      <div class="inline-flex items-center gap-2 bg-red-500/20 border border-red-500/30 rounded-full px-5 py-2 mb-8" data-animate>
        <span class="w-2 h-2 rounded-full bg-red-400 animate-pulse"></span>
        <span class="text-sm font-semibold text-red-300 tracking-wider uppercase">Buen Fin 2026 &bull; 20-23 Noviembre</span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold text-white mb-6" data-animate>
        <span class="text-amber-400">10%</span> de Descuento en tu
        <br><span class="bg-gradient-to-r from-red-400 via-amber-400 to-red-400 bg-clip-text text-transparent">Sitio Web</span>
      </h1>
      <p class="text-xl text-white/70 max-w-3xl mx-auto mb-10" data-animate>
        Obten la pagina web para tu negocio con un <strong class="text-amber-300">10% de descuento</strong>. Diseno profesional, hosting incluido y entrega en 6 dias.
      </p>

      <!-- Urgency banner -->
      <div class="inline-flex items-center gap-3 bg-amber-500/10 border border-amber-500/20 rounded-2xl px-6 py-3 mb-10" data-animate>
        <span class="text-amber-400 text-lg">⏰</span>
        <span class="text-amber-200 font-medium">Solo por tiempo limitado &mdash; 20 al 23 de noviembre 2026</span>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate>
        <a href="https://wa.me/5215564721547?text=Hola%2C%20me%20interesa%20la%20*Promoci%C3%B3n%20Buen%20Fin*.%20%C2%BFMe%20pueden%20dar%20m%C3%A1s%20informaci%C3%B3n%3F" target="_blank" rel="noopener" class="wa-lead bg-gradient-to-r from-red-500 to-amber-500 text-white font-bold px-8 py-4 rounded-full text-lg hover:from-red-600 hover:to-amber-600 transition-all hover:scale-105 shadow-xl shadow-red-500/20" data-plan="Aprovecha el Descuento" data-price="" data-category="Promoción Buen Fin">
          Aprovecha el Descuento
        </a>
        <a href="https://wa.me/5215564721547?text=Hola%2C%20me%20interesa%20la%20promo%20Buen%20Fin%202026" target="_blank" rel="noopener" class="wa-lead border-2 border-white/20 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all" data-plan="WhatsApp" data-price="" data-category="Promoción Buen Fin">
          WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Value prop -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Creamos increibles <span class="bg-gradient-to-r from-red-500 to-amber-500 bg-clip-text text-transparent">Sitios Web</span></h2>
        <p class="text-gray-600 mt-4 max-w-2xl mx-auto">Te ofrecemos la oportunidad perfecta para llevar tu negocio al siguiente nivel con sitios web innovadores, rapidos y adaptados a tus necesidades.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {['Diseno web personalizado y profesional', 'Optimizacion SEO para Google', 'Adaptacion a dispositivos moviles', 'Soporte continuo y mantenimiento'].map((f) => (
          <div class="flex items-center gap-3 p-4 rounded-xl bg-gray-50" data-animate>
            <svg class="w-6 h-6 text-red-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-gray-700 font-medium">{f}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-red-950 to-gray-900"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">Todos los disenos <span class="text-amber-400">incluyen</span></h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((f) => (
          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-all" data-animate>
            <div class="text-3xl mb-4">{f.icon}</div>
            <h3 class="text-lg font-bold text-white mb-2">{f.title}</h3>
            <p class="text-white/60 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING - Buen Fin con descuento -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <div class="inline-flex items-center gap-2 bg-red-50 border border-red-200 rounded-full px-4 py-1.5 mb-4">
          <span class="text-red-500 font-bold text-sm">🔥 BUEN FIN 2026</span>
        </div>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Paquetes con <span class="bg-gradient-to-r from-red-500 to-amber-500 bg-clip-text text-transparent">10% de Descuento</span></h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {planes.map((plan) => (
          <div class={`relative rounded-2xl p-8 ${plan.popular ? 'bg-gradient-to-br from-red-600 via-red-700 to-amber-700 text-white shadow-2xl shadow-red-500/25 scale-105' : 'bg-gray-50 border border-gray-200'} transition-all hover:shadow-xl`} data-animate>
            {plan.popular && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full bg-amber-400 text-gray-900 text-xs font-bold uppercase tracking-wider">
                Mas Vendido
              </div>
            )}
            <h3 class={`text-xl font-bold mb-2 ${plan.popular ? 'text-white' : 'text-gray-900'}`}>{plan.name}</h3>
            <p class={`text-sm mb-4 ${plan.popular ? 'text-white/70' : 'text-gray-500'}`}>{plan.desc}</p>
            <div class="mb-2">
              <span class={`text-sm line-through ${plan.popular ? 'text-white/40' : 'text-gray-400'}`}>{plan.originalPrice}</span>
            </div>
            <div class="mb-1">
              <span class={`text-4xl font-bold ${plan.popular ? 'text-amber-300' : 'bg-gradient-to-r from-red-500 to-amber-500 bg-clip-text text-transparent'}`}>{plan.promoPrice}</span>
              <span class={`text-sm ${plan.popular ? 'text-white/60' : 'text-gray-400'}`}> + IVA</span>
            </div>
            <div class={`inline-block px-3 py-1 rounded-full text-xs font-bold mb-6 ${plan.popular ? 'bg-amber-400/20 text-amber-300' : 'bg-red-50 text-red-500'}`}>
              Ahorras {plan.savings}
            </div>
            <ul class="space-y-3 mb-8">
              {plan.features.map((f) => (
                <li class={`flex items-start gap-2 text-sm ${plan.popular ? 'text-white/90' : 'text-gray-600'}`}>
                  <svg class={`w-5 h-5 flex-shrink-0 mt-0.5 ${plan.popular ? 'text-amber-300' : 'text-red-500'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href={`https://wa.me/5215564721547?text=Hola%2C%20me%20interesa%20el%20plan%20*${encodeURIComponent(plan.name)}*%20del%20Buen%20Fin%20(${encodeURIComponent(plan.promoPrice)}%20%2B%20IVA).%20%C2%BFMe%20pueden%20dar%20m%C3%A1s%20informaci%C3%B3n%3F`} target="_blank" rel="noopener" class={`wa-lead block w-full py-3 rounded-xl font-semibold transition-all text-center ${plan.popular ? 'bg-amber-400 text-gray-900 hover:bg-amber-300' : 'bg-gradient-to-r from-red-500 to-amber-500 text-white hover:opacity-90'}`} data-plan={plan.name} data-price={plan.promoPrice} data-category="Promoción Buen Fin">
              Aprovecha ahora
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Preguntas <span class="bg-gradient-to-r from-red-500 to-amber-500 bg-clip-text text-transparent">Frecuentes</span></h2>
      </div>
      <div class="space-y-4">
        {faqs.map((faq, i) => (
          <div class="bg-white rounded-xl border border-gray-200 overflow-hidden" data-animate>
            <button class="faq-toggle w-full px-6 py-5 text-left flex justify-between items-center gap-4 cursor-pointer" data-faq={i}>
              <span class="font-semibold text-gray-900">{faq.q}</span>
              <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-gray-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-red-600 via-red-700 to-amber-600"></div>
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">No dejes pasar esta oportunidad</h2>
      <p class="text-white/80 text-lg mb-8">El Buen Fin 2026 termina el 23 de noviembre. Aprovecha el 10% de descuento en tu sitio web profesional.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/5215564721547?text=Hola%2C%20me%20interesa%20la%20*Promoci%C3%B3n%20Buen%20Fin*.%20%C2%BFMe%20pueden%20dar%20m%C3%A1s%20informaci%C3%B3n%3F" target="_blank" rel="noopener" class="wa-lead bg-white text-red-600 font-bold px-8 py-4 rounded-full text-lg hover:bg-white/90 transition-all hover:scale-105 shadow-xl" data-plan="Cotiza con Descuento" data-price="" data-category="Promoción Buen Fin">
          Cotiza con Descuento
        </a>
        <a href="https://wa.me/5215564721547?text=Hola%2C%20quiero%20aprovechar%20la%20promo%20Buen%20Fin%202026" target="_blank" rel="noopener" class="wa-lead border-2 border-white text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all" data-plan="WhatsApp" data-price="" data-category="Promoción Buen Fin">
          WhatsApp
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppWidget />
</Layout>

<script>
function initFaqBF() {
  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling;
      const icon = btn.querySelector('svg');
      const isOpen = !content.classList.contains('hidden');
      document.querySelectorAll('.faq-content').forEach(c => c.classList.add('hidden'));
      document.querySelectorAll('.faq-toggle svg').forEach(s => s.style.transform = '');
      if (!isOpen) {
        content.classList.remove('hidden');
        icon.style.transform = 'rotate(180deg)';
      }
    });
  });
}
initFaqBF();
document.addEventListener('astro:page-load', initFaqBF);
</script>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.wa-lead').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        if (typeof gtag === 'function') {
          gtag('event', 'generate_lead', {
            event_category: 'WhatsApp',
            plan_name: el.dataset.plan || '',
            plan_price: el.dataset.price || '',
            category: el.dataset.category || '',
            source_page: 'promocion-buen-fin',
          });
        }
      });
    });
  });
</script>
