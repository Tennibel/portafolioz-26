---
/**
 * branding-and-launch-kit.astro - Landing page: Branding & Launch Kit
 *
 * Secciones:
 * 1. Hero
 * 2. Pain Points (3 columnas)
 * 3. Qué incluye (Timeline/steps)
 * 4. Planes (3 cards)
 * 5. Portafolio de Marcas
 * 6. Proceso (timeline)
 * 7. FAQ (6 preguntas)
 * 8. CTA Final
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';

const painPoints = [
  {
    icon: '🎨',
    title: 'Logo amateur',
    hook: 'Un logo hecho en 5 minutos en Canva comunica que tu negocio no es serio.',
    desc: 'Tu logo es la cara de tu empresa. Si se ve improvisado, tus clientes potenciales asumirán que tu producto o servicio también lo es. Las marcas profesionales generan hasta 3x más confianza.',
    gradient: 'from-pink-500 to-rose-500',
  },
  {
    icon: '🔀',
    title: 'Sin consistencia visual',
    hook: 'Cada post, cada tarjeta, cada documento se ve diferente.',
    desc: 'Sin una identidad visual definida, tu comunicación se ve fragmentada y confusa. Tus clientes no pueden reconocerte ni recordarte. La consistencia visual aumenta el reconocimiento de marca un 80%.',
    gradient: 'from-rose-500 to-magenta-500',
  },
  {
    icon: '👥',
    title: 'No te diferencias',
    hook: 'Si tu marca se ve igual a la de todos, ¿por qué deberían elegirte a ti?',
    desc: 'En un mercado saturado, tu identidad visual es tu arma secreta. Una marca memorable te posiciona como líder y justifica precios más altos. Sin diferenciación, compites solo por precio.',
    gradient: 'from-magenta-500 to-fuchsia-500',
  },
];

const deliverables = [
  {
    num: '01',
    title: 'Investigación y Estrategia',
    items: ['Briefing de marca', 'Análisis de competencia visual', 'Definición de posicionamiento', 'Moodboard de inspiración'],
    icon: '🔍',
  },
  {
    num: '02',
    title: 'Diseño de Logo',
    items: ['3 propuestas de diseño', '2 rondas de revisión', 'Versiones: principal, horizontal, vertical, ícono', 'Archivos AI / SVG / PNG / PDF / JPG', 'Favicon para sitio web'],
    icon: '✏️',
  },
  {
    num: '03',
    title: 'Identidad Visual Completa',
    items: ['Paleta de colores (HEX, RGB, CMYK)', 'Tipografías primaria y secundaria', 'Patrones y elementos gráficos', 'Estilo fotográfico definido', 'Reglas de uso y aplicación'],
    icon: '🎨',
  },
  {
    num: '04',
    title: 'Manual de Marca',
    items: ['PDF profesional de 15-25 páginas', 'Historia y valores de marca', 'Uso correcto e incorrecto del logo', 'Aplicaciones en papelería', 'Aplicaciones digitales'],
    icon: '📖',
  },
  {
    num: '05',
    title: 'Aplicaciones',
    items: ['Tarjeta de presentación', 'Hoja membretada', 'Firma de email HTML', 'Avatar y portada para redes sociales', '3 plantillas de posts para Canva'],
    icon: '📦',
  },
];

const planes = [
  {
    name: 'Logo Start',
    price: '$4,200',
    delivery: '7 días',
    desc: 'Ideal para emprendedores que inician.',
    accent: 'pink',
    popular: false,
    features: [
      '2 propuestas de logotipo',
      '1 ronda de revisión',
      'Archivos vectoriales (AI, SVG, PNG, PDF)',
      'Versión color + blanco/negro',
      'Paleta básica (3 colores)',
      'Tipografía principal',
      'Entrega: 7 días',
    ],
  },
  {
    name: 'Brand Kit',
    price: '$7,600',
    delivery: '12 días',
    desc: 'Identidad visual completa para tu negocio.',
    accent: 'rose',
    popular: true,
    features: [
      'Todo de Logo Start más:',
      '3 propuestas + 2 rondas de revisión',
      'Identidad visual completa',
      'Manual de marca (15-20 páginas)',
      'Tarjeta de presentación + hoja membretada',
      'Firma de email HTML',
      'Avatares y portadas para redes',
      'Entrega: 12 días',
    ],
  },
  {
    name: 'Full Brand',
    price: '$13,900',
    delivery: '18 días',
    desc: 'Branding premium para marcas ambiciosas.',
    accent: 'fuchsia',
    popular: false,
    features: [
      'Todo de Brand Kit más:',
      '5 propuestas + 3 rondas de revisión',
      'Manual extenso (25+ páginas)',
      'Estilo fotográfico definido',
      'Papelería completa',
      '6 plantillas de posts para Canva',
      'Packaging básico',
      'Sesión de estrategia 1 hora',
      'Entrega: 18 días',
    ],
  },
];

const accentColors: Record<string, { border: string; check: string; badge: string; btn: string }> = {
  pink: { border: 'border-pink-500/30', check: 'text-pink-400', badge: 'bg-pink-500/20 text-pink-300', btn: 'border-pink-500 text-pink-400 hover:bg-pink-500 hover:text-white' },
  rose: { border: 'border-rose-500/30', check: 'text-rose-400', badge: 'bg-rose-500/20 text-rose-300', btn: 'border-rose-500 text-rose-400 hover:bg-rose-500 hover:text-white' },
  fuchsia: { border: 'border-fuchsia-500/30', check: 'text-fuchsia-400', badge: 'bg-fuchsia-500/20 text-fuchsia-300', btn: 'border-fuchsia-500 text-fuchsia-400 hover:bg-fuchsia-500 hover:text-white' },
};

const plansWithColors = planes.map((plan) => ({
  ...plan,
  colors: accentColors[plan.accent],
  cardClass: plan.popular
    ? 'bg-gradient-to-br from-rose-600/20 via-pink-600/20 to-fuchsia-600/20 text-white ring-2 ring-rose-400/50 shadow-2xl shadow-rose-500/20 scale-105 border border-rose-500/30'
    : 'bg-dark-800/80 backdrop-blur-sm text-white border ' + accentColors[plan.accent].border,
  btnClass: plan.popular
    ? 'bg-gradient-to-r from-rose-500 to-pink-500 border-transparent text-white hover:opacity-90 shadow-lg shadow-rose-500/25'
    : accentColors[plan.accent].btn,
}));

const processSteps = [
  { day: 'Día 1-2', title: 'Briefing y kick-off', desc: 'Conocemos tu negocio, objetivos, audiencia y preferencias visuales. Definimos el rumbo creativo juntos.', icon: '📋' },
  { day: 'Día 3-5', title: 'Investigación + moodboard', desc: 'Analizamos tu competencia, tendencias del sector y creamos un moodboard de inspiración para tu aprobación.', icon: '🔎' },
  { day: 'Día 6-8', title: 'Diseño de propuestas de logo', desc: 'Creamos las propuestas de logotipo basadas en la estrategia definida. Cada propuesta incluye concepto y aplicaciones.', icon: '✏️' },
  { day: 'Día 9-10', title: 'Revisiones y ajustes', desc: 'Refinamos la propuesta elegida según tu feedback. Ajustamos colores, tipografía y detalles hasta que quede perfecto.', icon: '🔄' },
  { day: 'Día 11-12', title: 'Identidad visual + manual + entrega', desc: 'Desarrollamos la identidad completa, armamos el manual de marca y entregamos todos los archivos finales.', icon: '🚀' },
];

const portfolioItems = [
  { name: 'Marca 1', gradient: 'from-pink-500 to-rose-600' },
  { name: 'Marca 2', gradient: 'from-rose-500 to-fuchsia-600' },
  { name: 'Marca 3', gradient: 'from-fuchsia-500 to-purple-600' },
  { name: 'Marca 4', gradient: 'from-purple-500 to-pink-600' },
  { name: 'Marca 5', gradient: 'from-magenta-500 to-rose-600' },
  { name: 'Marca 6', gradient: 'from-pink-600 to-fuchsia-500' },
];

const faqs = [
  {
    q: '¿Cuánto tiempo tarda el proceso de branding?',
    a: 'Depende del plan que elijas. Logo Start se entrega en 7 días, Brand Kit en 12 días y Full Brand en 18 días. Estos tiempos son calendario, no hábiles. Si necesitas entrega urgente, podemos acelerar el proceso con un costo adicional.',
  },
  {
    q: '¿Qué necesito para empezar?',
    a: 'Solo necesitas contarnos sobre tu negocio: qué haces, a quién le vendes, qué te diferencia y cualquier preferencia visual que tengas (colores, estilos que te gusten). Nosotros nos encargamos del resto. Te enviaremos un briefing para guiarte.',
  },
  {
    q: '¿Puedo pedir cambios en el logo?',
    a: 'Por supuesto. Cada plan incluye rondas de revisión: Logo Start incluye 1, Brand Kit incluye 2 y Full Brand incluye 3. Las revisiones adicionales tienen un costo de $500 MXN cada una.',
  },
  {
    q: '¿En qué formatos recibo mi logo?',
    a: 'Recibes tu logo en todos los formatos que necesitas: AI (editable en Illustrator), SVG (vectorial para web), PNG (fondo transparente en varias resoluciones), PDF (para imprenta) y JPG. También incluimos versiones en color, blanco/negro y negativo.',
  },
  {
    q: '¿Qué diferencia hay entre Logo Start y Brand Kit?',
    a: 'Logo Start te da un logotipo profesional con sus variantes y archivos. Brand Kit incluye todo eso más la identidad visual completa: manual de marca, paleta de colores extendida, tipografías, tarjeta de presentación, hoja membretada, firma de email y diseños para redes sociales. Es la opción más popular porque te da todo lo que necesitas para verte profesional desde el día uno.',
  },
  {
    q: '¿Puedo usar las plantillas de Canva para crear mis propios posts?',
    a: 'Sí. Las plantillas que incluimos en Brand Kit y Full Brand son 100% editables en Canva (versión gratuita). Te capacitamos para que puedas modificar textos, imágenes y crear nuevos posts manteniendo la consistencia visual de tu marca.',
  },
];
---

<Layout title="Branding & Launch Kit: Crea una Marca Profesional | Portafolio Z" description="Diseñamos identidades visuales que transmiten confianza. Logo, colores, tipografía, manual de marca. Desde $4,200 MXN.">
  <Navbar />

  <!-- SECCION 1: Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-pink-600 via-rose-500 to-fuchsia-500"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-rose-400/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-pink-400/20 rounded-full blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <nav class="flex justify-center items-center gap-2 text-sm text-white/60 mb-6">
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-white/60">Servicios</span>
        <span>/</span>
        <span class="text-white">Branding</span>
      </nav>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
        Branding & Launch Kit: Crea una <span class="text-pink-200">Marca Profesional</span> para Tu Negocio
      </h1>
      <p class="text-xl text-white/80 max-w-3xl mx-auto mb-8">
        Tu marca es la primera impresión que das. Diseñamos identidades visuales que transmiten confianza, profesionalismo y conectan con tu audiencia. <strong class="text-white">Logo, colores, tipografía y todo lo que necesitas para verte como las grandes marcas.</strong>
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        <a href={`https://wa.me/5215647215472?text=${encodeURIComponent('Hola, me interesa el servicio de *Branding & Launch Kit*. ¿Me pueden dar más información?')}`} target="_blank" rel="noopener" class="wa-lead bg-white text-pink-600 font-bold px-8 py-4 rounded-full text-lg hover:bg-white/90 transition-all hover:scale-105 shadow-xl cursor-pointer" data-plan="Branding & Launch Kit" data-price="" data-category="Branding & Launch Kit">
          Cotizar Mi Marca
        </a>
        <a href="#portafolio" class="border-2 border-white/40 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all">
          Ver Ejemplos
        </a>
      </div>
      <div class="flex flex-wrap justify-center gap-6 text-white/70 text-sm">
        <span class="flex items-center gap-2"><span class="text-pink-200 font-bold">+200</span> marcas diseñadas</span>
        <span class="hidden sm:block">·</span>
        <span class="flex items-center gap-2">Entrega en <span class="text-pink-200 font-bold">10 días</span></span>
        <span class="hidden sm:block">·</span>
        <span class="flex items-center gap-2"><span class="text-pink-200 font-bold">Archivos editables</span> incluidos</span>
      </div>
    </div>
  </section>

  <!-- SECCION 2: Pain Points -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6" data-animate>
        <p class="text-sm font-semibold text-rose-500 tracking-wider uppercase mb-3">El problema</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
          ¿Tu negocio se ve <span class="gradient-text">profesional o improvisado</span>?
        </h2>
      </div>
      <p class="text-gray-600 text-center max-w-3xl mx-auto mb-16" data-animate>
        El 94% de las primeras impresiones se basan en el diseño visual. Si tu marca no transmite profesionalismo desde el primer contacto, estás perdiendo clientes antes de que conozcan tu producto.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {painPoints.map((p) => (
          <div class="relative p-8 rounded-2xl bg-gray-50 border border-gray-100 hover:shadow-xl transition-all group" data-animate>
            <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${p.gradient} flex items-center justify-center text-2xl mb-5 group-hover:scale-110 transition-transform`}>
              {p.icon}
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">{p.title}</h3>
            <p class="text-rose-600 font-medium text-sm mb-3">{p.hook}</p>
            <p class="text-gray-600 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCION 3: Qué incluye (Timeline/Steps) -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-pink-600 via-rose-500 to-fuchsia-500"></div>
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-3xl -translate-y-1/2"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-pink-500/10 rounded-full blur-3xl translate-y-1/2"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6" data-animate>
        <p class="text-sm font-semibold text-pink-200 tracking-wider uppercase mb-3">Entregables</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">
          Todo lo que Tu Marca Necesita para <span class="text-pink-200">Brillar</span>
        </h2>
      </div>
      <p class="text-white/70 text-center max-w-3xl mx-auto mb-16" data-animate>
        No solo diseñamos un logo. Creamos un sistema de identidad visual completo para que tu marca sea reconocible, consistente y profesional en todos los puntos de contacto.
      </p>
      <div class="space-y-6">
        {deliverables.map((d) => (
          <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-6 sm:p-8 hover:bg-white/15 transition-all duration-300" data-animate>
            <div class="flex flex-col sm:flex-row gap-6 items-start">
              <div class="flex items-center gap-4 flex-shrink-0">
                <div class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center text-2xl">
                  {d.icon}
                </div>
                <span class="text-pink-200 font-bold text-sm uppercase tracking-wider">{d.num}</span>
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold text-white mb-3">{d.title}</h3>
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                  {d.items.map((item) => (
                    <li class="flex items-center gap-2 text-white/80 text-sm">
                      <svg class="w-4 h-4 text-pink-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCION 4: Planes (3 cards) -->
  <section class="relative bg-dark-900 py-24 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(236,72,153,0.15),transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,rgba(244,63,94,0.15),transparent_50%)]"></div>
    <div class="absolute top-10 left-1/4 w-64 h-64 bg-pink-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-1/4 w-80 h-80 bg-rose-500/10 rounded-full blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6" data-animate>
        <p class="text-pink-400 font-medium text-sm uppercase tracking-widest mb-3">Paquetes de Branding</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          Planes de Branding — Elige el Que Se Ajusta a Tu <span class="gradient-text">Marca</span>
        </h2>
      </div>
      <p class="text-gray-400 text-center max-w-3xl mx-auto mb-16" data-animate>
        Todos los planes incluyen archivos vectoriales editables, versiones en color y blanco/negro, y soporte post-entrega para resolver cualquier duda sobre tu nueva identidad visual.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto" data-animate>
        {plansWithColors.map((plan) => (
          <div class={`relative rounded-2xl p-7 transition-all duration-300 hover:-translate-y-2 ${plan.cardClass}`}>
            {plan.popular && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                <span class="bg-gradient-to-r from-rose-500 to-pink-500 text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-lg">Recomendado</span>
              </div>
            )}
            <div class={`inline-flex items-center gap-1.5 ${plan.colors.badge} text-xs font-medium px-3 py-1 rounded-full mb-4`}>
              <span>{plan.delivery}</span>
            </div>
            <h3 class="text-lg font-bold mb-1 text-white">{plan.name}</h3>
            <p class="text-xs mb-5 text-gray-400">{plan.desc}</p>
            <div class="mb-6">
              <span class="text-3xl font-extrabold text-white">{plan.price}</span>
              <span class="text-xs ml-1 text-gray-500">MXN + IVA</span>
            </div>
            <ul class="space-y-2.5 mb-6">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm">
                  <svg class={`w-4 h-4 flex-shrink-0 mt-0.5 ${plan.colors.check}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-gray-300">{f}</span>
                </li>
              ))}
            </ul>
            <a href={`https://wa.me/5215647215472?text=${encodeURIComponent('Hola, me interesa el plan *' + plan.name + '* (' + plan.price + ') de Branding & Launch Kit. ¿Me pueden dar más información?')}`} target="_blank" rel="noopener" class={`wa-lead w-full text-center font-semibold py-3 px-5 rounded-full transition-all text-sm border-2 cursor-pointer block ${plan.btnClass}`} data-plan={plan.name} data-price={plan.price} data-category="Branding & Launch Kit">
              ¡Quiero Mi Marca!
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCION 5: Portafolio de Marcas -->
  <section id="portafolio" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-sm font-semibold text-rose-500 tracking-wider uppercase mb-3">Portafolio</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
          Marcas que <span class="gradient-text">Hemos Creado</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {portfolioItems.map((item) => (
          <div class="group relative aspect-[4/3] rounded-2xl overflow-hidden cursor-pointer" data-animate>
            <div class={`absolute inset-0 bg-gradient-to-br ${item.gradient} opacity-90 group-hover:opacity-100 transition-opacity`}></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="text-center">
                <div class="w-20 h-20 mx-auto mb-4 rounded-2xl bg-white/20 backdrop-blur-sm flex items-center justify-center">
                  <svg class="w-10 h-10 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                </div>
                <p class="text-white/60 text-sm font-medium">Proyecto de branding</p>
              </div>
            </div>
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors"></div>
          </div>
        ))}
      </div>
      <div class="text-center mt-12" data-animate>
        <a href={`https://wa.me/5215647215472?text=${encodeURIComponent('Hola, vi su portafolio de *Branding* y me gustaría cotizar mi marca. ¿Me pueden asesorar?')}`} target="_blank" rel="noopener" class="wa-lead bg-gradient-to-r from-pink-500 to-rose-500 text-white font-bold px-8 py-4 rounded-full text-lg hover:opacity-90 transition-all hover:scale-105 shadow-xl cursor-pointer" data-plan="Portafolio CTA" data-price="" data-category="Branding & Launch Kit">
          Quiero una marca así
        </a>
      </div>
    </div>
  </section>

  <!-- SECCION 6: Proceso (Timeline) -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-sm font-semibold text-rose-500 tracking-wider uppercase mb-3">Proceso</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
          Así Creamos Tu <span class="gradient-text">Marca</span>
        </h2>
      </div>
      <div class="max-w-3xl mx-auto">
        {processSteps.map((step, i) => (
          <div class="relative flex gap-6 pb-12 last:pb-0" data-animate>
            {/* Timeline line */}
            {i < processSteps.length - 1 && (
              <div class="absolute left-7 top-14 w-0.5 h-full bg-gradient-to-b from-pink-300 to-rose-200"></div>
            )}
            <div class="flex-shrink-0">
