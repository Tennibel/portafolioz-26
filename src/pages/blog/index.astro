<script>
function initBlogFilters() {
  const searchInput = document.getElementById('blog-search') as HTMLInputElement;
  const filterBtns = document.querySelectorAll('.blog-filter');
  const cards = document.querySelectorAll('.blog-card');
  const articles = document.querySelectorAll('.blog-article');
  const categorySections = document.querySelectorAll('.blog-category-section');
  const resultsCount = document.getElementById('blog-results-count');
  const featuredSection = document.getElementById('featured-section');

  let activeCategory = 'all';

  function applyFilters() {
    const query = searchInput?.value.toLowerCase().trim() || '';
    let visible = 0;

    cards.forEach((card) => {
      const el = card as HTMLElement;
      const cat = el.dataset.category || '';
      const title = el.dataset.title || '';
      const matchesCat = activeCategory === 'all' || cat === activeCategory;
      const matchesSearch = !query || title.includes(query);
      if (matchesCat && matchesSearch) {
        el.style.display = '';
        visible++;
      } else {
        el.style.display = 'none';
      }
    });

    articles.forEach((article) => {
      const el = article as HTMLElement;
      const cat = el.dataset.category || '';
      const title = el.dataset.title || '';
      const matchesCat = activeCategory === 'all' || cat === activeCategory;
      const matchesSearch = !query || title.includes(query);
      el.style.display = (matchesCat && matchesSearch) ? '' : 'none';
    });

    // Hide category sections if no visible cards inside
    categorySections.forEach((section) => {
      const el = section as HTMLElement;
      const sectionCat = el.dataset.sectionCategory || '';
      const matchesCat = activeCategory === 'all' || sectionCat === activeCategory;
      const visibleCards = el.querySelectorAll('.blog-card:not([style*="display: none"])');
      el.style.display = (matchesCat && visibleCards.length > 0) ? '' : 'none';
    });

    // Hide featured section if featured post is hidden
    if (featuredSection) {
      const featuredCard = featuredSection.querySelector('.blog-card') as HTMLElement;
      featuredSection.style.display = featuredCard && featuredCard.style.display !== 'none' ? '' : 'none';
    }

    if (resultsCount) {
      resultsCount.textContent = `${visible} artículo${visible !== 1 ? 's' : ''} encontrado${visible !== 1 ? 's' : ''}`;
    }
  }

  // Category filter clicks
  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => {
        b.classList.remove('active', 'bg-primary-500/10', 'border-primary-500/30', 'text-primary-600');
        b.classList.add('bg-gray-50', 'border-gray-200', 'text-gray-500');
      });
      btn.classList.add('active', 'bg-primary-500/10', 'border-primary-500/30', 'text-primary-600');
      btn.classList.remove('bg-gray-50', 'border-gray-200', 'text-gray-500');
      activeCategory = (btn as HTMLElement).dataset.category || 'all';
      applyFilters();
    });
  });

  // Search input
  searchInput?.addEventListener('input', applyFilters);

  // Category toggle (Ver todos / Ver menos)
  document.querySelectorAll('.cat-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const catId = (btn as HTMLElement).dataset.catId || '';
      const grid = document.getElementById(catId);
      if (!grid) return;
      const extras = grid.querySelectorAll('.cat-extra');
      const isHidden = extras[0]?.classList.contains('hidden');
      extras.forEach((el) => el.classList.toggle('hidden'));
      btn.innerHTML = isHidden
        ? 'Ver menos <svg class="w-4 h-4 rotate-180 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>'
        : 'Ver todos <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>';
    });
  });
}

// Run on initial load (wait for DOM) and on Astro page transitions
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initBlogFilters);
} else {
  initBlogFilters();
}
document.addEventListener('astro:page-load', initBlogFilters);
</script>

