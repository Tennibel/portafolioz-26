---
/**
 * blog.astro - Página de listado de artículos
 *
 * Se alimenta del WP REST API. Fallback a posts mock si la API no responde.
 */
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppWidget from '../../components/WhatsAppWidget.astro';

interface WPPost {
  id: number;
  title: { rendered: string };
  excerpt: { rendered: string };
  content: { rendered: string };
  date: string;
  slug: string;
  link: string;
  _embedded?: {
    'wp:featuredmedia'?: Array<{ source_url: string; alt_text: string }>;
    'wp:term'?: Array<Array<{ name: string }>>;
    author?: Array<{ name: string; avatar_urls?: Record<string, string> }>;
  };
}

const WP_API_URL = import.meta.env.WP_API_URL || '';

let posts: Array<{
  id: string;
  title: string;
  excerpt: string;
  body: string[];
  category: string;
  date: string;
  slug: string;
  image: string;
  author: string;
}> = [];

if (WP_API_URL) {
  try {
    const res = await fetch(`${WP_API_URL}/wp-json/wp/v2/posts?per_page=100&_embed&orderby=date&order=desc`, {
      headers: { 'Accept': 'application/json' },
    });
    if (res.ok) {
      const wpPosts: WPPost[] = await res.json();
      posts = wpPosts.map((p) => ({
        id: p.slug,
        title: p.title.rendered.replace(/<[^>]*>/g, ''),
        excerpt: p.excerpt.rendered.replace(/<[^>]*>/g, '').trim(),
        body: [],
        category: p._embedded?.['wp:term']?.[0]?.[0]?.name || 'Blog',
        date: new Date(p.date).toLocaleDateString('es-MX', { day: 'numeric', month: 'short', year: 'numeric' }),
        slug: p.slug,
        image: p._embedded?.['wp:featuredmedia']?.[0]?.source_url || '',
        author: p._embedded?.author?.[0]?.name || 'Portafolio Z',
      }));
    }
  } catch (e) {
    // Fallback silencioso
  }
}

// Fallback mock data
if (posts.length === 0) {
  posts = [
    {
      id: 'agencia-seo',
      title: '¿Cuándo es necesaria una agencia de SEO en México?',
      category: 'SEO',
      date: '15 Mar 2025',
      excerpt: 'Descubre en qué momento tu negocio necesita ayuda profesional para posicionarse en buscadores y atraer tráfico orgánico de calidad.',
      body: [
        'Si tu sitio ya tiene tráfico pero no convierte, puede ser que el SEO no esté atacando las palabras clave correctas.',
        'Una agencia suele ayudar cuando necesitas estrategia, auditoría técnica y contenido orientado a intención de búsqueda.',
        'La clave es medir resultados con KPIs claros (ranking, tráfico orgánico y conversiones) y ajustar el plan mes a mes.',
      ],
      slug: 'agencia-seo',
      image: '',
      author: 'Portafolio Z',
    },
    {
      id: 'seguridad-sitio',
      title: '¿Cómo mejorar la seguridad de un sitio web?',
      category: 'Seguridad',
      date: '10 Mar 2025',
      excerpt: 'Consejos esenciales de seguridad web que todo dueño de negocio debe conocer para proteger su inversión digital.',
      body: [
        'Implementa HTTPS y configura correctamente cabeceras de seguridad (HSTS, Content-Security-Policy, etc.).',
        'Mantén plugins/SDKs actualizados y realiza revisiones periódicas de vulnerabilidades.',
        'Usa backups automáticos y un plan de recuperación para reducir el impacto de un incidente.',
      ],
      slug: 'seguridad-sitio',
      image: '',
      author: 'Portafolio Z',
    },
    {
      id: 'marketing-autos-lujo',
      title: 'Marketing de autos de lujo: estrategias para clientes exigentes',
      category: 'Marketing',
      date: '05 Mar 2025',
      excerpt: 'Estrategias adaptadas para satisfacer la exigente clientela del mercado automotriz premium y generar leads de alto valor.',
      body: [
        'Enfócate en experiencia y percepción de marca: el contenido debe sentirse premium.',
        'Segmenta por intención (financiamiento, interés por modelos específicos, pruebas de manejo).',
        'Mide resultados por etapas del embudo y optimiza con campañas dirigidas a calidad de leads.',
      ],
      slug: 'marketing-autos-lujo',
      image: '',
      author: 'Portafolio Z',
    },
  ];
}

const categoryColors: Record<string, string> = {
  'SEO': 'from-cyan-500 to-blue-500',
  'Seguridad': 'from-violet-500 to-purple-500',
  'Marketing': 'from-amber-500 to-orange-500',
  'Blog': 'from-pink-500 to-rose-500',
  'Diseño': 'from-emerald-500 to-cyan-500',
  'Tecnología': 'from-indigo-500 to-violet-500',
};

function getGradient(category: string): string {
  return categoryColors[category] || 'from-primary-500 to-accent-500';
}

const featured = posts.slice(0, 3);
const rest = posts.slice(3);
const categories = [...new Set(posts.map(p => p.category))];

// Category styles - cada categoría tiene un look diferente
const categoryStyles: Record<string, { bg: string; border: string; accent: string; icon: string }> = {
  'SEO': { bg: 'bg-emerald-50', border: 'border-emerald-200', accent: 'text-emerald-600', icon: '🔍' },
  'Sitio Web': { bg: 'bg-indigo-50', border: 'border-indigo-200', accent: 'text-indigo-600', icon: '🌐' },
  'Marketing': { bg: 'bg-orange-50', border: 'border-orange-200', accent: 'text-orange-600', icon: '📈' },
  'Ventas': { bg: 'bg-pink-50', border: 'border-pink-200', accent: 'text-pink-600', icon: '💰' },
  'Wordpress': { bg: 'bg-blue-50', border: 'border-blue-200', accent: 'text-blue-600', icon: '📝' },
  'Estrategias': { bg: 'bg-purple-50', border: 'border-purple-200', accent: 'text-purple-600', icon: '🎯' },
  'Branding': { bg: 'bg-amber-50', border: 'border-amber-200', accent: 'text-amber-600', icon: '🎨' },
  'Diseño': { bg: 'bg-cyan-50', border: 'border-cyan-200', accent: 'text-cyan-600', icon: '✨' },
};

function getCategoryStyle(category: string) {
  return categoryStyles[category] || { bg: 'bg-gray-50', border: 'border-gray-200', accent: 'text-primary-600', icon: '📄' };
}

// Group posts by category (excluding featured)
const postsByCategory = categories.map((cat) => ({
  category: cat,
  gradient: getGradient(cat),
  style: getCategoryStyle(cat),
  posts: rest.filter((p) => p.category === cat),
})).filter((g) => g.posts.length > 0);
---

<Layout title="Blog | Portafolio Z" description="Artículos sobre diseño web, SEO, marketing digital y tecnología para emprendedores y negocios en México.">
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-primary-900 to-dark-900"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(99,102,241,0.25),transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(236,72,153,0.15),transparent_50%)]"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex gap-2 text-sm text-white/50 mb-6" data-animate>
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-white">Blog</span>
      </nav>
      <div class="max-w-3xl" data-animate>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-5 leading-tight">
          Nuestro <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-primary-400 to-pink-400">Blog</span>
        </h1>
        <p class="text-lg text-white/60 leading-relaxed max-w-2xl">
          Ideas prácticas sobre diseño web, SEO, marketing digital y tecnología para hacer crecer tu negocio.
        </p>
      </div>
    </div>
  </section>

  <!-- BARRA DE SERVICIOS -->
  <section class="bg-gray-900 py-4 border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between gap-4 overflow-x-auto scrollbar-hide">
        <div class="flex items-center gap-6 text-sm whitespace-nowrap">
          <a href="/web-sales-machine" class="text-white/50 hover:text-cyan-400 transition-colors flex items-center gap-1.5">🌐 Diseño Web</a>
          <a href="/growth-marketing" class="text-white/50 hover:text-orange-400 transition-colors flex items-center gap-1.5">📈 Marketing</a>
          <a href="/posicionamiento-web-seo" class="text-white/50 hover:text-emerald-400 transition-colors flex items-center gap-1.5">🔍 SEO</a>
          <a href="/branding-and-launch-kit" class="text-white/50 hover:text-amber-400 transition-colors flex items-center gap-1.5">🎨 Branding</a>
          <a href="/tienda-en-linea-e-commerce" class="text-white/50 hover:text-pink-400 transition-colors flex items-center gap-1.5">🛒 E-Commerce</a>
          <a href="/social-media-marketing" class="text-white/50 hover:text-violet-400 transition-colors flex items-center gap-1.5">📱 Social Media</a>
        </div>
        <a href={`https://wa.me/5215647215472?text=${encodeURIComponent('Hola, vi su blog y me gustaría cotizar un servicio.')}`}
          target="_blank" rel="noopener"
          class="wa-lead shrink-0 bg-gradient-to-r from-primary-500 to-accent-500 text-white text-xs font-bold px-4 py-2 rounded-full hover:opacity-90 transition-all"
          data-plan="Blog Services Bar" data-price="" data-category="Blog">
          Cotizar Ahora
        </a>
      </div>
    </div>
  </section>

  <!-- SEARCH & CATEGORIES -->
  <section class="bg-gray-50 pt-8 pb-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-animate>
      <div class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 shadow-sm">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          <!-- Search -->
          <div class="flex-1 relative">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              id="blog-search"
              placeholder="Buscar artículos por título, tema o palabra clave..."
              class="w-full bg-gray-50 border border-gray-200 rounded-xl pl-12 pr-4 py-3.5 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 focus:bg-white transition-all"
            />
          </div>
          <!-- Category filters -->
          <div class="flex flex-wrap gap-2">
            <button class="blog-filter active bg-primary-500/10 border border-primary-500/30 text-primary-600 text-sm font-medium px-4 py-2.5 rounded-full cursor-pointer transition-all" data-category="all">
              Todos
            </button>
            {categories.map((cat) => (
              <button class="blog-filter bg-gray-50 border border-gray-200 text-gray-500 text-sm font-medium px-4 py-2.5 rounded-full hover:bg-primary-50 hover:text-primary-600 hover:border-primary-300 cursor-pointer transition-all" data-category={cat}>
                {cat}
              </button>
            ))}
          </div>
        </div>
        <!-- Results count -->
        <p class="text-gray-400 text-xs mt-4" id="blog-results-count">{posts.length} artículos encontrados</p>
      </div>
    </div>
  </section>

  <!-- 3 FEATURED POSTS -->
  {featured.length > 0 && (
    <section class="bg-gray-50 py-12" id="featured-section">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-gray-400 text-xs font-semibold uppercase tracking-widest mb-6" data-animate>Artículos destacados</p>
        <div class="grid md:grid-cols-3 gap-6" data-animate>
          {featured.map((feat) => (
            <a href={`/${feat.slug}`} class="blog-card group flex flex-col rounded-2xl overflow-hidden bg-white border border-gray-200 hover:border-gray-300 hover:shadow-xl hover:-translate-y-1 transition-all duration-300" data-category={feat.category} data-title={feat.title.toLowerCase()}>
              <div class="relative h-52 overflow-hidden">
                {feat.image ? (
                  <img src={feat.image} alt={feat.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
                ) : (
                  <div class={`w-full h-full bg-gradient-to-br ${getGradient(feat.category)}`}></div>
                )}
                <div class="absolute top-4 left-4 flex items-center gap-2">
                  <span class="bg-white/90 backdrop-blur-sm text-gray-800 text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider shadow-sm">
                    Destacado
                  </span>
                  <span class={`bg-gradient-to-r ${getGradient(feat.category)} text-white text-[10px] font-bold px-2.5 py-1 rounded-full`}>
                    {feat.category}
                  </span>
                </div>
              </div>
              <div class="p-6 flex flex-col flex-1">
                <time class="text-gray-400 text-xs">{feat.date}</time>
                <h2 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-primary-600 transition-colors line-clamp-2 mt-2">
                  {feat.title}
                </h2>
                <p class="text-gray-500 text-sm leading-relaxed line-clamp-2 flex-1">{feat.excerpt}</p>
                <div class="flex items-center gap-2 mt-4 text-primary-600 text-sm font-medium">
                  <span>Leer artículo</span>
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- POSTS BY CATEGORY + SIDEBAR -->
  <section class="bg-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_300px] gap-10">

        <!-- Columna principal: posts por categoria -->
        <div class="space-y-0">
  {postsByCategory.map((group, groupIdx) => (
    <div class={`py-10 blog-category-section ${groupIdx % 2 === 0 ? '' : 'bg-gray-50 -mx-4 px-4 rounded-2xl'}`} data-section-category={group.category}>
      <div>
        <div class={`rounded-2xl ${group.style.bg} ${group.style.border} border p-6 md:p-8 mb-8`} data-animate>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <span class="text-3xl">{group.style.icon}</span>
              <div>
                <h2 class={`text-2xl font-bold ${group.style.accent}`}>{group.category}</h2>
                <p class="text-gray-400 text-sm">{group.posts.length} artículo{group.posts.length !== 1 ? 's' : ''}</p>
              </div>
            </div>
            {group.posts.length > 6 && (
              <button class="cat-toggle text-sm font-medium text-gray-500 hover:text-primary-600 transition-colors flex items-center gap-1 cursor-pointer" data-cat-id={`cat-${groupIdx}`}>
                Ver todos
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </button>
            )}
          </div>
        </div>
        {/* Layout 0: Standard 3-column grid */}
        {groupIdx % 3 === 0 && (
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-animate id={`cat-${groupIdx}`}>
            {group.posts.map((post, postIdx) => (
              <a
                href={`/${post.slug}`}
                class={`blog-card group rounded-2xl overflow-hidden bg-white border ${group.style.border} hover:-translate-y-1 hover:shadow-lg transition-all duration-300 ${postIdx >= 6 ? 'hidden cat-extra' : ''}`}
                data-category={post.category}
                data-title={post.title.toLowerCase()}
              >
                <div class="relative h-48 overflow-hidden">
                  {post.image ? (
                    <img src={post.image} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  ) : (
                    <div class={`w-full h-full bg-gradient-to-br ${getGradient(post.category)} opacity-80`}></div>
                  )}
                  <div class="absolute top-4 left-4">
                    <span class={`bg-gradient-to-r ${group.gradient} text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg`}>
                      {post.category}
                    </span>
                  </div>
                </div>
                <div class="p-5">
                  <div class="flex items-center gap-3 mb-2">
                    <time class="text-gray-400 text-xs">{post.date}</time>
                    <span class="text-gray-300">·</span>
                    <span class="text-gray-400 text-xs">{post.author}</span>
                  </div>
                  <h3 class="text-base font-bold text-gray-900 mb-2 group-hover:text-primary-600 transition-colors line-clamp-2">
                    {post.title}
                  </h3>
                  <p class="text-gray-500 text-sm leading-relaxed line-clamp-2">
                    {post.excerpt}
                  </p>
                  <div class={`flex items-center gap-2 mt-4 ${group.style.accent} text-sm font-medium`}>
                    <span>Leer artículo</span>
                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                </div>
              </a>
            ))}
