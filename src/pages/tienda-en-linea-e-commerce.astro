---
/**
 * tienda-en-linea-e-commerce.astro - Landing page: E-Commerce / Tienda en Línea
 *
 * Secciones:
 * 1. Hero (emerald/green theme)
 * 2. Why Your Own Store
 * 3. Plans (4 cards)
 * 4. Included in All Plans
 * 5. Add-Ons
 * 6. FAQ
 * 7. CTA Final
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';

const limitations = [
  {
    icon: '🏪',
    title: 'Marketplaces',
    desc: 'Comisiones del 15-20% por venta, competencia directa en la misma página, sin branding propio y sin datos de tus clientes.',
    gradient: 'from-red-500 to-orange-500',
  },
  {
    icon: '📱',
    title: 'Redes sociales',
    desc: 'Sin catálogo organizado, sin carrito de compras, dependes del algoritmo y si te cierran la cuenta pierdes todo.',
    gradient: 'from-red-500 to-pink-500',
  },
  {
    icon: '💬',
    title: 'WhatsApp',
    desc: 'No escala, no puedes atender 50 clientes a la vez, no hay inventario, no hay seguimiento de pedidos.',
    gradient: 'from-orange-500 to-red-500',
  },
];

const advantages = [
  { icon: '💰', text: 'Sin comisiones por venta (solo ~3% del procesador de pagos)' },
  { icon: '🎨', text: 'Tu marca, tu diseño, tu experiencia de compra' },
  { icon: '📊', text: 'Datos de tus clientes: emails, historial, comportamiento' },
  { icon: '🔍', text: 'SEO propio: apareces en Google cuando buscan tus productos' },
  { icon: '📈', text: 'Escala sin límites: de 10 a 10,000 productos sin problema' },
];

const planes = [
  {
    name: 'Catálogo WooCommerce',
    price: '$7,800',
    renewal: '$2,800',
    delivery: '12 días',
    desc: 'Catálogo digital sin pasarela de pagos. Cliente ve y contacta por WhatsApp.',
    accent: 'emerald',
    popular: false,
    note: 'NO incluye: pasarela de pagos, carrito, checkout',
    features: [
      'Landing + catálogo hasta 50 productos',
      'Fichas de producto con descripción',
      'Categorías y filtros',
      'Galería de imágenes por producto',
      'Botón WhatsApp por producto',
      'Responsive (móvil + desktop)',
      'Hosting + dominio 1 año',
      'Certificado SSL',
      'Google Analytics',
      'SEO básico on-page',
      'Capacitación de uso',
      'Entrega: 12 días',
    ],
  },
  {
    name: 'Tienda WooCommerce Estándar',
    price: '$12,900',
    renewal: '$3,600',
    delivery: '18 días',
    desc: 'Tienda completa con carrito, pagos y envíos.',
    accent: 'blue',
    popular: true,
    note: null,
    features: [
      'Diseño personalizado',
      'Catálogo 5-50 productos',
      'Variaciones de producto',
      'Control de inventario',
      'Carrito de compras',
      'Checkout optimizado',
      'Stripe / Conekta / PayPal / OXXO',
      'Cupones y descuentos',
      'Cálculo de envíos',
      'Notificaciones por email',
      'WhatsApp integrado',
      'Responsive',
      'Hosting + dominio 1 año',
      'Certificado SSL',
      'GA4 enhanced e-commerce',
      'SEO on-page',
      'Capacitación 1:1',
      'Entrega: 18 días',
      '2 rondas de revisiones',
    ],
  },
  {
    name: 'Tienda WooCommerce Pro',
    price: '$15,600',
    renewal: '$4,200',
    delivery: '25 días',
    desc: 'Catálogos grandes, funcionalidades avanzadas.',
    accent: 'purple',
    popular: false,
    note: null,
    features: [
      'Todo de Estándar más:',
      '50-500 productos',
      'Carga masiva CSV',
      'Variaciones múltiples',
      'Inventario avanzado',
      'Múltiples pasarelas de pago',
      'Integración paqueterías (Fedex, DHL, Estafeta)',
      'Cálculo envíos automáticos',
      'Reseñas de productos',
      'Wishlist',
      'Upselling y cross-selling',
      'Email marketing integrado',
      'Recuperación de carritos abandonados',
      'Dashboard de ventas',
      'SEO avanzado',
      'Google Merchant Center',
      '2 sesiones de capacitación',
      'Entrega: 25 días',
      '3 rondas de revisiones',
    ],
  },
  {
    name: 'Headless E-Commerce',
    price: '$22,000',
    renewal: '$5,800',
    delivery: '30-35 días',
    desc: 'Frontend Astro ultra rápido + backend WooCommerce/Saleor.',
    accent: 'amber',
    popular: false,
    note: null,
    features: [
      'Todo de Pro más:',
      'Frontend Astro (ultra rápido)',
      'API REST / GraphQL',
      'PageSpeed 95+',
      'Diseño 100% personalizado',
      'SEO superior con HTML estático',
      'Seguridad mejorada',
      'Checkout personalizado',
      'Integración cualquier API',
      'Experiencia tipo app',
      'Escalabilidad ilimitada',
      'Panel WooCommerce personalizado',
      'Entrega: 30-35 días',
      '3 rondas de revisiones',
    ],
  },
];

const accentColors: Record<string, { border: string; check: string; badge: string; btn: string }> = {
  emerald: { border: 'border-emerald-500/30', check: 'text-emerald-400', badge: 'bg-emerald-500/20 text-emerald-300', btn: 'border-emerald-500 text-emerald-400 hover:bg-emerald-500 hover:text-white' },
  blue: { border: 'border-blue-500/30', check: 'text-blue-400', badge: 'bg-blue-500/20 text-blue-300', btn: 'border-blue-500 text-blue-400 hover:bg-blue-500 hover:text-white' },
  purple: { border: 'border-purple-500/30', check: 'text-purple-400', badge: 'bg-purple-500/20 text-purple-300', btn: 'border-purple-500 text-purple-400 hover:bg-purple-500 hover:text-white' },
  amber: { border: 'border-amber-500/30', check: 'text-amber-400', badge: 'bg-amber-500/20 text-amber-300', btn: 'border-amber-500 text-amber-400 hover:bg-amber-500 hover:text-white' },
};

const plansWithColors = planes.map((plan) => ({
  ...plan,
  colors: accentColors[plan.accent],
  cardClass: plan.popular
    ? 'bg-gradient-to-br from-blue-600/20 via-cyan-600/20 to-emerald-600/20 text-white ring-2 ring-blue-400/50 shadow-2xl shadow-blue-500/20 scale-105 border border-blue-500/30'
    : 'bg-dark-800/80 backdrop-blur-sm text-white border ' + accentColors[plan.accent].border,
  btnClass: plan.popular
    ? 'bg-gradient-to-r from-blue-500 to-emerald-500 border-transparent text-white hover:opacity-90 shadow-lg shadow-blue-500/25'
    : accentColors[plan.accent].btn,
}));

const included = [
  { icon: '🎨', title: 'Diseño a la medida', desc: 'Sin plantillas genéricas. Diseño único para tu marca.' },
  { icon: '🌐', title: 'Hosting + dominio 1 año', desc: 'Servidor optimizado y dominio .com o .mx incluido.' },
  { icon: '🔒', title: 'Certificado SSL', desc: 'Conexión segura HTTPS para tus clientes y pagos.' },
  { icon: '📱', title: 'Responsive', desc: 'Se ve perfecto en celular, tablet y computadora.' },
  { icon: '💬', title: 'WhatsApp por producto', desc: 'Botón de contacto directo en cada producto.' },
  { icon: '📊', title: 'Google Analytics', desc: 'Métricas de visitas, comportamiento y conversiones.' },
  { icon: '🔍', title: 'SEO on-page', desc: 'Optimización para aparecer en Google desde el día uno.' },
  { icon: '🎓', title: 'Capacitación', desc: 'Te enseñamos a administrar tu tienda paso a paso.' },
  { icon: '🛠️', title: 'Soporte 30 días', desc: 'Asistencia post-lanzamiento para resolver cualquier duda.' },
];

const addons = [
  { name: 'Productos adicionales', price: '$15/producto', icon: '📦' },
  { name: 'Sesión fotográfica', price: 'Desde $3,500', icon: '📸' },
  { name: 'Integración ERP', price: 'Desde $5,000', icon: '🔗' },
  { name: 'App móvil PWA', price: '$8,000', icon: '📲' },
  { name: 'Multi-idioma', price: '$4,500', icon: '🌍' },
  { name: 'Mantenimiento mensual', price: 'Desde $2,800/mes', icon: '⚙️' },
  { name: 'Migración de tienda', price: 'Desde $3,000', icon: '🚚' },
];

const faqs = [
  {
    q: '¿Cuánto tiempo tarda en estar lista mi tienda en línea?',
    a: 'Depende del plan: el Catálogo WooCommerce se entrega en 12 días, la Tienda Estándar en 18 días, la Pro en 25 días y la Headless en 30-35 días. Estos son tiempos calendario. Si tienes urgencia, podemos agilizar el proceso.',
  },
  {
    q: '¿Qué método de pago pueden aceptar mis clientes?',
    a: 'Integramos Stripe, Conekta, PayPal y pagos en OXXO. Tus clientes pueden pagar con tarjeta de crédito, débito, transferencia o efectivo en tienda. Todas las transacciones son seguras con cifrado SSL.',
  },
  {
    q: '¿Necesito saber de tecnología para administrar mi tienda?',
    a: 'No. WooCommerce tiene un panel de administración muy intuitivo. Además, incluimos capacitación personalizada donde te enseñamos a agregar productos, gestionar pedidos, ver reportes de ventas y más.',
  },
  {
    q: '¿Puedo migrar desde Shopify, Wix o Mercado Libre?',
    a: 'Sí. Ofrecemos servicio de migración desde cualquier plataforma. Trasladamos productos, imágenes, descripciones y categorías. El costo depende del volumen de productos (desde $3,000 MXN).',
  },
  {
    q: '¿Qué pasa con los envíos?',
    a: 'En los planes Estándar y superiores integramos cálculo de envíos automático. En el plan Pro además conectamos con paqueterías como Fedex, DHL y Estafeta para generar guías directamente desde tu panel.',
  },
  {
    q: '¿Cobran comisión por cada venta?',
    a: 'Nosotros no cobramos ninguna comisión. La única comisión es la del procesador de pagos (Stripe ~3.6%, Conekta ~2.9%). A diferencia de Mercado Libre (15-20%) o Shopify (2% + plan mensual), tu tienda propia es mucho más rentable.',
  },
];
---

<Layout title="Tu Tienda en Línea Profesional: Vende 24/7 | Portafolio Z" description="Tienda online profesional con WooCommerce o headless. Catálogo, carrito, pagos seguros, envíos. Desde $7,800 MXN.">
  <Navbar />

  <!-- SECCION 1: Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-600 via-emerald-500 to-teal-500"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-teal-400/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-emerald-400/20 rounded-full blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <nav class="flex justify-center items-center gap-2 text-sm text-white/60 mb-6" data-animate>
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <span>Servicios</span>
        <span>/</span>
        <span class="text-white">E-Commerce</span>
      </nav>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6" data-animate>
        Tu Tienda en Línea Profesional: Vende 24/7 desde <span class="text-teal-300">Tu Propia Plataforma</span>
      </h1>
      <p class="text-xl text-white/80 max-w-3xl mx-auto mb-8" data-animate>
        Desde un catálogo digital para mostrar tus productos hasta una tienda completa con carrito, pagos y envíos. <strong class="text-white">Deja de depender solo de redes sociales o marketplaces.</strong>
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8" data-animate>
        <a href={`https://wa.me/5215647215472?text=${encodeURIComponent('Hola, me interesa una *Tienda en Línea*. ¿Me pueden dar más información?')}`} target="_blank" rel="noopener" class="wa-lead bg-white text-emerald-600 font-bold px-8 py-4 rounded-full text-lg hover:bg-white/90 transition-all hover:scale-105 shadow-xl cursor-pointer" data-plan="Tienda en Línea" data-price="" data-category="Tienda en Línea E-Commerce">
          Cotizar Mi Tienda Online
        </a>
        <a href={`https://wa.me/5215647215472?text=${encodeURIComponent('Hola, me interesa una *Tienda en Línea*. ¿Me pueden dar más información?')}`} target="_blank" rel="noopener" class="wa-lead border-2 border-white/40 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all" data-plan="Tienda en Línea" data-price="" data-category="Tienda en Línea E-Commerce">
          Hablar con un Asesor
        </a>
      </div>
      <div class="flex flex-wrap justify-center gap-6 text-white/70 text-sm" data-animate>
        <span class="flex items-center gap-2"><span class="text-teal-300 font-bold">+80</span> tiendas creadas</span>
        <span class="hidden sm:block">·</span>
        <span class="flex items-center gap-2">Desde <span class="text-teal-300 font-bold">$7,800 MXN</span></span>
        <span class="hidden sm:block">·</span>
        <span class="flex items-center gap-2">Pagos seguros <span class="text-teal-300 font-bold">Stripe/Conekta</span></span>
      </div>
    </div>
  </section>

  <!-- SECCION 2: Why Your Own Store -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6" data-animate>
        <p class="text-sm font-semibold text-emerald-500 tracking-wider uppercase mb-3">El problema</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
          ¿Por Qué Necesitas Tu Propia <span class="gradient-text">Tienda en Línea</span>?
        </h2>
      </div>
      <p class="text-gray-600 text-center max-w-3xl mx-auto mb-16" data-animate>
        Vender solo en Instagram, Facebook o Mercado Libre tiene límites. Dependes de sus reglas, sus comisiones y sus algoritmos. Con tu propia tienda, tú tienes el control.
      </p>

      <!-- Limitation cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        {limitations.map((l) => (
          <div class="relative p-8 rounded-2xl bg-red-50 border border-red-100 hover:shadow-xl transition-all group" data-animate>
            <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${l.gradient} flex items-center justify-center text-2xl mb-5 group-hover:scale-110 transition-transform`}>
              {l.icon}
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">{l.title}</h3>
            <p class="text-red-600/80 leading-relaxed">{l.desc}</p>
          </div>
        ))}
      </div>

      <!-- Advantage items -->
      <div class="max-w-3xl mx-auto" data-animate>
        <h3 class="text-xl font-bold text-gray-900 mb-6 text-center">Con tu propia tienda en línea:</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {advantages.map((a) => (
            <div class="flex items-start gap-3 bg-emerald-50 border border-emerald-100 rounded-xl p-4">
              <span class="text-2xl flex-shrink-0">{a.icon}</span>
              <span class="text-gray-700 font-medium">{a.text}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION 3: Plans (4 cards) -->
  <section class="relative bg-dark-900 py-24 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(16,185,129,0.15),transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,rgba(20,184,166,0.15),transparent_50%)]"></div>
    <div class="absolute top-10 left-1/4 w-64 h-64 bg-emerald-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-1/4 w-80 h-80 bg-teal-500/10 rounded-full blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6" data-animate>
        <p class="text-emerald-400 font-medium text-sm uppercase tracking-widest mb-3">Planes E-Commerce</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          Elige el Plan Ideal para Tu <span class="gradient-text">Tienda Online</span>
        </h2>
      </div>
      <p class="text-gray-400 text-center max-w-3xl mx-auto mb-16" data-animate>
        Todos los planes incluyen: hosting y dominio el primer año, certificado SSL, diseño a la medida, responsive, WhatsApp, Google Analytics y soporte post-lanzamiento.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6" data-animate>
        {plansWithColors.map((plan) => (
          <div class={`relative rounded-2xl p-7 transition-all duration-300 hover:-translate-y-2 ${plan.cardClass}`}>
            {plan.popular && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                <span class="bg-gradient-to-r from-blue-500 to-emerald-500 text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-lg">Recomendado</span>
              </div>
            )}
            <div class={`inline-flex items-center gap-1.5 ${plan.colors.badge} text-xs font-medium px-3 py-1 rounded-full mb-4`}>
              <span>{plan.delivery}</span>
            </div>
            <h3 class="text-lg font-bold mb-1 text-white">{plan.name}</h3>
            <p class="text-xs mb-5 text-gray-400">{plan.desc}</p>
            <div class="mb-2">
              <span class="text-3xl font-extrabold text-white">{plan.price}</span>
              <span class="text-xs ml-1 text-gray-500">MXN + IVA</span>
            </div>
            <p class="text-[10px] text-gray-500 mb-5">Renovación anual: {plan.renewal} + IVA</p>
            <ul class="space-y-2.5 mb-6">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm">
                  <svg class={`w-4 h-4 flex-shrink-0 mt-0.5 ${plan.colors.check}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-gray-300">{f}</span>
                </li>
              ))}
            </ul>
            {plan.note && (
              <p class="text-[11px] text-red-400/80 mb-4 bg-red-500/10 rounded-lg px-3 py-2">{plan.note}</p>
            )}
            <a href={`https://wa.me/5215647215472?text=${encodeURIComponent(`Hola, me interesa el plan *${plan.name}* (${plan.price}) de Tienda en Línea. ¿Me pueden dar más información?`)}`} target="_blank" rel="noopener" class={`wa-lead w-full text-center font-semibold py-3 px-5 rounded-full transition-all text-sm border-2 cursor-pointer block ${plan.btnClass}`} data-plan={plan.name} data-price={plan.price} data-category="Tienda en Línea E-Commerce">
              Cotizar Tienda
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCION 4: Included in All Plans -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-600 via-emerald-500 to-teal-500"></div>
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-3xl -translate-y-1/2"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-teal-500/10 rounded-full blur-3xl translate-y-1/2"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6" data-animate>
        <p class="text-sm font-semibold text-teal-200 tracking-wider uppercase mb-3">Todo incluido</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">
          Esto Viene Incluido en <span class="text-teal-300">Cualquier Plan</span>
        </h2>
      </div>
      <p class="text-white/70 text-center max-w-3xl mx-auto mb-16" data-animate>
        Sin importar el plan que elijas, tu tienda en línea viene equipada con todo lo esencial para vender desde el primer día.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {included.map((item) => (
          <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-6 hover:bg-white/15 transition-all duration-300" data-animate>
            <div class="text-3xl mb-4">{item.icon}</div>
            <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
            <p class="text-white/70 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCION 5: Add-Ons -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-sm font-semibold text-emerald-500 tracking-wider uppercase mb-3">Extras</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
          Personaliza Tu <span class="gradient-text">Tienda</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {addons.map((addon) => (
          <div class="bg-white rounded-2xl p-6 border border-gray-200 hover:shadow-lg hover:-translate-y-1 transition-all duration-300" data-animate>
            <div class="text-3xl mb-4">{addon.icon}</div>
            <h3 class="text-base font-bold text-gray-900 mb-1">{addon.name}</h3>
            <p class="text-emerald-600 font-semibold text-lg">{addon.price}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCION 6: FAQ -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-sm font-semibold text-emerald-500 tracking-wider uppercase mb-3">FAQ</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Preguntas Frecuentes sobre <span class="gradient-text">E-Commerce</span></h2>
      </div>
      <div class="space-y-4">
        {faqs.map((faq, i) => (
          <div class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden" data-animate>
            <button class="faq-toggle-ecom w-full px-6 py-5 text-left flex justify-between items-center gap-4 cursor-pointer" data-faq={i}>
              <span class="font-semibold text-gray-900">{faq.q}</span>
              <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
