---
/**
 * diseno-web-cdmx.astro - Landing evergreen para Diseno Web en CDMX
 *
 * Secciones:
 * 1. Hero - Banner con CTA
 * 2. 3 Pilares principales
 * 3. Que incluyen los disenos
 * 4. Paquetes / Pricing
 * 5. Beneficios + propuesta de valor
 * 6. Testimonios
 * 7. FAQ
 * 8. Formulario de contacto
 * 9. CTA final
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';

const pilares = [
  {
    icon: '🎨',
    title: 'Desarrollo y Diseno Web Personalizado',
    desc: 'Creamos sitios web elegantes, funcionales y optimizados para tu posicionamiento online que capturan la esencia de tu negocio.',
    gradient: 'from-cyan-500 to-primary-500',
  },
  {
    icon: '📊',
    title: 'Consultoria de Marketing a tu Medida',
    desc: 'Nuestra consultoria personalizada esta disenada para que tu sitio web venda y comience a posicionarse en internet. Hacemos que tu inversion genere ingresos.',
    gradient: 'from-primary-500 to-accent-500',
  },
  {
    icon: '✍️',
    title: 'Copywriting que Realmente Conecta',
    desc: 'Nuestro equipo de expertos copywriters creara textos atractivos que resuenen con tus clientes y aumente las conversiones de tu sitio.',
    gradient: 'from-accent-500 to-pink-500',
  },
];

const features = [
  { icon: '🌐', title: 'Hosting y Dominio Web', desc: 'No sabes como registrar el dominio web que deseas? Nosotros lo hacemos por ti. Almacenamos tu informacion en nuestro hosting y te damos asistencia tecnica.' },
  { icon: '🎨', title: 'Desarrollo Web a la Medida', desc: 'Desarrollamos el sitio web de tus suenos. Nos adaptamos 100% a cada proyecto, te aseguramos que lo lograremos.' },
  { icon: '🖼️', title: 'Banco de Imagenes', desc: 'Todos nuestros desarrollos web incluyen recursos de los principales bancos de imagenes mundiales. Sin costo adicional.' },
  { icon: '🔒', title: 'Navegacion Segura', desc: 'Todos nuestros sitios web tienen la garantia del certificado SSL, seguridad contra ataques y backups semanales.' },
  { icon: '🔍', title: 'Posicionamiento en Google', desc: 'SEO basico en todos nuestros planes. Imagina posicionarte entre los primeros lugares de los motores de busqueda.' },
  { icon: '🛟', title: 'Soporte y Capacitacion', desc: 'Soporte en fallas tecnicas y capacitaciones de gestion de sitios o tiendas e-commerce. No te preocupes si no sabes gestionar tu website.' },
];

const planes = [
  {
    name: 'Landing Performance',
    price: '$3,800',
    desc: 'Ideal para campanas y emprendedores.',
    features: ['Hosting y Dominio incluido', 'Diseno estrategico Landing Page', 'Desarrollo ultra rapido y a la medida', 'Responsive + WhatsApp CTA', 'Formulario de contacto', 'Google Analytics + eventos', 'SEO basico on-page', 'Certificado SSL'],
    popular: false,
    renewal: '$1,840',
    delivery: '7 dias',
  },
  {
    name: 'Web Corporativa',
    price: '$6,400',
    desc: 'Presencia profesional completa.',
    features: ['Hosting y Dominio incluido', 'Diseno personalizado', 'Desarrollo ultra rapido y a la medida', 'Hasta 6 paginas internas', 'Formulario + WhatsApp CTA', 'SEO tecnico basico', 'Core Web Vitals optimizado', 'Certificado SSL'],
    popular: true,
    renewal: '$2,450',
    delivery: '15 dias',
  },
  {
    name: 'Web SEO Performance',
    price: '$8,900',
    desc: 'Crece con Google organicamente.',
    features: ['Hosting y Dominio incluido', 'Arquitectura SEO completa', 'Desarrollo ultra rapido y a la medida', 'Hasta 10 paginas', 'Estrategia de palabras clave', 'Schema markup', 'Search Console integrado', 'Analytics con eventos conversion', 'Certificado SSL'],
    popular: false,
    renewal: '$3,140',
    delivery: '20 dias',
  },
];

const testimonios = [
  { name: 'Claudia Moran', company: 'Seguridad Civil', text: 'Es un proveedor muy responsable, los servicios son dados con prontitud y cumpliendo con nuestras expectativas digitales.', stars: 5 },
  { name: 'Ivan Damian', company: 'Dig Promocionales', text: 'Maravilloso servicio, muy profesionales y con excelentes resultados. Todos mis clientes me chulean mi sitio. Ha sido muy inteligente invertir en Portafolio Z.', stars: 5 },
  { name: 'Alejandra Cisneros', company: 'Termoventanas', text: 'Excelente servicio, muy atentos y formales, siempre solucionando los problemas al momento. La mejor inversion que hemos hecho.', stars: 5 },
];

const faqs = [
  { q: 'Cuando tengo que pagar de nuevo?', a: 'La renovacion es anual. Landing Performance: $1,840 + IVA. Web Corporativa: $2,450 + IVA. Web SEO Performance: $3,140 + IVA. Incluye hosting, dominio y soporte.' },
  { q: 'Si quiero cambiar el contenido, tiene un costo adicional?', a: 'Si, contamos con planes y costos a la medida segun el tipo de contenido y la recurrencia de los cambios.' },
  { q: 'Como me puedes ayudar con el contenido de mi sitio?', a: 'Te ayudamos con la estructura y contamos con equipo de redaccion, diseno y fotografia para crear contenido profesional.' },
  { q: 'Que necesito para tener mi sitio web?', a: 'Informacion de tu negocio, responder un cuestionario y proporcionar contenido: secciones, textos, fotografias y graficos.' },
  { q: 'Como se paga el diseno web?', a: '50% al iniciar el proyecto y 50% al entregar. Aceptamos transferencia, deposito y tarjeta.' },
  { q: 'Cuanto tiempo tarda el desarrollo?', a: '8-10 dias habiles. A los 3 dias recibiras un avance. Si es urgente, podemos agilizar el proceso.' },
];
---

<Layout title="Agencia de Diseno Web CDMX | Atrae Mas Clientes y Ventas" description="Creamos sitios web profesionales en CDMX en solo 6 dias. Paquetes desde $6,900. Diseno personalizado, SEO, hosting y soporte incluido.">
  <Navbar />

  <!-- SECCION 1: Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-600 via-accent-600 to-pink-600"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-cyan-500/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-pink-500/20 rounded-full blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <nav class="flex justify-center items-center gap-2 text-sm text-white/60 mb-6">
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-white">Diseno Web CDMX</span>
      </nav>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
        Necesitas un <span class="gradient-text">Sitio Web</span> Efectivo para tu negocio?
      </h1>
      <p class="text-xl text-white/80 max-w-3xl mx-auto mb-8">
        Creamos Sitios Web en CDMX en solo <strong class="text-white">6 dias</strong>. Diseno personalizado, optimizado para ventas y posicionamiento en Google.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`https://wa.me/5215564721547?text=${encodeURIComponent('Hola, me interesa el servicio de *Diseño Web en CDMX*. ¿Me pueden dar más información?')}`} target="_blank" rel="noopener" class="wa-lead bg-white text-primary-600 font-bold px-8 py-4 rounded-full text-lg hover:bg-white/90 transition-all hover:scale-105 shadow-xl" data-plan="Hero CTA" data-price="" data-category="Diseño Web CDMX">
          Cotiza Ahora
        </a>
        <a href={`https://wa.me/5215564721547?text=${encodeURIComponent('Hola, me interesa el servicio de *Diseño Web en CDMX*. ¿Me pueden dar más información?')}`} target="_blank" rel="noopener" class="wa-lead border-2 border-white/40 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all" data-plan="Hero WhatsApp" data-price="" data-category="Diseño Web CDMX">
          Hablar por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- SECCION 2: 3 Pilares -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-sm font-semibold text-accent-500 tracking-wider uppercase mb-3">Lo que nos diferencia</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
          Todos nuestros paquetes incluyen estos <span class="gradient-text">3 pilares</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {pilares.map((p) => (
          <div class="relative p-8 rounded-2xl bg-gray-50 border border-gray-100 hover:shadow-xl transition-all group" data-animate>
            <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${p.gradient} flex items-center justify-center text-2xl mb-5 group-hover:scale-110 transition-transform`}>
              {p.icon}
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{p.title}</h3>
            <p class="text-gray-600 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCION 3: Que incluyen los disenos -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-600 via-accent-600 to-pink-600"></div>
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-3xl -translate-y-1/2"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">
          Todos los disenos de sitios web <span class="text-cyan-300">incluyen</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((f) => (
          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-all duration-300" data-animate>
            <div class="text-3xl mb-4">{f.icon}</div>
            <h3 class="text-lg font-bold text-white mb-2">{f.title}</h3>
            <p class="text-white/70 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCION 4: Paquetes / Pricing -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-sm font-semibold text-accent-500 tracking-wider uppercase mb-3">Paquetes</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
          Paquetes <span class="gradient-text">Diseno Web CDMX</span>
        </h2>
        <p class="text-gray-600 mt-4 max-w-2xl mx-auto">Elige el paquete que necesites, todos son escalables. Nuestro equipo esta listo para transformar tu vision en una realidad digital.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {planes.map((plan) => (
          <div class={`relative rounded-2xl p-8 ${plan.popular ? 'bg-gradient-to-br from-primary-600 via-accent-600 to-pink-600 text-white shadow-2xl shadow-accent-500/25 scale-105' : 'bg-gray-50 border border-gray-200'} transition-all hover:shadow-xl`} data-animate>
            {plan.popular && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full bg-cyan-400 text-dark-900 text-xs font-bold uppercase tracking-wider">
                Popular
              </div>
            )}
            <h3 class={`text-xl font-bold mb-2 ${plan.popular ? 'text-white' : 'text-gray-900'}`}>{plan.name}</h3>
            <p class={`text-sm mb-4 ${plan.popular ? 'text-white/70' : 'text-gray-500'}`}>{plan.desc}</p>
            <div class="mb-6">
              <span class={`text-4xl font-bold ${plan.popular ? 'text-white' : 'gradient-text'}`}>{plan.price}</span>
              <span class={`text-sm ${plan.popular ? 'text-white/60' : 'text-gray-400'}`}> + IVA</span>
              <p class={`text-xs mt-1 ${plan.popular ? 'text-white/50' : 'text-gray-400'}`}>Solo un pago</p>
            </div>
            <ul class="space-y-3 mb-8">
              {plan.features.map((f) => (
                <li class={`flex items-start gap-2 text-sm ${plan.popular ? 'text-white/90' : 'text-gray-600'}`}>
                  <svg class={`w-5 h-5 flex-shrink-0 mt-0.5 ${plan.popular ? 'text-cyan-300' : 'text-accent-500'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href={`https://wa.me/5215564721547?text=${encodeURIComponent(`Hola, me interesa el plan *${plan.name}* (${plan.price}) de Diseño Web CDMX. ¿Me pueden dar más información?`)}`} target="_blank" rel="noopener" class={`wa-lead block text-center w-full py-3 rounded-xl font-semibold transition-all ${plan.popular ? 'bg-white text-primary-600 hover:bg-white/90' : 'gradient-bg text-white hover:opacity-90'}`} data-plan={plan.name} data-price={plan.price} data-category="Diseño Web CDMX">
              Comienza hoy
            </a>
            <p class={`text-xs text-center mt-3 ${plan.popular ? 'text-white/40' : 'text-gray-400'}`}>Renovacion anual: {plan.renewal} + IVA</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCION 5: Beneficios -->
  <section class="py-20 bg-dark-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div data-animate>
          <p class="text-sm font-semibold text-cyan-400 tracking-wider uppercase mb-3">Propuesta de valor</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">
            Imagina un <span class="gradient-text">Diseno Web</span> Hecho Solo para Ti
          </h2>
          <p class="text-white/60 mb-8 leading-relaxed">La presencia en linea de tu negocio es mas crucial que nunca. Si estas lidiando con un sitio web desactualizado o no tienes uno, puede ser el momento de una transformacion.</p>
          <ul class="space-y-4">
            {[
              'Hosting y dominio por un ano incluido',
              'Diseno moderno y personalizado que captura tu marca',
              'Optimizado para dispositivos moviles',
              'Enfocado a la conversion para cerrar ventas online',
              'Visible en motores de busqueda con SEO',
              'Banco de imagenes y videos incluido',
              'Textos optimizados para tu web',
              'Asesoria de marketing y ventas',
            ].map((item) => (
              <li class="flex items-start gap-3 text-white/80">
                <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="grid grid-cols-2 gap-4" data-animate>
          {[
            { num: '6', label: 'Dias de entrega' },
            { num: '30+', label: 'Clientes satisfechos' },
            { num: '12+', label: 'Anos de experiencia' },
            { num: '3', label: 'Paises' },
          ].map((stat) => (
            <div class="bg-white/5 border border-white/10 rounded-xl p-6 text-center hover:bg-white/10 transition-colors">
              <div class="text-3xl font-bold gradient-text">{stat.num}</div>
              <div class="text-sm text-white/60 mt-1">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION 6: Testimonios -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-sm font-semibold text-accent-500 tracking-wider uppercase mb-3">Testimonios</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Lo que dicen <span class="gradient-text">nuestros clientes</span></h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonios.map((t) => (
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition-shadow" data-animate>
            <div class="flex gap-1 mb-4">
              {Array(t.stars).fill(0).map(() => (
                <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <p class="text-gray-600 mb-6 leading-relaxed italic">"{t.text}"</p>
            <div>
              <p class="font-semibold text-gray-900">{t.name}</p>
              <p class="text-sm text-accent-500">{t.company}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCION 7: FAQ -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Preguntas <span class="gradient-text">Frecuentes</span></h2>
      </div>
      <div class="space-y-4">
        {faqs.map((faq, i) => (
          <div class="bg-white rounded-xl border border-gray-200 overflow-hidden" data-animate>
            <button class="faq-toggle w-full px-6 py-5 text-left flex justify-between items-center gap-4 cursor-pointer" data-faq={i}>
              <span class="font-semibold text-gray-900">{faq.q}</span>
              <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-gray-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCION 8: CTA Final -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-primary-600 via-accent-600 to-pink-600"></div>
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Comienza a vender hoy mismo</h2>
      <p class="text-white/80 text-lg mb-8">Agenda tu consulta gratuita y empieza a transformar tu negocio con un sitio web profesional.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`https://wa.me/5215564721547?text=${encodeURIComponent('Hola, vi su servicio de *Diseño Web CDMX* y me gustaría cotizar. ¿Me pueden asesorar?')}`} target="_blank" rel="noopener" class="wa-lead bg-white text-primary-600 font-bold px-8 py-4 rounded-full text-lg hover:bg-white/90 transition-all hover:scale-105 shadow-xl" data-plan="CTA Cotización" data-price="" data-category="Diseño Web CDMX">
          Cotiza Ahora
        </a>
        <a href={`https://wa.me/5215564721547?text=${encodeURIComponent('Hola, vi su servicio de *Diseño Web CDMX* y me gustaría cotizar. ¿Me pueden asesorar?')}`} target="_blank" rel="noopener" class="wa-lead border-2 border-white text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all" data-plan="CTA WhatsApp" data-price="" data-category="Diseño Web CDMX">
          WhatsApp
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppWidget />

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.wa-lead').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        if (typeof gtag === 'function') {
          gtag('event', 'generate_lead', {
            event_category: 'WhatsApp',
            plan_name: el.dataset.plan || '',
            plan_price: el.dataset.price || '',
            category: el.dataset.category || '',
            source_page: 'diseno-web-cdmx',
          });
        }
      });
    });
  });
</script>
</Layout>

<script>
function initFaqCdmx() {
  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling;
      const icon = btn.querySelector('svg');
      const isOpen = !content.classList.contains('hidden');
      // Close all
      document.querySelectorAll('.faq-content').forEach(c => c.classList.add('hidden'));
      document.querySelectorAll('.faq-toggle svg').forEach(s => s.style.transform = '');
      // Toggle current
      if (!isOpen) {
        content.classList.remove('hidden');
        icon.style.transform = 'rotate(180deg)';
      }
    });
  });
}
initFaqCdmx();
document.addEventListener('astro:page-load', initFaqCdmx);
</script>
