---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Página no encontrada" description="La página que buscas no existe o fue movida.">
  <Navbar />

  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-dark-900 via-purple-950/60 to-dark-900"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(139,92,246,0.15),transparent_60%)]"></div>

    <div class="relative z-10 text-center px-4 max-w-2xl mx-auto">
      <div class="text-8xl sm:text-9xl font-extrabold gradient-text mb-6">404</div>
      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-4">Página no encontrada</h1>
      <p class="text-white/60 text-lg mb-10">La página que buscas no existe, fue movida o el enlace es incorrecto.</p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="gradient-bg text-white font-semibold px-8 py-4 rounded-full text-lg hover:opacity-90 transition-all hover:scale-105 shadow-xl">
          Ir al inicio
        </a>
        <a href="/contacto" class="border-2 border-white/30 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all">
          Contacto
        </a>
      </div>

      <div class="mt-12 text-white/40 text-sm">
        <p>También puedes visitar:</p>
        <div class="flex flex-wrap gap-4 justify-center mt-3">
          <a href="/servicios" class="text-cyan-400 hover:text-cyan-300 transition-colors">Servicios</a>
          <a href="/proyectos-desarrollo-web" class="text-cyan-400 hover:text-cyan-300 transition-colors">Proyectos</a>
          <a href="/blog" class="text-cyan-400 hover:text-cyan-300 transition-colors">Blog</a>
          <a href="/cotizador" class="text-cyan-400 hover:text-cyan-300 transition-colors">Cotizador</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
