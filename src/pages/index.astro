---
/**
 * index.astro - Homepage de Portafolio Z
 *
 * Ensambla las 14 secciones del sitio en orden segun el diseno de Figma Make.
 * Las secciones alternan entre fondos oscuros y claros para crear
 * contraste visual. Cada componente es independiente y reutilizable.
 *
 * Orden de secciones:
 * 1.  Hero (oscuro)          - Banner principal con CTA
 * 2.  TrustBar (blanco)      - Logos de herramientas/plataformas
 * 3.  Services (oscuro)      - 8 servicios con hover reveal
 * 4.  WhyUs (degradado)      - Historia y razones para elegirnos
 * 5.  Plans (blanco)         - 4 planes de precios
 * 6.  Features (degradado)   - 6 caracteristicas incluidas
 * 7.  Projects (blanco)      - Portafolio de proyectos
 * 8.  TechStack (oscuro)     - 12 tecnologias que usamos
 * 9.  Process (blanco)       - 4 pasos de nuestro proceso
 * 10. CtaSection (degradado) - Call to Action principal
 * 11. BlogPreview (blanco)   - 3 ultimos posts (mock, sera WP REST API)
 * 12. Testimonials (blanco)  - 3 testimonios de clientes
 * 13. ContactForm (oscuro)   - Formulario de contacto + info
 * 14. Footer (oscuro)        - Footer con 3 columnas
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Services from '../components/Services.astro';
import WhyUs from '../components/WhyUs.astro';
import Plans from '../components/Plans.astro';
import Features from '../components/Features.astro';
import Projects from '../components/Projects.astro';
import TechStack from '../components/TechStack.astro';
import Process from '../components/Process.astro';
import CtaSection from '../components/CtaSection.astro';
import BlogPreview from '../components/BlogPreview.astro';
import Testimonials from '../components/Testimonials.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';
---

<Layout title="Agencia de Diseno Web">
  <!-- Navegacion fija (se oscurece al hacer scroll) -->
  <Navbar />

  <!-- 1. Hero (oscuro) - Banner principal con stats y CTAs -->
  <Hero />

  <!-- 2. Trust (blanco) - Logos de herramientas que utilizamos -->
  <TrustBar />

  <!-- 3. Servicios (oscuro) - Cards con hover reveal de descripcion -->
  <Services />

  <!-- 3.5 Servicios Principales - Cards con links a paginas de servicio -->
  <section id="servicios-principales" class="sp-section">
    <div class="sp-container">
      <h2 class="sp-title">Nuestros Servicios Principales</h2>
      <p class="sp-subtitle">Soluciones integrales de marketing digital y desarrollo web para hacer crecer tu negocio</p>
      <div class="sp-grid">

        <a href="/web-sales-machine" class="sp-card">
          <span class="sp-icon">🌐</span>
          <h3 class="sp-card-title">Diseño y Desarrollo Web</h3>
          <p class="sp-card-desc">Sitios web rápidos, modernos y optimizados para convertir visitantes en clientes.</p>
          <span class="sp-badge">Desde $3,800 MXN</span>
          <span class="sp-link">Ver más →</span>
        </a>

        <a href="/posicionamiento-web-seo" class="sp-card">
          <span class="sp-icon">🔍</span>
          <h3 class="sp-card-title">Posicionamiento SEO</h3>
          <p class="sp-card-desc">Aparece en los primeros resultados de Google y atrae tráfico orgánico de calidad.</p>
          <span class="sp-badge">Desde $4,900/mes</span>
          <span class="sp-link">Ver más →</span>
        </a>

        <a href="/growth-marketing" class="sp-card">
          <span class="sp-icon">📈</span>
          <h3 class="sp-card-title">Growth Marketing</h3>
          <p class="sp-card-desc">Estrategias de crecimiento basadas en datos para escalar tu negocio rápidamente.</p>
          <span class="sp-badge">Desde $6,400/mes</span>
          <span class="sp-link">Ver más →</span>
        </a>

        <a href="/leadboost-z" class="sp-card">
          <span class="sp-icon">🤖</span>
          <h3 class="sp-card-title">LeadBoost Z</h3>
          <p class="sp-card-desc">Automatización inteligente con IA para captar y nutrir leads 24/7.</p>
          <span class="sp-badge">Desde $6,900/mes</span>
          <span class="sp-link">Ver más →</span>
        </a>

        <a href="/branding-and-launch-kit" class="sp-card">
          <span class="sp-icon">🎨</span>
          <h3 class="sp-card-title">Branding & Launch Kit</h3>
          <p class="sp-card-desc">Identidad visual completa y kit de lanzamiento para destacar desde el día uno.</p>
          <span class="sp-badge">Desde $4,200 MXN</span>
          <span class="sp-link">Ver más →</span>
        </a>

        <a href="/social-media-marketing" class="sp-card">
          <span class="sp-icon">📱</span>
          <h3 class="sp-card-title">Social Media</h3>
          <p class="sp-card-desc">Gestión profesional de redes sociales para construir comunidad y generar ventas.</p>
          <span class="sp-badge">Desde $6,400/mes</span>
          <span class="sp-link">Ver más →</span>
        </a>

      </div>
    </div>
  </section>

  <style>
    .sp-section {
      background: #0a0a0f;
      padding: 5rem 1.5rem;
      position: relative;
      overflow: hidden;
    }
    .sp-section::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(ellipse at 30% 50%, rgba(139, 92, 246, 0.06) 0%, transparent 60%),
                  radial-gradient(ellipse at 70% 50%, rgba(236, 72, 153, 0.04) 0%, transparent 60%);
      pointer-events: none;
    }
    .sp-container {
      max-width: 1200px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .sp-title {
      text-align: center;
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 800;
      background: linear-gradient(135deg, #fff 0%, #c4b5fd 50%, #f9a8d4 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.75rem;
    }
    .sp-subtitle {
      text-align: center;
      color: rgba(255, 255, 255, 0.6);
      font-size: 1.05rem;
      max-width: 600px;
      margin: 0 auto 3rem;
    }
    .sp-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .sp-card {
      display: flex;
      flex-direction: column;
      padding: 1.75rem;
      background: rgba(255, 255, 255, 0.04);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 1rem;
      text-decoration: none;
      color: #fff;
      transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
    }
    .sp-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(236, 72, 153, 0.08) 100%);
      opacity: 0;
      transition: opacity 0.35s ease;
      border-radius: 1rem;
    }
    .sp-card:hover {
      transform: translateY(-6px);
      border-color: rgba(139, 92, 246, 0.3);
      box-shadow: 0 20px 40px rgba(139, 92, 246, 0.15), 0 0 60px rgba(139, 92, 246, 0.05);
    }
    .sp-card:hover::before {
      opacity: 1;
    }
    .sp-card > * {
      position: relative;
      z-index: 1;
    }
    .sp-icon {
      font-size: 2.25rem;
      margin-bottom: 0.75rem;
      display: block;
    }
    .sp-card-title {
      font-size: 1.15rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: #fff;
    }
    .sp-card-desc {
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.55);
      line-height: 1.5;
      margin-bottom: 1rem;
      flex-grow: 1;
    }
    .sp-badge {
      display: inline-block;
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(236, 72, 153, 0.2));
      border: 1px solid rgba(139, 92, 246, 0.25);
      color: #c4b5fd;
      font-size: 0.8rem;
      font-weight: 600;
      padding: 0.3rem 0.75rem;
      border-radius: 2rem;
      margin-bottom: 0.75rem;
      width: fit-content;
    }
    .sp-link {
      font-size: 0.85rem;
      font-weight: 600;
      color: #a78bfa;
      transition: color 0.3s ease;
    }
    .sp-card:hover .sp-link {
      color: #f9a8d4;
    }
    @media (max-width: 900px) {
      .sp-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 550px) {
      .sp-grid {
        grid-template-columns: 1fr;
      }
      .sp-section {
        padding: 3.5rem 1rem;
      }
    }
  </style>

  <!-- 4. Why Portafolio Z (degradado purpura-rosa) - Nuestra historia -->
  <WhyUs />

  <!-- 5. Planes (blanco) - 4 paquetes de precios en MXN -->
  <Plans />

  <!-- 6. Features (degradado rosa-coral) - Caracteristicas incluidas -->
  <Features />

  <!-- 7. Proyectos (blanco) - Galeria de trabajos realizados -->
  <Projects />

  <!-- 8. Tecnologias (oscuro) - Stack tecnologico -->
  <TechStack />

  <!-- 9. Proceso (blanco) - 4 pasos horizontales con flechas -->
  <Process />

  <!-- 10. CTA (degradado coral-amber) - Call to Action glassmorphism -->
  <CtaSection />

  <!-- 11. Blog (blanco) - Previews de articulos (mock -> WP REST API) -->
  <BlogPreview />

  <!-- 12. Testimonios (blanco) - Opiniones de clientes -->
  <Testimonials />

  <!-- 13. Formulario (oscuro) - Contacto con glassmorphism -->
  <ContactForm />

  <!-- 14. Footer (oscuro) - 3 columnas: CTA + contacto + direccion -->
  <Footer />

  <!-- Widget flotante de WhatsApp (bottom-right, siempre visible) -->
  <WhatsAppWidget />

  <!-- Popup de urgencia/escasez - bottom-left -->
  <div id="urgency-popup" class="urgency-popup" aria-live="polite">
    <button id="urgency-close" class="urgency-close" aria-label="Cerrar">✕</button>
    <p class="urgency-text">🔥 <strong>Marzo 2026:</strong> 20% de descuento en tu primer sitio web. Quedan <strong>7 lugares</strong> este mes.</p>
    <a href="https://wa.me/5215564721547?text=Hola%2C%20vi%20su%20p%C3%A1gina%20y%20me%20gustar%C3%ADa%20*apartar%20mi%20lugar*.%20%C2%BFMe%20pueden%20dar%20m%C3%A1s%20informaci%C3%B3n%3F" target="_blank" rel="noopener" class="wa-lead urgency-cta" style="text-decoration:none;" data-plan="Apartar Mi Lugar" data-price="" data-category="Home">Apartar Mi Lugar</a>
  </div>

  <style>
    .urgency-popup {
      position: fixed;
      bottom: 1.5rem;
      left: 1.5rem;
      z-index: 9998;
      max-width: 360px;
      padding: 1.25rem 1.5rem;
      background: rgba(10, 10, 18, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(139, 92, 246, 0.25);
      border-radius: 1rem;
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4), 0 0 40px rgba(139, 92, 246, 0.1);
      color: #fff;
      transform: translateY(120%);
      opacity: 0;
      transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease;
      pointer-events: none;
    }
    .urgency-popup.visible {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }
    .urgency-popup.hiding {
      transform: translateY(120%);
      opacity: 0;
      pointer-events: none;
    }
    .urgency-close {
      position: absolute;
      top: 0.5rem;
      right: 0.75rem;
      background: none;
      border: none;
      color: rgba(255, 255, 255, 0.5);
      font-size: 1rem;
      cursor: pointer;
      padding: 0.25rem;
      line-height: 1;
      transition: color 0.2s ease;
    }
    .urgency-close:hover {
      color: #fff;
    }
    .urgency-text {
      font-size: 0.9rem;
      line-height: 1.55;
      margin-bottom: 1rem;
      padding-right: 1rem;
      color: rgba(255, 255, 255, 0.9);
    }
    .urgency-cta {
      display: inline-block;
      width: 100%;
      padding: 0.65rem 1.25rem;
      background: linear-gradient(135deg, #8b5cf6, #ec4899);
      color: #fff;
      font-size: 0.9rem;
      font-weight: 700;
      border: none;
      border-radius: 0.5rem;
      text-align: center;
      transition: opacity 0.3s ease, transform 0.2s ease;
    }
    .urgency-cta:hover {
      opacity: 0.9;
      transform: scale(1.02);
    }
    @media (max-width: 480px) {
      .urgency-popup {
        left: 0.75rem;
        right: 0.75rem;
        max-width: none;
        bottom: 1rem;
      }
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const popup = document.getElementById('urgency-popup');
      const closeBtn = document.getElementById('urgency-close');
      if (!popup || !closeBtn) return;

      // Don't show if already dismissed this session
      if (sessionStorage.getItem('urgency-popup-dismissed')) return;

      let autoHideTimer: ReturnType<typeof setTimeout>;

      function hidePopup() {
        popup.classList.remove('visible');
        popup.classList.add('hiding');
        sessionStorage.setItem('urgency-popup-dismissed', '1');
        clearTimeout(autoHideTimer);
      }

      // Show after 5 seconds
      setTimeout(() => {
        popup.classList.add('visible');

        // Auto-hide after 15 seconds
        autoHideTimer = setTimeout(hidePopup, 15000);
      }, 5000);

      closeBtn.addEventListener('click', hidePopup);
    });
  </script>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.wa-lead').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        if (typeof gtag === 'function') {
          gtag('event', 'generate_lead', {
            event_category: 'WhatsApp',
            plan_name: el.dataset.plan || '',
            plan_price: el.dataset.price || '',
            category: el.dataset.category || '',
            source_page: 'home',
          });
        }
      });
    });
  });
</script>
</Layout>
