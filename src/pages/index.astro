---
/**
 * index.astro - Homepage de Portafolio Z
 *
 * Ensambla las 14 secciones del sitio en orden segun el diseno de Figma Make.
 * Las secciones alternan entre fondos oscuros y claros para crear
 * contraste visual. Cada componente es independiente y reutilizable.
 *
 * Orden de secciones:
 * 1.  Hero (oscuro)          - Banner principal con CTA
 * 2.  TrustBar (blanco)      - Logos de herramientas/plataformas
 * 3.  Services (oscuro)      - 8 servicios con hover reveal
 * 4.  WhyUs (degradado)      - Historia y razones para elegirnos
 * 5.  Plans (blanco)         - 4 planes de precios
 * 6.  Features (degradado)   - 6 caracteristicas incluidas
 * 7.  Projects (blanco)      - Portafolio de proyectos
 * 8.  TechStack (oscuro)     - 12 tecnologias que usamos
 * 9.  Process (blanco)       - 4 pasos de nuestro proceso
 * 10. CtaSection (degradado) - Call to Action principal
 * 11. BlogPreview (blanco)   - 3 ultimos posts (mock, sera WP REST API)
 * 12. Testimonials (blanco)  - 3 testimonios de clientes
 * 13. ContactForm (oscuro)   - Formulario de contacto + info
 * 14. Footer (oscuro)        - Footer con 3 columnas
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Services from '../components/Services.astro';
import WhyUs from '../components/WhyUs.astro';
import Plans from '../components/Plans.astro';
import Features from '../components/Features.astro';
import Projects from '../components/Projects.astro';
import TechStack from '../components/TechStack.astro';
import Process from '../components/Process.astro';
import CtaSection from '../components/CtaSection.astro';
import BlogPreview from '../components/BlogPreview.astro';
import Testimonials from '../components/Testimonials.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';
import ServicesPrincipales from '../components/ServicesPrincipales.astro';
import { getCurrentPromo } from '../lib/promos';

const promo = getCurrentPromo();
---

<Layout title="Agencia de Diseno Web">
  <!-- Navegacion fija (se oscurece al hacer scroll) -->
  <Navbar />

  <!-- 1. Hero (oscuro) - Banner principal con stats y CTAs -->
  <Hero />

  <!-- 2. Trust (blanco) - Logos de herramientas que utilizamos -->
  <TrustBar />

  <!-- 3. Servicios (oscuro) - Cards con hover reveal de descripcion -->
  <Services />

  <!-- 3.5 Servicios Principales - Cards con links a paginas de servicio -->
  <ServicesPrincipales />

  <!-- 4. Why Portafolio Z (degradado purpura-rosa) - Nuestra historia -->
  <WhyUs />

  <!-- 5. Planes (blanco) - 4 paquetes de precios en MXN -->
  <Plans />

  <!-- 6. Features (degradado rosa-coral) - Caracteristicas incluidas -->
  <Features />

  <!-- 7. Proyectos (blanco) - Galeria de trabajos realizados -->
  <Projects />

  <!-- 8. Tecnologias (oscuro) - Stack tecnologico -->
  <TechStack />

  <!-- 9. Proceso (blanco) - 4 pasos horizontales con flechas -->
  <Process />

  <!-- 10. CTA (degradado coral-amber) - Call to Action glassmorphism -->
  <CtaSection />

  <!-- 11. Blog (blanco) - Previews de articulos (mock -> WP REST API) -->
  <BlogPreview />

  <!-- 12. Testimonios (blanco) - Opiniones de clientes -->
  <Testimonials />

  <!-- 13. Formulario (oscuro) - Contacto con glassmorphism -->
  <ContactForm />

  <!-- 14. Footer (oscuro) - 3 columnas: CTA + contacto + direccion -->
  <Footer />

  <!-- Widget flotante de WhatsApp (bottom-right, siempre visible) -->
  <WhatsAppWidget />

  <!-- Popup de urgencia/escasez - bottom-left -->
  <div id="urgency-popup" class="urgency-popup" aria-live="polite">
    <button id="urgency-close" class="urgency-close" aria-label="Cerrar">✕</button>
    <p class="urgency-text">{promo.emoji} <strong>{promo.mesAnio}:</strong> {promo.texto}. Quedan <strong>{promo.lugares} lugares</strong> este mes.</p>
    <a href="https://wa.me/5215564721547?text=Hola%2C%20vi%20su%20p%C3%A1gina%20y%20me%20gustar%C3%ADa%20*apartar%20mi%20lugar*.%20%C2%BFMe%20pueden%20dar%20m%C3%A1s%20informaci%C3%B3n%3F" target="_blank" rel="noopener" class="wa-lead urgency-cta" style="text-decoration:none;" data-plan="Apartar Mi Lugar" data-price="" data-category="Home">Apartar Mi Lugar</a>
  </div>

  <style>
    .urgency-popup {
      position: fixed;
      bottom: 1.5rem;
      left: 1.5rem;
      z-index: 9998;
      max-width: 360px;
      padding: 1.25rem 1.5rem;
      background: rgba(10, 10, 18, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(139, 92, 246, 0.25);
      border-radius: 1rem;
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4), 0 0 40px rgba(139, 92, 246, 0.1);
      color: #fff;
      transform: translateY(120%);
      opacity: 0;
      transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease;
      pointer-events: none;
    }
    .urgency-popup.visible {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }
    .urgency-popup.hiding {
      transform: translateY(120%);
      opacity: 0;
      pointer-events: none;
    }
    .urgency-close {
      position: absolute;
      top: 0.5rem;
      right: 0.75rem;
      background: none;
      border: none;
      color: rgba(255, 255, 255, 0.5);
      font-size: 1rem;
      cursor: pointer;
      padding: 0.25rem;
      line-height: 1;
      transition: color 0.2s ease;
    }
    .urgency-close:hover {
      color: #fff;
    }
    .urgency-text {
      font-size: 0.9rem;
      line-height: 1.55;
      margin-bottom: 1rem;
      padding-right: 1rem;
      color: rgba(255, 255, 255, 0.9);
    }
    .urgency-cta {
      display: inline-block;
      width: 100%;
      padding: 0.65rem 1.25rem;
      background: linear-gradient(135deg, #8b5cf6, #ec4899);
      color: #fff;
      font-size: 0.9rem;
      font-weight: 700;
      border: none;
      border-radius: 0.5rem;
      text-align: center;
      transition: opacity 0.3s ease, transform 0.2s ease;
    }
    .urgency-cta:hover {
      opacity: 0.9;
      transform: scale(1.02);
    }
    @media (max-width: 480px) {
      .urgency-popup {
        left: 0.75rem;
        right: 0.75rem;
        max-width: none;
        bottom: 1rem;
      }
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const popup = document.getElementById('urgency-popup');
      const closeBtn = document.getElementById('urgency-close');
      if (!popup || !closeBtn) return;

      // Don't show if already dismissed this session
      if (sessionStorage.getItem('urgency-popup-dismissed')) return;

      let autoHideTimer: ReturnType<typeof setTimeout>;

      function hidePopup() {
        popup.classList.remove('visible');
        popup.classList.add('hiding');
        sessionStorage.setItem('urgency-popup-dismissed', '1');
        clearTimeout(autoHideTimer);
      }

      // Show after 5 seconds
      setTimeout(() => {
        popup.classList.add('visible');

        // Auto-hide after 15 seconds
        autoHideTimer = setTimeout(hidePopup, 15000);
      }, 5000);

      closeBtn.addEventListener('click', hidePopup);
    });
  </script>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.wa-lead').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        if (typeof gtag === 'function') {
          gtag('event', 'generate_lead', {
            event_category: 'WhatsApp',
            plan_name: el.dataset.plan || '',
            plan_price: el.dataset.price || '',
            category: el.dataset.category || '',
            source_page: 'home',
          });
        }
      });
    });
  });
</script>
</Layout>
