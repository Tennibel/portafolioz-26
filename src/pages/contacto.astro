---
/**
 * contacto.astro - Pagina dedicada de Contacto
 *
 * Secciones:
 * 1. Hero interno con breadcrumb
 * 2. Info de contacto + Formulario (2 columnas)
 * 3. Mapa de ubicacion (placeholder/embed)
 * 4. Horarios y redes sociales
 * 5. FAQ rapido
 * 6. CTA WhatsApp
 *
 * Info real de portafolioz.com/contacto/
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';

// Medios de contacto
const contactMethods = [
  {
    title: 'Email',
    value: 'hola@portafolioz.com',
    href: 'mailto:hola@portafolioz.com',
    icon: 'email',
    desc: 'Respuesta en menos de 24 horas',
  },
  {
    title: 'Teléfono',
    value: '55 6195 9724',
    href: 'tel:+525561959724',
    icon: 'phone',
    desc: 'Lun - Vie: 8am a 6pm',
  },
  {
    title: 'WhatsApp',
    value: '56 4721 5472',
    href: 'https://wa.me/5215564721547',
    icon: 'whatsapp',
    desc: 'Respuesta inmediata',
  },
  {
    title: 'Oficina',
    value: 'CDMX, México',
    href: 'https://maps.google.com/?q=Dr+Jose+Maria+Vertiz+84bis+Doctores+Cuauhtemoc+CDMX',
    icon: 'location',
    desc: 'Dr. José María Vértiz 84BIS',
  },
];

// Preguntas frecuentes
const faqs = [
  {
    q: '¿Cuánto tiempo toma crear mi sitio web?',
    a: 'Dependiendo del plan, entre 2 y 6 semanas. Una Landing Page toma aproximadamente 2 semanas, mientras que un Sitio Empresarial puede tomar hasta 6 semanas.',
  },
  {
    q: '¿Incluyen hosting y dominio?',
    a: 'Sí, todos nuestros planes pueden incluir hosting y dominio. Tenemos opciones desde $650 MXN anuales con dominio .com y hasta 15GB de almacenamiento.',
  },
  {
    q: '¿Puedo actualizar mi sitio yo mismo?',
    a: 'Sí, incluimos capacitación para que puedas gestionar tu contenido. Además ofrecemos soporte técnico continuo para resolver cualquier duda.',
  },
  {
    q: '¿Qué formas de pago aceptan?',
    a: 'Aceptamos transferencia bancaria, depósito y pagos con tarjeta. El proyecto se inicia con un anticipo del 50% y el resto al finalizar.',
  },
  {
    q: '¿Hacen tiendas en línea?',
    a: 'Sí, ofrecemos integración de Tienda Online por $3,800 MXN adicionales. Trabajamos con WooCommerce y Shopify según tus necesidades.',
  },
];
---

<Layout title="Contacto" description="Contáctanos para cotizar tu sitio web. Email, WhatsApp, teléfono y oficina en CDMX.">
  <Navbar />

  <!-- ================================================
       SECCION 1: Hero interno
       ================================================ -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-accent-600 via-pink-600 to-coral-500"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="absolute top-10 right-20 w-80 h-80 bg-cyan-400/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-10 w-64 h-64 bg-amber-400/20 rounded-full blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <nav class="flex justify-center gap-2 text-sm text-white/60 mb-6" data-animate>
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-white">Contacto</span>
      </nav>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white mb-4" data-animate>
        Estás a un paso del <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 to-white">éxito</span>
      </h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto" data-animate>
        ¡Quiero comenzar a vender con mi Sitio Web! Contáctanos por cualquiera de nuestros medios.
      </p>
    </div>
  </section>

  <!-- ================================================
       SECCION 2: Medios de contacto (4 cards glassmorphism)
       ================================================ -->
  <section class="bg-white py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 -mt-32 relative z-20" data-animate>
        {contactMethods.map((method) => (
          <a href={method.href} target={method.href.startsWith('http') ? '_blank' : undefined} rel={method.href.startsWith('http') ? 'noopener' : undefined} class="bg-white/80 backdrop-blur-xl rounded-2xl p-6 text-center shadow-xl hover:-translate-y-2 hover:shadow-2xl transition-all duration-300 group border border-white/60">
            <div class="w-14 h-14 rounded-2xl gradient-bg flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform shadow-lg shadow-accent-500/20">
              {method.icon === 'email' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              )}
              {method.icon === 'phone' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              )}
              {method.icon === 'whatsapp' && (
                <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              )}
              {method.icon === 'location' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              )}
            </div>
            <h3 class="text-sm font-bold text-gray-900 mb-1">{method.title}</h3>
            <p class="text-accent-600 font-semibold text-sm mb-1">{method.value}</p>
            <p class="text-gray-400 text-xs">{method.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ================================================
       SECCION 3: Formulario + Info (2 columnas)
       ================================================ -->
  <section class="bg-dark-900 py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <!-- Columna izquierda: Info -->
        <div data-animate>
          <p class="text-cyan-400 font-medium text-sm uppercase tracking-widest mb-3">Escríbenos</p>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
            ¿Listo para hacer crecer <span class="gradient-text">tu negocio?</span>
          </h2>
          <p class="text-white/60 text-lg leading-relaxed mb-8">
            Cuéntanos sobre tu proyecto o negocio y te responderemos en menos de 24 horas con una propuesta personalizada.
          </p>

          <!-- Direccion completa -->
          <div class="glass-card p-6 mb-6">
            <h3 class="text-white font-semibold mb-3">Oficina CDMX</h3>
            <p class="text-white/60 text-sm leading-relaxed">
              Dr. José María Vértiz 84BIS, Doctores,<br/>
              Cuauhtémoc, 06720 Ciudad de México, CDMX
            </p>
            <div class="mt-4 pt-4 border-t border-white/10 grid grid-cols-2 gap-4">
              <div>
                <p class="text-white/40 text-xs mb-1">Lun - Vie</p>
                <p class="text-white text-sm font-medium">8:00 am - 6:00 pm</p>
              </div>
              <div>
                <p class="text-white/40 text-xs mb-1">Sábado</p>
                <p class="text-white text-sm font-medium">9:00 am - 2:00 pm</p>
              </div>
            </div>
          </div>

          <!-- Redes sociales -->
          <div class="flex gap-4">
            <a href="https://facebook.com/portafolioz" target="_blank" rel="noopener" class="w-10 h-10 rounded-full glass flex items-center justify-center text-white/60 hover:text-cyan-400 hover:bg-white/10 transition-all" aria-label="Facebook">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://instagram.com/portafolio.z" target="_blank" rel="noopener" class="w-10 h-10 rounded-full glass flex items-center justify-center text-white/60 hover:text-pink-400 hover:bg-white/10 transition-all" aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="https://tiktok.com/@portafolioz" target="_blank" rel="noopener" class="w-10 h-10 rounded-full glass flex items-center justify-center text-white/60 hover:text-white hover:bg-white/10 transition-all" aria-label="TikTok">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
            </a>
            <a href="https://x.com/PortafolioZ" target="_blank" rel="noopener" class="w-10 h-10 rounded-full glass flex items-center justify-center text-white/60 hover:text-cyan-400 hover:bg-white/10 transition-all" aria-label="X (Twitter)">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          </div>
        </div>

        <!-- Columna derecha: Formulario -->
        <div data-animate>
          <form class="glass-card p-8 space-y-5">
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-white/60 text-sm mb-2">Nombre</label>
                <input type="text" placeholder="Tu nombre" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-colors" />
              </div>
              <div>
                <label class="block text-white/60 text-sm mb-2">Apellido</label>
                <input type="text" placeholder="Tu apellido" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-colors" />
              </div>
            </div>
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-white/60 text-sm mb-2">Email</label>
                <input type="email" placeholder="tu@email.com" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-colors" />
              </div>
              <div>
                <label class="block text-white/60 text-sm mb-2">Teléfono</label>
                <input type="tel" placeholder="55 1234 5678" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-colors" />
              </div>
            </div>
            <div>
              <label class="block text-white/60 text-sm mb-2">¿Qué tipo de sitio necesitas?</label>
              <select class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white/70 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-colors">
                <option value="" class="bg-dark-900">Selecciona una opción</option>
                <option value="landing" class="bg-dark-900">Landing Page ($5,600)</option>
                <option value="basico" class="bg-dark-900">Sitio Básico ($6,400)</option>
                <option value="profesional" class="bg-dark-900">Sitio Profesional ($7,300)</option>
                <option value="empresarial" class="bg-dark-900">Sitio Empresarial ($8,900)</option>
                <option value="tienda" class="bg-dark-900">Tienda en Línea</option>
                <option value="otro" class="bg-dark-900">Otro / No estoy seguro</option>
              </select>
            </div>
            <div>
              <label class="block text-white/60 text-sm mb-2">Cuéntanos tu proyecto</label>
              <textarea rows="4" placeholder="Describe brevemente qué necesitas..." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-colors resize-none"></textarea>
            </div>
            <button type="submit" class="w-full gradient-bg text-white font-semibold py-4 rounded-full text-lg hover:opacity-90 transition-all hover:scale-[1.02]">
              Enviar Mensaje
            </button>
            <p class="text-white/30 text-xs text-center">Al enviar aceptas nuestro aviso de privacidad.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       SECCION 4: Mapa embed
       ================================================ -->
  <section class="bg-white">
    <div class="w-full h-80 bg-gray-100 relative">
      <!-- Google Maps embed de la ubicacion real -->
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3763.0!2d-99.15!3d19.42!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTnCsDI1JzEyLjAiTiA5OcKwMDknMDAuMCJX!5e0!3m2!1ses!2smx!4v1"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Ubicación de Portafolio Z en CDMX"
      ></iframe>
      <!-- Overlay con direccion -->
      <div class="absolute bottom-6 left-6 bg-white/80 backdrop-blur-xl rounded-xl shadow-xl p-4 max-w-xs border border-white/60">
        <p class="font-bold text-gray-900 text-sm">Portafolio Z</p>
        <p class="text-gray-500 text-xs mt-1">Dr. José María Vértiz 84BIS, Doctores, Cuauhtémoc, 06720 CDMX</p>
      </div>
    </div>
  </section>

  <!-- ================================================
       SECCION 5: FAQ
       ================================================ -->
  <section class="bg-white py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-accent-600 font-medium text-sm uppercase tracking-widest mb-3">Preguntas Frecuentes</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
          Resolvemos tus <span class="gradient-text">dudas</span>
        </h2>
      </div>
      <div class="space-y-4" data-animate>
        {faqs.map((faq, i) => (
          <details class="group bg-gray-50 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-gray-100 transition-colors">
              <h3 class="text-base font-semibold text-gray-900 pr-4">{faq.q}</h3>
              <svg class="w-5 h-5 text-accent-500 flex-shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6">
              <p class="text-gray-500 text-sm leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ================================================
       SECCION 6: CTA WhatsApp
       ================================================ -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green-500 via-green-600 to-emerald-600"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-animate>
      <div class="glass-card-light p-12 md:p-16">
        <span class="text-5xl mb-4 block">💬</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark-900 mb-4">
          ¿Prefieres chatear?
        </h2>
        <p class="text-dark-700/70 text-lg mb-8 max-w-xl mx-auto">
          Escríbenos por WhatsApp y recibe respuesta inmediata. Estamos listos para ayudarte.
