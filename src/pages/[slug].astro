---
/**
 * blog/[slug].astro - Pagina individual de articulo del blog
 * Consume el WP REST API para obtener el post por slug
 */
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';

interface WPPost {
  id: number;
  title: { rendered: string };
  excerpt: { rendered: string };
  content: { rendered: string };
  date: string;
  slug: string;
  _embedded?: {
    'wp:featuredmedia'?: Array<{ source_url: string; alt_text: string }>;
    'wp:term'?: Array<Array<{ name: string }>>;
    author?: Array<{ name: string; avatar_urls?: Record<string, string> }>;
  };
}

const { slug } = Astro.params;
const WP_API_URL = import.meta.env.WP_API_URL || process.env.WP_API_URL || '';

let post: {
  title: string;
  content: string;
  excerpt: string;
  category: string;
  date: string;
  image: string;
  imageAlt: string;
  author: string;
} | null = null;

let relatedPosts: Array<{ title: string; slug: string; image: string; category: string; date: string }> = [];

if (WP_API_URL) {
  try {
    const res = await fetch(`${WP_API_URL}/wp-json/wp/v2/posts?slug=${slug}&_embed`, {
      headers: { 'Accept': 'application/json' },
    });
    if (res.ok) {
      const wpPosts: WPPost[] = await res.json();
      if (wpPosts.length > 0) {
        const p = wpPosts[0];
        post = {
          title: p.title.rendered.replace(/<[^>]*>/g, ''),
          content: p.content.rendered,
          excerpt: p.excerpt.rendered.replace(/<[^>]*>/g, '').trim(),
          category: p._embedded?.['wp:term']?.[0]?.[0]?.name || 'Blog',
          date: new Date(p.date).toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' }),
          image: p._embedded?.['wp:featuredmedia']?.[0]?.source_url || '',
          imageAlt: p._embedded?.['wp:featuredmedia']?.[0]?.alt_text || '',
          author: p._embedded?.author?.[0]?.name || 'Portafolio Z',
        };

        // Traer posts relacionados (excluyendo el actual)
        const relRes = await fetch(`${WP_API_URL}/wp-json/wp/v2/posts?per_page=4&_embed&exclude=${p.id}`, {
          headers: { 'Accept': 'application/json' },
        });
        if (relRes.ok) {
          const relPosts: WPPost[] = await relRes.json();
          relatedPosts = relPosts.slice(0, 3).map((r) => ({
            title: r.title.rendered.replace(/<[^>]*>/g, ''),
            slug: r.slug,
            image: r._embedded?.['wp:featuredmedia']?.[0]?.source_url || '',
            category: r._embedded?.['wp:term']?.[0]?.[0]?.name || 'Blog',
            date: new Date(r.date).toLocaleDateString('es-MX', { day: 'numeric', month: 'short', year: 'numeric' }),
          }));
        }
      }
    }
  } catch (e) {
    // Error silencioso
  }
}

if (!post) {
  return Astro.redirect('/blog');
}

const gradients: Record<string, string> = {
  'SEO': 'from-emerald-500 to-cyan-500',
  'Marketing': 'from-orange-500 to-amber-500',
  'Ventas': 'from-pink-500 to-rose-500',
  'Sitio Web': 'from-indigo-500 to-violet-500',
  'Wordpress': 'from-blue-500 to-indigo-500',
  'Estrategias': 'from-purple-500 to-pink-500',
  'Branding': 'from-amber-500 to-orange-500',
};
const gradient = gradients[post.category] || 'from-primary-500 to-accent-500';

const quickLinks = [
  { name: 'Diseño Web', href: '/web-sales-machine', icon: '🌐' },
  { name: 'Marketing', href: '/growth-marketing', icon: '📈' },
  { name: 'SEO', href: '/posicionamiento-web-seo', icon: '🔍' },
  { name: 'Branding', href: '/branding-and-launch-kit', icon: '🎨' },
  { name: 'E-Commerce', href: '/tienda-en-linea-e-commerce', icon: '🛒' },
  { name: 'Cotizador', href: '/cotizador', icon: '💰' },
];
---

<Layout title={`${post.title} | Blog Portafolio Z`} description={post.excerpt}>
  <Navbar />

  <!-- Header del articulo con gradiente -->
  <section class="relative pt-28 pb-12 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-primary-900/80 to-dark-900"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(139,92,246,0.15),transparent_60%)]"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex gap-2 text-sm text-white/50 mb-6" data-animate>
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <a href="/blog" class="hover:text-white transition-colors">Blog</a>
        <span>/</span>
        <span class="text-white/80 line-clamp-1">{post.title}</span>
      </nav>
      <div class="max-w-4xl">
        <div class="flex flex-wrap items-center gap-3 mb-5" data-animate>
          <span class={`bg-gradient-to-r ${gradient} text-white text-xs font-bold px-3 py-1.5 rounded-full`}>
            {post.category}
          </span>
          <time class="text-white/50 text-sm">{post.date}</time>
          <span class="text-white/30">·</span>
          <span class="text-white/50 text-sm">{post.author}</span>
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-6 leading-tight" data-animate>
          {post.title}
        </h1>
        <p class="text-lg text-white/60 leading-relaxed" data-animate>{post.excerpt}</p>
      </div>
    </div>
  </section>

  <!-- Contenido principal + Sidebar -->
  <section class="bg-gray-50 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_320px] gap-12">

        <!-- Columna principal -->
        <div>

          <!-- Imagen destacada -->
          {post.image && (
            <div class="mb-10 rounded-2xl overflow-hidden shadow-lg" data-animate>
              <img src={post.image} alt={post.imageAlt || post.title} class="w-full h-auto object-cover" loading="eager" />
            </div>
          )}

          <!-- Contenido del articulo -->
          <article class="blog-content bg-white rounded-2xl shadow-sm border border-gray-100 p-8 md:p-12 mb-10" set:html={post.content} />

          <!-- Navegacion inferior -->
          <div class="flex items-center justify-between py-8 border-t border-gray-200">
            <a href="/blog" class="inline-flex items-center gap-2 text-primary-600 hover:text-accent-600 text-sm font-medium transition-colors">
              <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              Volver al blog
            </a>
            <a href={`https://wa.me/5215647215472?text=${encodeURIComponent(`Hola, vi el artículo *${post.title}* en su blog y me gustaría más información. ¿Me pueden asesorar?`)}`}
              target="_blank" rel="noopener"
              class="wa-lead inline-flex items-center gap-2 gradient-bg text-white text-sm font-semibold px-6 py-3 rounded-full hover:opacity-90 transition-all hover:scale-105 shadow-lg shadow-primary-500/20"
              data-plan={post.title} data-price="" data-category="Blog">
              ¿Necesitas ayuda?
            </a>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:sticky lg:top-28 lg:self-start space-y-6">

          <!-- Nuestros Servicios -->
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6" data-animate>
            <h3 class="text-sm font-bold text-gray-900 uppercase tracking-wider mb-4">Nuestros Servicios</h3>
            <div class="space-y-2">
              {quickLinks.map((link) => (
                <a href={link.href} class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-50 transition-colors group">
                  <span class="text-xl group-hover:scale-110 transition-transform">{link.icon}</span>
                  <span class="text-sm font-medium text-gray-700 group-hover:text-primary-600 transition-colors">{link.name}</span>
                  <svg class="w-4 h-4 text-gray-300 ml-auto group-hover:text-primary-500 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              ))}
            </div>
          </div>

          <!-- CTA WhatsApp sidebar -->
          <div class="bg-gradient-to-br from-primary-600 to-accent-600 rounded-2xl p-6 text-white shadow-lg shadow-primary-500/20" data-animate>
            <h3 class="text-lg font-bold mb-2">¿Tienes un proyecto en mente?</h3>
            <p class="text-white/70 text-sm mb-5 leading-relaxed">Platiquemos sobre cómo podemos ayudarte a crecer tu negocio.</p>
            <a href={`https://wa.me/5215647215472?text=${encodeURIComponent('Hola, vi su blog y me gustaría cotizar un servicio. ¿Me pueden asesorar?')}`}
              target="_blank" rel="noopener"
              class="wa-lead flex items-center justify-center gap-2 bg-white text-primary-600 font-semibold py-3 px-5 rounded-full text-sm hover:bg-white/90 transition-all hover:scale-105"
              data-plan="Sidebar Blog CTA" data-price="" data-category="Blog">
              <svg class="w-5 h-5 text-green-500" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Escríbenos por WhatsApp
            </a>
          </div>

          <!-- Paquetes Populares -->
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6" data-animate>
            <h3 class="text-sm font-bold text-gray-900 uppercase tracking-wider mb-4">Paquetes Populares</h3>
            <div class="space-y-3">
              <a href="/web-sales-machine" class="block p-3 rounded-xl bg-indigo-50 border border-indigo-100 hover:border-indigo-200 transition-colors">
                <p class="text-sm font-semibold text-indigo-700">Web Corporativa</p>
                <p class="text-xs text-indigo-500">Desde $6,400 MXN</p>
              </a>
              <a href="/growth-marketing" class="block p-3 rounded-xl bg-orange-50 border border-orange-100 hover:border-orange-200 transition-colors">
                <p class="text-sm font-semibold text-orange-700">Growth Marketing</p>
                <p class="text-xs text-orange-500">Desde $6,400/mes</p>
              </a>
              <a href="/posicionamiento-web-seo" class="block p-3 rounded-xl bg-emerald-50 border border-emerald-100 hover:border-emerald-200 transition-colors">
                <p class="text-sm font-semibold text-emerald-700">SEO Positioning</p>
                <p class="text-xs text-emerald-500">Desde $4,900/mes</p>
              </a>
            </div>
          </div>

          <!-- Cotizador CTA -->
          <div class="bg-gray-900 rounded-2xl p-6 text-white" data-animate>
            <h3 class="text-lg font-bold mb-2">Cotiza tu proyecto</h3>
            <p class="text-white/60 text-sm mb-4 leading-relaxed">Usa nuestro cotizador interactivo para obtener un precio estimado al instante.</p>
            <a href="/cotizador" class="block text-center bg-white text-gray-900 font-semibold py-3 px-5 rounded-full text-sm hover:bg-gray-100 transition-all">
              Ir al Cotizador
            </a>
          </div>

          <!-- Sigue leyendo -->
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6" data-animate>
            <h3 class="text-sm font-bold text-gray-900 uppercase tracking-wider mb-4">Sigue leyendo</h3>
            <a href="/blog" class="flex items-center gap-3 text-sm font-medium text-primary-600 hover:text-accent-600 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
              Ver todos los artículos
            </a>
          </div>

          <!-- Categorias del Blog -->
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6" data-animate>
            <h3 class="text-sm font-bold text-gray-900 uppercase tracking-wider mb-4">Categorías</h3>
            <div class="space-y-1">
              <a href="/blog" class="flex items-center justify-between px-3 py-2.5 rounded-lg hover:bg-gray-50 transition-colors">
                <span class="text-sm text-gray-600">SEO</span>
                <span class="text-xs text-gray-400">🔍</span>
              </a>
              <a href="/blog" class="flex items-center justify-between px-3 py-2.5 rounded-lg hover:bg-gray-50 transition-colors">
                <span class="text-sm text-gray-600">Marketing</span>
                <span class="text-xs text-gray-400">📈</span>
              </a>
              <a href="/blog" class="flex items-center justify-between px-3 py-2.5 rounded-lg hover:bg-gray-50 transition-colors">
                <span class="text-sm text-gray-600">Sitio Web</span>
                <span class="text-xs text-gray-400">🌐</span>
              </a>
              <a href="/blog" class="flex items-center justify-between px-3 py-2.5 rounded-lg hover:bg-gray-50 transition-colors">
                <span class="text-sm text-gray-600">Ventas</span>
                <span class="text-xs text-gray-400">💰</span>
              </a>
              <a href="/blog" class="flex items-center justify-between px-3 py-2.5 rounded-lg hover:bg-gray-50 transition-colors">
                <span class="text-sm text-gray-600">Branding</span>
                <span class="text-xs text-gray-400">🎨</span>
              </a>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- Notas relacionadas -->
  {relatedPosts.length > 0 && (
    <section class="bg-white py-16 border-t border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-8" data-animate>También te puede interesar</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-animate>
          {relatedPosts.map((rel) => (
            <a href={`/${rel.slug}`} class="group rounded-2xl overflow-hidden bg-gray-50 border border-gray-200 hover:border-gray-300 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
              <div class="relative h-44 overflow-hidden">
                {rel.image ? (
                  <img src={rel.image} alt={rel.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-primary-500 to-accent-500"></div>
                )}
                <div class="absolute top-3 left-3">
                  <span class="bg-white/90 backdrop-blur-sm text-gray-700 text-[10px] font-bold px-2.5 py-1 rounded-full">{rel.category}</span>
                </div>
              </div>
              <div class="p-5">
                <time class="text-gray-400 text-xs">{rel.date}</time>
                <h3 class="text-base font-bold text-gray-900 mt-1 group-hover:text-primary-600 transition-colors line-clamp-2">{rel.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Servicios relacionados -->
  <section class="bg-gray-50 py-16 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-3" data-animate>Nuestros Servicios</h2>
      <p class="text-gray-500 mb-8" data-animate>Conoce cómo podemos ayudarte a crecer tu negocio</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" data-animate>
        {quickLinks.map((link) => (
          <a href={link.href} class="flex items-center gap-4 bg-white border border-gray-200 rounded-xl p-5 hover:border-primary-300 hover:shadow-md hover:-translate-y-0.5 transition-all group">
            <span class="text-2xl group-hover:scale-110 transition-transform">{link.icon}</span>
            <div>
              <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors">{link.name}</h3>
              <p class="text-gray-400 text-xs">Ver más</p>
            </div>
            <svg class="w-5 h-5 text-gray-300 ml-auto group-hover:text-primary-500 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-primary-600 via-accent-600 to-pink-600"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center" data-animate>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">¿Listo para transformar tu presencia digital?</h2>
      <p class="text-white/80 text-lg mb-8">Aplica lo que aprendes en el blog o déjanos hacerlo por ti.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`https://wa.me/5215647215472?text=${encodeURIComponent('Hola, vi su *Blog* y me gustaría cotizar un servicio. ¿Me pueden asesorar?')}`}
          target="_blank" rel="noopener"
          class="wa-lead bg-white text-primary-600 font-bold px-8 py-4 rounded-full text-lg hover:bg-white/90 transition-all hover:scale-105 shadow-xl"
          data-plan="Solicitar Cotización" data-price="" data-category="Blog">
          Solicitar Cotización
        </a>
        <a href={`https://wa.me/5215647215472?text=${encodeURIComponent('Hola, quiero información sobre sus servicios.')}`}
          target="_blank" rel="noopener"
          class="wa-lead border-2 border-white text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all"
          data-plan="WhatsApp Blog" data-price="" data-category="Blog">
          WhatsApp
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppWidget />

  <style is:global>
    .blog-content {
      font-size: 1.125rem;
      line-height: 1.85;
      color: #4b5563;
    }
    .blog-content h1 {
      font-size: 2.25rem;
      font-weight: 800;
      background: linear-gradient(135deg, #6366f1, #a855f7);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      line-height: 1.25;
    }
    .blog-content h2 {
      font-size: 1.75rem;
      font-weight: 700;
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid #e0e7ff;
      line-height: 1.3;
    }
    .blog-content h3 {
      font-size: 1.375rem;
      font-weight: 700;
      color: #7c3aed;
      margin-top: 2rem;
      margin-bottom: 0.5rem;
      line-height: 1.35;
    }
    .blog-content h4 {
      font-size: 1.125rem;
      font-weight: 600;
      color: #06b6d4;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
      line-height: 1.4;
    }
    .blog-content p {
      margin-bottom: 1.5rem;
      line-height: 1.85;
      text-align: justify;
    }
    .blog-content a {
      color: #7c3aed;
      font-weight: 500;
      text-decoration: none;
      transition: color 0.2s;
    }
    .blog-content a:hover {
      color: #a855f7;
    }
    .blog-content strong, .blog-content b {
      color: #1f2937;
      font-weight: 600;
    }
    .blog-content ul, .blog-content ol {
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
    }
    .blog-content li {
      margin-bottom: 0.5rem;
      line-height: 1.75;
      text-align: justify;
    }
    .blog-content ol li {
      list-style-type: decimal;
    }
    .blog-content ul li {
      list-style-type: disc;
    }
    .blog-content img {
      border-radius: 0.75rem;
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
      margin: 1.5rem 0;
    }
    .blog-content blockquote {
      border-left: 4px solid #7c3aed;
      background: #f5f3ff;
      padding: 1rem 1.5rem;
      border-radius: 0 0.75rem 0.75rem 0;
      margin: 1.5rem 0;
      color: #4b5563;
      font-style: italic;
    }
    .blog-content hr {
      border: none;
      border-top: 1px solid #e5e7eb;
      margin: 2rem 0;
    }
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll('.wa-lead').forEach((btn) => {
        btn.addEventListener('click', () => {
          const el = btn as HTMLElement;
          if (typeof gtag === 'function') {
            gtag('event', 'generate_lead', {
              event_category: 'WhatsApp',
              plan_name: el.dataset.plan || '',
              plan_price: el.dataset.price || '',
              category: el.dataset.category || '',
              source_page: 'blog-post',
            });
          }
        });
      });
    });
  </script>
</Layout>
