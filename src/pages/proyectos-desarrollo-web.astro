---
/**
 * proyectos-desarrollo-web.astro - Portafolio de proyectos publico
 *
 * Grid con infinite scroll + efecto scroll-on-hover en cada tarjeta.
 * Los proyectos se alimentan desde el admin panel (SQLite).
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';
import { getVisibleProjects } from '../lib/db';

// Nota: para el build estático local, este page se prerenderiza.
// Si la BD no existe o falla la consulta, usamos placeholders para evitar romper el build.
export const prerender = true;

const PLACEHOLDER_PROJECTS = [
  {
    nombre: 'Hotel Boutique',
    slug: 'hotel-boutique',
    url: null,
    categoria: 'sitio-web',
    descripcion: 'Landing y diseño de experiencia para un hotel boutique.',
    imagen: null,
    featured: 1,
    visible: 1,
    orden: 1,
    created_at: new Date().toISOString(),
    updated_at: new Date().toISOString(),
  },
  {
    nombre: 'E-Commerce Moda',
    slug: 'ecommerce-moda',
    url: null,
    categoria: 'ecommerce',
    descripcion: 'Tienda online con checkout optimizado y catálogo dinámico.',
    imagen: null,
    featured: 0,
    visible: 1,
    orden: 2,
    created_at: new Date().toISOString(),
    updated_at: new Date().toISOString(),
  },
  {
    nombre: 'Clinica Dental',
    slug: 'clinica-dental',
    url: null,
    categoria: 'landing',
    descripcion: 'Landing enfocada a captación y agendamiento.',
    imagen: null,
    featured: 0,
    visible: 1,
    orden: 3,
    created_at: new Date().toISOString(),
    updated_at: new Date().toISOString(),
  },
];

let initialProjects: Array<any> = [];
let initialHasMore = false;
try {
  const res = getVisibleProjects({ page: 1, perPage: 12 });
  initialProjects = res.projects;
  initialHasMore = res.hasMore;
} catch (e) {
  initialProjects = PLACEHOLDER_PROJECTS;
  initialHasMore = false;
}

const categoriaLabels: Record<string, string> = {
  'landing': 'Landing Page',
  'sitio-web': 'Sitio Web',
  'ecommerce': 'E-commerce',
  'corporativo': 'Corporativo',
  'bienes-raices': 'Bienes Raices',
  'profesional': 'Profesional',
  'restaurante': 'Restaurante',
  'otro': 'Otro',
};
---

<Layout title="Proyectos de Desarrollo Web | Portafolio Z" description="Conoce nuestros proyectos de desarrollo web. Sitios web profesionales, tiendas en linea, landing pages y mas. Resultados que hablan por si solos.">
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-dark-900 via-purple-950/60 to-dark-900"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(168,85,247,0.15),transparent_60%)]"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-cyan-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 bg-cyan-500/20 border border-cyan-500/30 rounded-full px-5 py-2 mb-8" data-animate>
        <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
        <span class="text-sm font-semibold text-cyan-300 tracking-wider uppercase">Nuestro Portafolio</span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6" data-animate>
        Proyectos de
        <br><span class="bg-gradient-to-r from-cyan-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">Desarrollo Web</span>
      </h1>

      <p class="text-xl text-white/60 max-w-2xl mx-auto" data-animate>
        Cada proyecto es unico. Descubre como hemos ayudado a negocios como el tuyo a crecer con una presencia web profesional.
      </p>
    </div>
  </section>

  <!-- PROJECTS SECTION -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-dark-900 to-dark-800"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Category filters -->
      <div class="flex gap-2 mb-12 overflow-x-auto pb-2 justify-center flex-wrap" id="category-filters" data-animate>
        <button data-cat="todas" class="cat-pill active px-5 py-2 rounded-full text-sm font-medium transition-all">
          Todos
        </button>
        {Object.entries(categoriaLabels).map(([key, label]) => (
          <button data-cat={key} class="cat-pill px-5 py-2 rounded-full text-sm font-medium transition-all">
            {label}
          </button>
        ))}
      </div>

      <!-- Projects grid -->
      <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {initialProjects.map(p => (
          <div class="project-card group rounded-2xl overflow-hidden border border-white/10 bg-white/5 hover:border-white/20 transition-all" data-animate>
            <!-- Image container with scroll-on-hover -->
            <div class="relative h-[400px] overflow-hidden">
              {p.imagen ? (
                <img
                  src={p.imagen}
                  alt={p.nombre}
                  class="absolute top-0 left-0 w-full transition-all ease-in-out duration-[3000ms] group-hover:translate-y-[var(--scroll-y)]"
                  loading="lazy"
                  onload="this.style.setProperty('--scroll-y', `calc(-100% + 400px)`)"
                />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-purple-500/20 to-cyan-500/20 flex items-center justify-center">
                  <span class="text-white/20 text-6xl font-bold">{p.nombre.charAt(0)}</span>
                </div>
              )}
              <!-- Overlay gradient -->
              <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-dark-900/90 to-transparent pointer-events-none"></div>
              <!-- Category badge -->
              <div class="absolute top-4 left-4">
                <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-white/10 text-white/80 backdrop-blur-sm">
                  {categoriaLabels[p.categoria] || p.categoria}
                </span>
              </div>
              <!-- Info overlay -->
              <div class="absolute inset-x-0 bottom-0 p-5">
                <h3 class="text-lg font-bold text-white mb-1">{p.nombre}</h3>
                {p.descripcion && <p class="text-sm text-white/60 line-clamp-2">{p.descripcion}</p>}
                {p.url && (
                  <a href={p.url} target="_blank" rel="noopener"
                    class="inline-flex items-center gap-1 text-cyan-400 hover:text-cyan-300 text-sm font-medium mt-2 transition-colors">
                    Ver proyecto
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Loading spinner -->
      <div id="load-more" class={`text-center py-12 ${initialHasMore ? '' : 'hidden'}`}>
        <div class="inline-flex items-center gap-3 text-white/50">
          <svg class="animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          Cargando mas proyectos...
        </div>
      </div>

      <!-- Empty state -->
      <div id="empty-state" class={`text-center py-12 ${initialProjects.length === 0 ? '' : 'hidden'}`}>
        <p class="text-white/40 text-lg">No hay proyectos en esta categoria.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-cyan-600 via-purple-600 to-pink-600"></div>
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4" data-animate>Quieres un proyecto asi?</h2>
      <p class="text-white/80 text-lg mb-8" data-animate>Agenda una consultoria gratuita de 30 minutos y te mostramos como podemos llevar tu negocio al siguiente nivel.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate>
        <a href="/consultoria-marketing-digital" class="bg-white text-purple-600 font-bold px-8 py-4 rounded-full text-lg hover:bg-white/90 transition-all hover:scale-105 shadow-xl">
          Consultoria Gratuita
        </a>
        <a href="https://wa.me/5215647215472?text=Hola%2C%20vi%20su%20*portafolio%20de%20proyectos*%20y%20me%20gustar%C3%ADa%20cotizar%20mi%20sitio%20web.%20%C2%BFMe%20pueden%20asesorar%3F" target="_blank" rel="noopener" class="wa-lead border-2 border-white text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all" data-plan="Contacto Proyectos" data-price="" data-category="Proyectos">
          Contacto
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppWidget />

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.wa-lead').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        if (typeof gtag === 'function') {
          gtag('event', 'generate_lead', {
            event_category: 'WhatsApp',
            plan_name: el.dataset.plan || '',
            plan_price: el.dataset.price || '',
            category: el.dataset.category || '',
            source_page: 'proyectos-desarrollo-web',
          });
        }
      });
    });
  });
</script>
</Layout>

<style>
  .cat-pill {
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.6);
  }
  .cat-pill:hover {
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.8);
  }
  .cat-pill.active {
    background: linear-gradient(135deg, #06b6d4, #8b5cf6);
    color: white;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .project-card.fade-in {
    animation: fadeInUp 0.5s ease forwards;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script define:vars={{ initialHasMore, initialProjectsJSON: JSON.stringify(initialProjects) }}>
</script>

<script>
function initPortfolio() {
  const grid = document.getElementById('projects-grid');
  const loadMore = document.getElementById('load-more');
  const emptyState = document.getElementById('empty-state');
  const pills = document.querySelectorAll<HTMLButtonElement>('.cat-pill');
  if (!grid || !loadMore || !emptyState) return;

  const catLabels: Record<string, string> = {
    'landing': 'Landing Page', 'sitio-web': 'Sitio Web', 'ecommerce': 'E-commerce',
    'corporativo': 'Corporativo', 'bienes-raices': 'Bienes Raices', 'profesional': 'Profesional',
    'restaurante': 'Restaurante', 'otro': 'Otro',
  };

  const initialProjects = (() => {
    try {
      return JSON.parse(initialProjectsJSON || '[]');
    } catch {
      return [];
    }
  })();

  let currentPage = 1;
  let currentCat = 'todas';
  let hasMore = loadMore.classList.contains('hidden') ? false : true;
  let loading = false;

  // Fix image scroll offset after load
  function setupImageScroll() {
    grid.querySelectorAll<HTMLImageElement>('.project-card img').forEach(img => {
      const setup = () => {
        const container = 400;
        const offset = Math.min(0, container - img.naturalHeight);
        img.style.setProperty('--scroll-y', `${offset}px`);
      };
      if (img.complete) setup();
      else img.addEventListener('load', setup);
    });
  }

  setupImageScroll();

  // Category filter
  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      currentCat = pill.dataset.cat || 'todas';

      // En build estático (sin /api), filtramos localmente los proyectos prerenderizados.
      currentPage = 1;
      hasMore = false;
      grid.innerHTML = '';
      loadMore.classList.add('hidden');
      emptyState.classList.add('hidden');

      const filtered = currentCat === 'todas'
        ? initialProjects
        : initialProjects.filter((p: any) => p.categoria === currentCat);

      if (filtered.length === 0) {
        emptyState.classList.remove('hidden');
        loading = false;
        return;
      }

      for (const p of filtered) {
        const card = document.createElement('div');
        card.className = 'project-card group rounded-2xl overflow-hidden border border-white/10 bg-white/5 hover:border-white/20 transition-all fade-in';

        const imgHTML = p.imagen
          ? `<img src="${p.imagen}" alt="${p.nombre}" class="absolute top-0 left-0 w-full transition-all ease-in-out duration-[3000ms] group-hover:translate-y-[var(--scroll-y)]" loading="lazy" />`
          : `<div class="w-full h-full bg-gradient-to-br from-purple-500/20 to-cyan-500/20 flex items-center justify-center"><span class="text-white/20 text-6xl font-bold">${p.nombre.charAt(0)}</span></div>`;

        const urlHTML = p.url
          ? `<a href="${p.url}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-cyan-400 hover:text-cyan-300 text-sm font-medium mt-2 transition-colors">Ver proyecto <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg></a>`
          : '';

        const descHTML = p.descripcion ? `<p class="text-sm text-white/60 line-clamp-2">${p.descripcion}</p>` : '';

        card.innerHTML = `
          <div class="relative h-[400px] overflow-hidden">
            ${imgHTML}
            <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-dark-900/90 to-transparent pointer-events-none"></div>
            <div class="absolute top-4 left-4">
              <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-white/10 text-white/80 backdrop-blur-sm">${catLabels[p.categoria] || p.categoria}</span>
            </div>
            <div class="absolute inset-x-0 bottom-0 p-5">
              <h3 class="text-lg font-bold text-white mb-1">${p.nombre}</h3>
              ${descHTML}
              ${urlHTML}
            </div>
          </div>
        `;

        grid.appendChild(card);
      }

      setupImageScroll();
      loading = false;
    });
  });

  async function loadProjects() {
    if (loading || !hasMore) return;
    loading = true;

    const catParam = currentCat !== 'todas' ? `&categoria=${currentCat}` : '';
    try {
      const res = await fetch(`/api/projects?page=${currentPage}${catParam}`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      if (data.projects.length === 0 && currentPage === 1) {
        emptyState.classList.remove('hidden');
        loadMore.classList.add('hidden');
        loading = false;
        return;
      }

      for (const p of data.projects) {
        const card = document.createElement('div');
        card.className = 'project-card group rounded-2xl overflow-hidden border border-white/10 bg-white/5 hover:border-white/20 transition-all fade-in';

        const imgHTML = p.imagen
          ? `<img src="${p.imagen}" alt="${p.nombre}" class="absolute top-0 left-0 w-full transition-all ease-in-out duration-[3000ms] group-hover:translate-y-[var(--scroll-y)]" loading="lazy" />`
          : `<div class="w-full h-full bg-gradient-to-br from-purple-500/20 to-cyan-500/20 flex items-center justify-center"><span class="text-white/20 text-6xl font-bold">${p.nombre.charAt(0)}</span></div>`;

        const urlHTML = p.url
          ? `<a href="${p.url}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-cyan-400 hover:text-cyan-300 text-sm font-medium mt-2 transition-colors">Ver proyecto <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg></a>`
          : '';

        const descHTML = p.descripcion ? `<p class="text-sm text-white/60 line-clamp-2">${p.descripcion}</p>` : '';

        card.innerHTML = `
          <div class="relative h-[400px] overflow-hidden">
            ${imgHTML}
            <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-dark-900/90 to-transparent pointer-events-none"></div>
            <div class="absolute top-4 left-4">
              <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-white/10 text-white/80 backdrop-blur-sm">${catLabels[p.categoria] || p.categoria}</span>
            </div>
            <div class="absolute inset-x-0 bottom-0 p-5">
              <h3 class="text-lg font-bold text-white mb-1">${p.nombre}</h3>
              ${descHTML}
              ${urlHTML}
            </div>
          </div>
        `;

        grid.appendChild(card);
      }

      setupImageScroll();

      hasMore = data.hasMore;
      if (!hasMore) loadMore.classList.add('hidden');

      currentPage++;
      loading = false;
      return;
    } catch (e) {
      // En estático local no existe /api/projects; evitamos que se quede “cargando” o spameando.
      hasMore = false;
      loadMore.classList.add('hidden');
      if (currentPage === 1 && grid.children.length === 0) emptyState.classList.remove('hidden');
      loading = false;
      return;
    }
  }

  // Infinite scroll with IntersectionObserver
  const observer = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && hasMore && !loading) {
      loadProjects();
    }
  }, { rootMargin: '200px' });

  observer.observe(loadMore);
}

initPortfolio();
document.addEventListener('astro:page-load', initPortfolio);
</script>
