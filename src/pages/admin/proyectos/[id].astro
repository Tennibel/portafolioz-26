---
/**
 * /admin/proyectos/[id] - Editar proyecto
 */
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { isAuthenticated } from '../../../lib/auth';
import { getProjectById } from '../../../lib/db';

if (!isAuthenticated(Astro.request)) {
  return Astro.redirect('/admin/');
}

const id = parseInt(Astro.params.id || '0');
const project = getProjectById(id);

if (!project) {
  return Astro.redirect('/admin/proyectos');
}

const categorias = [
  { value: 'landing', label: 'Landing Page' },
  { value: 'sitio-web', label: 'Sitio Web' },
  { value: 'ecommerce', label: 'E-commerce' },
  { value: 'corporativo', label: 'Corporativo' },
  { value: 'bienes-raices', label: 'Bienes Raices' },
  { value: 'profesional', label: 'Profesional' },
  { value: 'restaurante', label: 'Restaurante' },
  { value: 'otro', label: 'Otro' },
];
---

<AdminLayout title={`Editar: ${project.nombre}`}>
  <div class="max-w-2xl mx-auto">
    <div class="flex items-center gap-4 mb-8">
      <a href="/admin/proyectos" class="text-white/50 hover:text-white transition-colors">&larr; Volver</a>
      <h1 class="text-2xl font-bold text-white">Editar Proyecto</h1>
    </div>

    <form id="form-project" class="space-y-6" data-project-id={project.id}>
      <div id="form-error" class="hidden bg-red-500/10 border border-red-500/30 rounded-lg p-3 text-red-300 text-sm"></div>
      <div id="form-success" class="hidden bg-green-500/10 border border-green-500/30 rounded-lg p-3 text-green-300 text-sm">Proyecto actualizado</div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-white/70 mb-1">Nombre *</label>
          <input type="text" name="nombre" required value={project.nombre}
            class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-white placeholder-white/30 focus:border-cyan-500 focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-white/70 mb-1">Slug *</label>
          <input type="text" name="slug" required value={project.slug}
            class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-white placeholder-white/30 focus:border-cyan-500 focus:outline-none transition-colors" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-white/70 mb-1">URL del proyecto</label>
        <input type="url" name="url" value={project.url || ''} placeholder="https://ejemplo.com"
          class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-white placeholder-white/30 focus:border-cyan-500 focus:outline-none transition-colors" />
      </div>

      <div>
        <label class="block text-sm font-medium text-white/70 mb-1">Categoria *</label>
        <select name="categoria" required
          class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:border-cyan-500 focus:outline-none transition-colors">
          {categorias.map(c => (
            <option value={c.value} selected={c.value === project.categoria} class="bg-dark-900">{c.label}</option>
          ))}
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-white/70 mb-1">Descripcion</label>
        <textarea name="descripcion" rows="3"
          class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-white placeholder-white/30 focus:border-cyan-500 focus:outline-none transition-colors resize-none"
          placeholder="Breve descripcion del proyecto">{project.descripcion || ''}</textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-white/70 mb-1">Imagen (screenshot largo)</label>
        {project.imagen && (
          <div class="mb-3">
            <p class="text-xs text-white/40 mb-1">Imagen actual:</p>
            <img src={project.imagen} class="max-h-40 rounded-lg border border-white/10" />
          </div>
        )}
        <input type="file" name="imagen" accept="image/jpeg,image/png,image/webp"
          class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-white file:mr-4 file:py-1 file:px-3 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-cyan-500/20 file:text-cyan-300 hover:file:bg-cyan-500/30 transition-colors" />
        <p class="text-xs text-white/40 mt-1">Deja vacio para mantener la imagen actual. JPG, PNG o WebP. Max 5MB.</p>
        <div id="img-preview" class="mt-3 hidden">
          <img id="img-preview-src" class="max-h-40 rounded-lg border border-white/10" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-white/70 mb-1">Orden</label>
        <input type="number" name="orden" value={project.orden} min="0"
          class="w-24 bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:border-cyan-500 focus:outline-none transition-colors" />
      </div>

      <div class="flex gap-6">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="visible" value="1" checked={!!project.visible} class="accent-cyan-500 w-4 h-4" />
          <span class="text-sm text-white/70">Visible</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="featured" value="1" checked={!!project.featured} class="accent-amber-500 w-4 h-4" />
          <span class="text-sm text-white/70">Destacado</span>
        </label>
      </div>

      <div class="flex gap-3">
        <button type="submit" class="gradient-bg text-white font-semibold px-6 py-3 rounded-lg hover:opacity-90 transition-opacity cursor-pointer">
          Guardar Cambios
        </button>
        <button type="button" id="btn-delete" class="bg-red-500/10 border border-red-500/30 text-red-300 font-semibold px-6 py-3 rounded-lg hover:bg-red-500/20 transition-colors cursor-pointer">
          Eliminar
        </button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
function initEditarProyecto() {
  const form = document.getElementById('form-project') as HTMLFormElement;
  const errorDiv = document.getElementById('form-error') as HTMLDivElement;
  const successDiv = document.getElementById('form-success') as HTMLDivElement;
  const deleteBtn = document.getElementById('btn-delete') as HTMLButtonElement;
  const fileInput = form?.querySelector('input[name="imagen"]') as HTMLInputElement;
  const preview = document.getElementById('img-preview') as HTMLDivElement;
  const previewImg = document.getElementById('img-preview-src') as HTMLImageElement;

  if (!form) return;
  const projectId = form.dataset.projectId;

  // Image preview
  fileInput?.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file && preview && previewImg) {
      const reader = new FileReader();
      reader.onload = (e) => {
        previewImg.src = e.target?.result as string;
        preview.classList.remove('hidden');
      };
      reader.readAsDataURL(file);
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');
    successDiv.classList.add('hidden');

    const formData = new FormData(form);
    if (!formData.has('visible')) formData.set('visible', '0');
    else formData.set('visible', '1');
    if (!formData.has('featured')) formData.set('featured', '0');
    else formData.set('featured', '1');

    try {
      const res = await fetch(`/api/admin/projects/${projectId}`, { method: 'PATCH', body: formData });
      const data = await res.json();
      if (data.ok) {
        successDiv.classList.remove('hidden');
        setTimeout(() => successDiv.classList.add('hidden'), 3000);
      } else {
        errorDiv.textContent = data.error || 'Error al actualizar';
        errorDiv.classList.remove('hidden');
      }
    } catch {
      errorDiv.textContent = 'Error de conexion';
      errorDiv.classList.remove('hidden');
    }
  });

  deleteBtn?.addEventListener('click', async () => {
    if (!confirm('¿Seguro que quieres eliminar este proyecto? Esta accion no se puede deshacer.')) return;
    const res = await fetch(`/api/admin/projects/${projectId}`, { method: 'DELETE' });
    if (res.ok) window.location.href = '/admin/proyectos';
  });
}
initEditarProyecto();
document.addEventListener('astro:page-load', initEditarProyecto);
</script>
