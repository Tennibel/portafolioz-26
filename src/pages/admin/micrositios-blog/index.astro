---
/**
 * /admin/micrositios-blog - Listado de posts del blog de los micrositios
 *
 * Filtros: dominio, estado (publicado / borrador)
 * Acciones: nuevo post, editar, eliminar
 */
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { isAuthenticated } from '../../../lib/auth';
import { getMicrositePostsAdmin, getMicrositePostStats } from '../../../lib/db';
import { MICROSITIOS, getMicrositeByDomain } from '../../../lib/micrositios';

if (!isAuthenticated(Astro.request)) {
  return Astro.redirect('/admin/');
}

const domainFilter = Astro.url.searchParams.get('domain') || 'todos';
const statusFilter = Astro.url.searchParams.get('status') || 'todos';
const page = parseInt(Astro.url.searchParams.get('page') || '1');

const publishedFilter = statusFilter === 'publicado' ? 1 : statusFilter === 'borrador' ? 0 : undefined;

const { posts, total } = getMicrositePostsAdmin({
  domain: domainFilter === 'todos' ? undefined : domainFilter,
  published: publishedFilter,
  page,
  perPage: 20,
});
const stats = getMicrositePostStats();
const totalPages = Math.ceil(total / 20);

function formatDate(d: string): string {
  return new Date(d.endsWith('Z') ? d : d + 'Z').toLocaleDateString('es-MX', {
    day: '2-digit', month: 'short', year: 'numeric',
  });
}
---

<AdminLayout title="Blog Micrositios">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Blog Micrositios</h1>
      <p class="text-sm text-white/50 mt-1">Administra el contenido de blog de los 14 dominios del ecosistema</p>
    </div>
    <a href="/admin/micrositios-blog/nuevo" class="bg-gradient-to-r from-cyan-500 to-purple-500 text-white font-semibold px-5 py-2 rounded-lg text-sm hover:opacity-90 transition-opacity">
      + Nuevo Post
    </a>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white/5 border border-white/10 rounded-xl p-4">
      <div class="text-xs text-white/50 uppercase tracking-wider">Total posts</div>
      <div class="text-3xl font-bold text-white mt-1">{stats.total}</div>
    </div>
    <div class="bg-green-500/10 border border-green-500/20 rounded-xl p-4">
      <div class="text-xs text-green-400 uppercase tracking-wider">Publicados</div>
      <div class="text-3xl font-bold text-green-400 mt-1">{stats.publicados}</div>
    </div>
    <div class="bg-amber-500/10 border border-amber-500/20 rounded-xl p-4">
      <div class="text-xs text-amber-400 uppercase tracking-wider">Borradores</div>
      <div class="text-3xl font-bold text-amber-400 mt-1">{stats.borradores}</div>
    </div>
    <div class="bg-cyan-500/10 border border-cyan-500/20 rounded-xl p-4">
      <div class="text-xs text-cyan-400 uppercase tracking-wider">Dominios activos</div>
      <div class="text-3xl font-bold text-cyan-400 mt-1">{stats.porDominio.length}</div>
    </div>
  </div>

  <!-- Filtros -->
  <form method="get" class="flex flex-wrap gap-3 mb-6 items-end">
    <div>
      <label class="block text-xs text-white/50 mb-1">Dominio</label>
      <select name="domain" class="bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-sm text-white min-w-[220px]">
        <option value="todos" selected={domainFilter === 'todos'}>Todos los dominios</option>
        {MICROSITIOS.map((m) => (
          <option value={m.domain} selected={domainFilter === m.domain}>
            {m.name} ({m.domain})
          </option>
        ))}
      </select>
    </div>
    <div>
      <label class="block text-xs text-white/50 mb-1">Estado</label>
      <select name="status" class="bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-sm text-white">
        <option value="todos" selected={statusFilter === 'todos'}>Todos</option>
        <option value="publicado" selected={statusFilter === 'publicado'}>Publicados</option>
        <option value="borrador" selected={statusFilter === 'borrador'}>Borradores</option>
      </select>
    </div>
    <button type="submit" class="bg-white/10 hover:bg-white/15 border border-white/15 text-white px-4 py-2 rounded-lg text-sm transition-colors">
      Filtrar
    </button>
  </form>

  <!-- Tabla -->
  {posts.length === 0 ? (
    <div class="bg-white/5 border border-white/10 rounded-xl p-12 text-center">
      <p class="text-white/50">No hay posts que coincidan con los filtros.</p>
      <a href="/admin/micrositios-blog/nuevo" class="inline-block mt-4 text-cyan-400 hover:text-cyan-300 text-sm">
        Crear el primero →
      </a>
    </div>
  ) : (
    <div class="bg-white/5 border border-white/10 rounded-xl overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-white/5 border-b border-white/10">
          <tr class="text-left">
            <th class="p-3 font-semibold text-white/70">Post</th>
            <th class="p-3 font-semibold text-white/70">Dominio</th>
            <th class="p-3 font-semibold text-white/70">Estado</th>
            <th class="p-3 font-semibold text-white/70">Views</th>
            <th class="p-3 font-semibold text-white/70">Fecha</th>
            <th class="p-3 font-semibold text-white/70 w-24"></th>
          </tr>
        </thead>
        <tbody>
          {posts.map((post) => {
            const m = getMicrositeByDomain(post.domain);
            return (
              <tr class="border-b border-white/5 hover:bg-white/3 transition-colors">
                <td class="p-3">
                  <div class="flex items-center gap-3">
                    {post.cover_image ? (
                      <img src={post.cover_image} alt="" class="w-12 h-12 rounded-lg object-cover bg-white/5" loading="lazy" />
                    ) : (
                      <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center text-white/30 text-lg">📝</div>
                    )}
                    <div class="min-w-0">
                      <div class="font-medium text-white truncate max-w-[280px]">{post.title}</div>
                      <div class="text-xs text-white/40 truncate max-w-[280px]">/{post.slug}</div>
                    </div>
                  </div>
                </td>
                <td class="p-3 text-white/70 text-xs">{m?.name || post.domain}</td>
                <td class="p-3">
                  {post.published === 1 ? (
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-green-500/15 text-green-400 text-xs font-semibold">
                      <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
                      Publicado
                    </span>
                  ) : (
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-500/15 text-amber-400 text-xs font-semibold">
                      <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                      Borrador
                    </span>
                  )}
                  {post.featured === 1 && (
                    <span class="ml-1 inline-block px-2 py-0.5 rounded-full bg-pink-500/15 text-pink-400 text-xs font-semibold">★ Destacado</span>
                  )}
                </td>
                <td class="p-3 text-white/60 text-xs">{post.views}</td>
                <td class="p-3 text-white/60 text-xs">{formatDate(post.created_at)}</td>
                <td class="p-3 text-right">
                  <a href={`/admin/micrositios-blog/${post.id}`} class="text-cyan-400 hover:text-cyan-300 text-xs font-medium">
                    Editar
                  </a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}

  <!-- Paginacion -->
  {totalPages > 1 && (
    <div class="flex justify-center gap-2 mt-6">
      {Array.from({ length: totalPages }).map((_, i) => {
        const p = i + 1;
        const qs = new URLSearchParams(Astro.url.searchParams);
        qs.set('page', String(p));
        return (
          <a
            href={`?${qs.toString()}`}
            class={`px-3 py-1.5 rounded-lg text-sm ${p === page ? 'bg-cyan-500 text-white' : 'bg-white/5 text-white/60 hover:bg-white/10'}`}
          >
            {p}
          </a>
        );
      })}
    </div>
  )}

  <!-- Breakdown por dominio -->
  {stats.porDominio.length > 0 && (
    <div class="mt-10">
      <h2 class="text-sm font-semibold text-white/70 uppercase tracking-wider mb-3">Posts por dominio</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2">
        {stats.porDominio.map((d) => {
          const m = getMicrositeByDomain(d.domain);
          return (
            <a href={`?domain=${d.domain}`} class="bg-white/5 border border-white/10 rounded-lg p-3 hover:bg-white/10 transition-colors">
              <div class="text-xs text-white/40 truncate">{d.domain}</div>
              <div class="text-sm font-semibold text-white mt-0.5">{m?.name || d.domain}</div>
              <div class="flex gap-3 mt-1.5 text-xs">
                <span class="text-green-400">{d.publicados} pub</span>
                <span class="text-amber-400">{d.total - d.publicados} borr</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  )}
</AdminLayout>
