---
/**
 * /admin/cotizaciones - Lista de cotizaciones
 */
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { isAuthenticated } from '../../lib/auth';
import { getQuotes, getQuoteStats } from '../../lib/db';

if (!isAuthenticated(Astro.request)) {
  return Astro.redirect('/admin/');
}

const status = Astro.url.searchParams.get('status') || 'todas';
const page = parseInt(Astro.url.searchParams.get('page') || '1');
const { quotes, total } = getQuotes(status, page);
const stats = getQuoteStats();
const totalPages = Math.ceil(total / 20);

const statusColors: Record<string, string> = {
  nueva: 'bg-cyan-500/20 text-cyan-300',
  contactada: 'bg-amber-500/20 text-amber-300',
  cerrada: 'bg-green-500/20 text-green-300',
  descartada: 'bg-red-500/20 text-red-300',
};

function formatMXN(n: number): string {
  return '$' + n.toLocaleString('es-MX');
}

function formatDate(d: string): string {
  return new Date(d + 'Z').toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: 'numeric' });
}
---

<AdminLayout title="Cotizaciones">
  <!-- Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-8">
    {[
      { label: 'Total', value: stats.total, color: 'bg-white/5' },
      { label: 'Nuevas', value: stats.nueva, color: 'bg-cyan-500/10 border-cyan-500/20' },
      { label: 'Contactadas', value: stats.contactada, color: 'bg-amber-500/10 border-amber-500/20' },
      { label: 'Cerradas', value: stats.cerrada, color: 'bg-green-500/10 border-green-500/20' },
      { label: 'Descartadas', value: stats.descartada, color: 'bg-red-500/10 border-red-500/20' },
    ].map(s => (
      <div class={`${s.color} border border-white/10 rounded-xl p-4 text-center`}>
        <div class="text-2xl font-bold text-white">{s.value}</div>
        <div class="text-xs text-white/50">{s.label}</div>
      </div>
    ))}
  </div>

  <!-- Filter tabs -->
  <div class="flex gap-2 mb-6 overflow-x-auto pb-2">
    {['todas', 'nueva', 'contactada', 'cerrada', 'descartada'].map(s => (
      <a href={`/admin/cotizaciones?status=${s}`}
        class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap ${status === s ? 'gradient-bg text-white' : 'bg-white/5 text-white/60 hover:bg-white/10'}`}>
        {s.charAt(0).toUpperCase() + s.slice(1)}
      </a>
    ))}
  </div>

  <!-- Table -->
  {quotes.length === 0 ? (
    <div class="bg-white/5 border border-white/10 rounded-xl p-12 text-center">
      <p class="text-white/40">No hay cotizaciones {status !== 'todas' ? `con status "${status}"` : ''}</p>
    </div>
  ) : (
    <div class="bg-white/5 border border-white/10 rounded-xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-white/10">
              <th class="text-left text-xs font-medium text-white/50 px-4 py-3">ID</th>
              <th class="text-left text-xs font-medium text-white/50 px-4 py-3">Fecha</th>
              <th class="text-left text-xs font-medium text-white/50 px-4 py-3">Nombre</th>
              <th class="text-left text-xs font-medium text-white/50 px-4 py-3">Email</th>
              <th class="text-left text-xs font-medium text-white/50 px-4 py-3">Tipo</th>
              <th class="text-right text-xs font-medium text-white/50 px-4 py-3">Total</th>
              <th class="text-center text-xs font-medium text-white/50 px-4 py-3">Status</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {quotes.map(q => (
              <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
                <td class="px-4 py-3 text-sm text-white/40">#{q.id}</td>
                <td class="px-4 py-3 text-sm text-white/60">{formatDate(q.created_at)}</td>
                <td class="px-4 py-3 text-sm text-white font-medium">{q.nombre}</td>
                <td class="px-4 py-3 text-sm text-white/60">{q.email}</td>
                <td class="px-4 py-3 text-sm text-white/60 capitalize">{q.tipo_sitio}</td>
                <td class="px-4 py-3 text-sm text-white font-semibold text-right">{formatMXN(q.total)}</td>
                <td class="px-4 py-3 text-center">
                  <span class={`inline-block px-2 py-1 rounded-md text-xs font-medium ${statusColors[q.status] || 'bg-white/10 text-white/50'}`}>
                    {q.status}
                  </span>
                </td>
                <td class="px-4 py-3">
                  <a href={`/admin/cotizaciones/${q.id}`} class="text-cyan-400 hover:text-cyan-300 text-sm font-medium transition-colors">
                    Ver &rarr;
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <!-- Pagination -->
  {totalPages > 1 && (
    <div class="flex justify-center gap-2 mt-6">
      {page > 1 && (
        <a href={`/admin/cotizaciones?status=${status}&page=${page - 1}`}
          class="px-4 py-2 rounded-lg bg-white/5 text-white/60 hover:bg-white/10 text-sm">&larr; Anterior</a>
      )}
      <span class="px-4 py-2 text-white/40 text-sm">Pagina {page} de {totalPages}</span>
      {page < totalPages && (
        <a href={`/admin/cotizaciones?status=${status}&page=${page + 1}`}
          class="px-4 py-2 rounded-lg bg-white/5 text-white/60 hover:bg-white/10 text-sm">Siguiente &rarr;</a>
      )}
    </div>
  )}
</AdminLayout>
