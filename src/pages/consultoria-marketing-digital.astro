---
/**
 * consultoria-marketing-digital.astro - Consultoria Digital 30 Minutos
 *
 * Pagina de consultoria gratuita de marketing digital.
 * Se enlaza desde CTAs del sitio.
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';

const benefits = [
  { icon: '🎯', title: 'Servicio Personalizado', desc: 'Ofrecemos un servicio personalizado para cada cliente, automatizaciones y las tecnologias mas actuales del mercado.' },
  { icon: '📈', title: 'Mas Clientes y Ventas', desc: 'Consigue mas clientes y mas ventas por medio de diferentes estrategias de Marketing Digital.' },
  { icon: '🏆', title: 'Expertos desde 2013', desc: 'Desde el 2013 somos expertos en el desarrollo web y desarrollo de marcas con autoridad en Internet.' },
  { icon: '✅', title: 'Casos de Exito', desc: 'Aumenta tus ventas y tu clientes con nuestros servicios, contamos con casos de exito comprobables.' },
];

const steps = [
  { num: '01', title: 'Agenda tu Cita', desc: 'Selecciona una fecha y hora disponible en nuestro calendario. Es rapido y sin compromiso.' },
  { num: '02', title: 'Reunion de 30 min', desc: 'Nos reunimos por videollamada para conocer tu negocio, objetivos y retos actuales.' },
  { num: '03', title: 'Plan de Accion', desc: 'Te entregamos recomendaciones claras y un plan estrategico para generar mas clientes y ventas.' },
];
---

<Layout title="Consultoria Digital 30 Minutos | Portafolio Z - Asesoria Gratuita" description="Consultoria de Marketing Digital SIN COSTO de 30 minutos para tu negocio. Revisamos la estrategia ganadora para llegar a mas prospectos y generar mas ventas.">
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-32 pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-dark-900 via-purple-950/60 to-dark-900"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(168,85,247,0.15),transparent_60%)]"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-pink-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-purple-500/20 border border-purple-500/30 rounded-full px-5 py-2 mb-8" data-animate>
            <span class="w-2 h-2 rounded-full bg-pink-400 animate-pulse"></span>
            <span class="text-sm font-semibold text-purple-300 tracking-wider uppercase">Consultoria Gratuita</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6" data-animate>
            Consultoria Digital
            <br><span class="bg-gradient-to-r from-pink-400 via-purple-400 to-indigo-400 bg-clip-text text-transparent">30 Minutos</span>
          </h1>

          <p class="text-xl text-white/70 mb-8" data-animate>
            Consultoria de Marketing Digital <strong class="text-pink-300">SIN COSTO</strong> de 30 minutos para tu negocio. Revisaremos cual es la estrategia ganadora para llegar a mas prospectos y generar mas ventas.
          </p>

          <div class="flex flex-col sm:flex-row gap-4" data-animate>
            <a href="https://wa.me/5215647215472?text=Hola%2C%20me%20interesa%20la%20consultoria%20gratuita%20de%20marketing%20digital" target="_blank" rel="noopener" class="wa-lead bg-gradient-to-r from-pink-500 to-purple-500 text-white font-bold px-8 py-4 rounded-full text-lg hover:from-pink-600 hover:to-purple-600 transition-all hover:scale-105 shadow-xl shadow-pink-500/20 text-center" data-plan="Consultoría Gratuita" data-price="0" data-category="Consultoría Marketing Digital">
              Agendar Consultoria
            </a>
            <a href="https://wa.me/5215647215472?text=Hola%2C%20me%20interesa%20una%20*Consultor%C3%ADa%20de%20Marketing%20Digital*.%20%C2%BFMe%20pueden%20asesorar%3F" target="_blank" rel="noopener" class="wa-lead border-2 border-white/20 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all text-center" data-plan="Contacto Consultoría" data-price="0" data-category="Consultoría Marketing Digital">
              Contacto
            </a>
          </div>
        </div>

        <!-- Right: highlights -->
        <div class="space-y-4" data-animate>
          {benefits.map((b) => (
            <div class="bg-white/5 border border-white/10 rounded-2xl p-5 hover:bg-white/10 transition-all flex items-start gap-4">
              <span class="text-3xl">{b.icon}</span>
              <div>
                <h3 class="text-white font-bold mb-1">{b.title}</h3>
                <p class="text-white/60 text-sm leading-relaxed">{b.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Value prop -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center" data-animate>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">En esta <span class="bg-gradient-to-r from-pink-500 to-purple-500 bg-clip-text text-transparent">Asesoria Personalizada</span></h2>
        <p class="text-lg text-gray-600 leading-relaxed mb-8">
          Revisaremos cual es la estrategia ganadora para tu negocio, llegar a mas prospectos y generar mas ventas. Genera mas clientes y mas ventas con nuestra Asesoria de Marketing personalizada.
        </p>
        <p class="text-gray-600 leading-relaxed">
          Si ya sabes lo que quieres y aun no sabes como obtenerlo, entonces necesitas nuestros servicios. Una asesoria de marketing personalizada es el mejor camino para crear un plan ganador para tu negocio.
        </p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-dark-900 via-purple-950/60 to-dark-900"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">Como <span class="text-pink-400">funciona</span></h2>
        <p class="text-white/60 mt-4">3 pasos simples para transformar tu negocio</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {steps.map((s) => (
          <div class="text-center" data-animate>
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gradient-to-r from-pink-500 to-purple-500 text-white text-xl font-bold mb-6">{s.num}</div>
            <h3 class="text-lg font-bold text-white mb-3">{s.title}</h3>
            <p class="text-white/60 text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">¿Por qué elegir <span class="bg-gradient-to-r from-pink-500 to-purple-500 bg-clip-text text-transparent">Portafolio Z</span>?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {[
          'Estrategia personalizada para tu negocio',
          'Mas de 10 anos de experiencia en marketing digital',
          'Resultados medibles y comprobables',
          'Sin compromiso ni costo oculto',
          'Expertos en SEO, redes sociales y publicidad',
          'Acompanamiento durante todo el proceso',
        ].map((f) => (
          <div class="flex items-center gap-3 p-4 rounded-xl bg-gray-50" data-animate>
            <svg class="w-6 h-6 text-purple-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-gray-700 font-medium">{f}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-pink-600 via-purple-600 to-indigo-600"></div>
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4" data-animate>Agenda tu consultoria gratuita hoy</h2>
      <p class="text-white/80 text-lg mb-8" data-animate>30 minutos que pueden transformar tu negocio. Sin costo, sin compromiso. Detectamos oportunidades rapidas y te damos un plan claro.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate>
        <a href="https://wa.me/5215647215472?text=Hola%2C%20quiero%20agendar%20mi%20consultoria%20gratuita%20de%20marketing%20digital" target="_blank" rel="noopener" class="wa-lead bg-white text-purple-600 font-bold px-8 py-4 rounded-full text-lg hover:bg-white/90 transition-all hover:scale-105 shadow-xl" data-plan="Agendar WhatsApp" data-price="0" data-category="Consultoría Marketing Digital">
          Agendar por WhatsApp
        </a>
        <a href="https://wa.me/5215647215472?text=Hola%2C%20me%20interesa%20una%20*Consultor%C3%ADa%20de%20Marketing%20Digital*.%20%C2%BFMe%20pueden%20asesorar%3F" target="_blank" rel="noopener" class="wa-lead border-2 border-white text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-all" data-plan="Formulario Contacto" data-price="0" data-category="Consultoría Marketing Digital">
          Formulario de Contacto
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppWidget />

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.wa-lead').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        if (typeof gtag === 'function') {
          gtag('event', 'generate_lead', {
            event_category: 'WhatsApp',
            plan_name: el.dataset.plan || '',
            plan_price: el.dataset.price || '',
            category: el.dataset.category || '',
            source_page: 'consultoria-marketing-digital',
          });
        }
      });
    });
  });
</script>
</Layout>
