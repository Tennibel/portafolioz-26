---
/**
 * servicios.astro - Pagina completa de Servicios Web
 *
 * Secciones:
 * 1. Hero interno - Banner con breadcrumb
 * 2. Servicios principales - 6 servicios con cards expandibles
 * 3. Planes de hosting - 4 opciones de hosting
 * 4. Tipos de sitio web - 4 planes de diseño (reutilizando precios reales)
 * 5. Integraciones - Modulos adicionales con precios
 * 6. Cuentas de correo - 4 opciones
 * 7. Extras - Complementos adicionales
 * 8. Caracteristicas incluidas - Lo que diferencia a PZ
 * 9. CTA final
 *
 * Toda la info es real de portafolioz.com/servicios-web/
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';

// 6 servicios principales
const services = [
  {
    title: 'Diseño y Desarrollo Web',
    desc: 'Desarrollamos el sitio web de tus sueños. Nos adaptamos 100% a los requerimientos de cada proyecto para crear experiencias únicas.',
    icon: '🎨',
    gradient: 'from-cyan-500 to-primary-500',
  },
  {
    title: 'Creación de Marca',
    desc: 'Te asesoramos con la identidad de tu marca para lograr un impacto visual y eficiente en la web. Logo, paleta de colores y más.',
    icon: '✨',
    gradient: 'from-primary-500 to-accent-500',
  },
  {
    title: 'Posicionamiento SEO',
    desc: 'SEO básico incluido en todos nuestros planes. También contamos con servicios avanzados para posicionarte en Google.',
    icon: '🔍',
    gradient: 'from-accent-500 to-pink-500',
  },
  {
    title: 'Google & Facebook ADS',
    desc: 'Campañas de anuncios en Google Ads y Facebook Ads para atraer tráfico cualificado y aumentar tus conversiones.',
    icon: '📊',
    gradient: 'from-pink-500 to-coral-500',
  },
  {
    title: 'Social Media Marketing',
    desc: 'Gestión de redes sociales para construir tu comunidad y generar engagement con tu audiencia objetivo.',
    icon: '📱',
    gradient: 'from-coral-500 to-amber-500',
  },
  {
    title: 'Administrador de Contenidos',
    desc: 'Sistemas CMS para que puedas actualizar tu sitio fácilmente. WordPress, Shopify o soluciones a medida.',
    icon: '💻',
    gradient: 'from-amber-500 to-cyan-500',
  },
];

// Planes de hosting
const hostingPlans = [
  { name: 'Ya tengo hosting', price: '$0', desc: 'Usa tu propio dominio y hosting', popular: false },
  { name: 'Dominio + 5GB', price: '$650', desc: 'Dominio .com + Hosting 5GB', popular: false },
  { name: 'Dominio + 10GB', price: '$890', desc: 'Dominio .com + Hosting 10GB', popular: true },
  { name: 'Dominio + 15GB', price: '$1,290', desc: 'Dominio .com + Hosting 15GB', popular: false },
];

// Planes de diseño web
const webPlans = [
  { name: 'Landing Page', price: '$5,600', sections: '1-3 secciones', features: ['Diseño responsivo', '1-3 secciones', 'Formulario de contacto', 'SEO básico', 'Certificado SSL'], popular: false },
  { name: 'Sitio Básico', price: '$6,400', sections: '2-4 secciones', features: ['2-4 secciones', 'Diseño personalizado', 'SEO básico', 'Certificado SSL', 'Banco de imágenes'], popular: true },
  { name: 'Sitio Profesional', price: '$7,300', sections: '5-8 secciones', features: ['5-8 secciones', 'Diseño premium', 'Blog integrado', 'SEO avanzado', 'Banco de imágenes', 'Soporte 6 meses'], popular: false },
  { name: 'Sitio Empresarial', price: '$8,900', sections: '9-12 secciones', features: ['9-12 secciones', 'Diseño a medida', 'Blog + CRM', 'SEO avanzado', 'Banco de imágenes', 'Soporte 12 meses'], popular: false },
];

// Integraciones con precios
const integrations = [
  { name: 'Blog', price: '$390', icon: '📝' },
  { name: 'Catálogo de Productos', price: '$2,900', icon: '📦' },
  { name: 'Sistema de Entregas', price: '$3,800', icon: '🚚' },
  { name: 'Tienda Online', price: '$3,800', icon: '🛒', popular: true },
  { name: 'Sistema de Citas', price: '$3,200', icon: '📅' },
  { name: 'Cotizador', price: '$1,200', icon: '🧮' },
  { name: 'CRM', price: '$1,200', icon: '👥' },
];

// Cuentas de correo
const emailPlans = [
  { name: 'Sin correos', price: '$0', popular: false },
  { name: '2 cuentas', price: '$220', popular: true },
  { name: '6 cuentas', price: '$320', popular: false },
  { name: 'Ilimitado', price: '$900', popular: false },
];

// Extras
const extras = [
  { name: 'Botón WhatsApp', price: '$500', icon: '💬', popular: true },
  { name: 'Chatbot', price: '$4,200', icon: '🤖' },
  { name: 'Localizador de Tiendas', price: '$900', icon: '📍' },
  { name: 'Lector PDF', price: '$350', icon: '📄' },
];

// Diferenciadores
const differentiators = [
  { title: '+10 años de experiencia', desc: 'Más de una década creando sitios web que generan resultados reales.', icon: '🏆' },
  { title: 'Soporte 24/7', desc: 'Estamos disponibles para resolver cualquier problema técnico en tu sitio.', icon: '🛟' },
  { title: 'Redacción de contenidos', desc: 'Te ayudamos con los textos de tu sitio para que comuniquen de forma efectiva.', icon: '✍️' },
  { title: 'Mejor relación calidad-precio', desc: 'Ofrecemos precios accesibles sin sacrificar la calidad del diseño y desarrollo.', icon: '💎' },
];
---

<Layout title="Servicios Web" description="Servicios de diseño web, SEO, branding, hosting y más. Conoce nuestros planes y precios.">
  <Navbar />

  <!-- ================================================
       SECCION 1: Hero interno
       ================================================ -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-600 via-accent-600 to-pink-600"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="absolute top-10 left-20 w-80 h-80 bg-cyan-400/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-10 w-64 h-64 bg-amber-400/20 rounded-full blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <nav class="flex justify-center gap-2 text-sm text-white/60 mb-6" data-animate>
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-white">Servicios</span>
      </nav>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white mb-4" data-animate>
        Nuestros <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 to-amber-300">Servicios Web</span>
      </h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto" data-animate>
        Ayudamos a proyectos y marcas a conseguir ventas online a través de sitios web optimizados y servicios especializados en prospección.
      </p>
    </div>
  </section>

  <!-- ================================================
       SECCION 2: Servicios principales - 6 cards
       ================================================ -->
  <section class="bg-dark-900 py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-cyan-400 font-medium text-sm uppercase tracking-widest mb-3">Lo que hacemos</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          Servicios especializados en <span class="gradient-text">prospección y ventas</span>
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-animate>
        {services.map((s) => (
          <div class="group relative glass-card p-8 hover:scale-[1.03] hover:-translate-y-2 transition-all duration-500 cursor-pointer overflow-hidden">
            <div class={`absolute inset-0 bg-gradient-to-br ${s.gradient} opacity-0 group-hover:opacity-15 transition-opacity duration-500 rounded-2xl`}></div>
            <div class="relative z-10">
              <span class="text-4xl mb-4 block group-hover:scale-110 transition-transform">{s.icon}</span>
              <h3 class="text-xl font-bold text-white mb-3">{s.title}</h3>
              <p class="text-white/50 text-sm leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================================================
       SECCION 3: Planes de hosting
       ================================================ -->
  <section class="bg-white py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-accent-600 font-medium text-sm uppercase tracking-widest mb-3">Hosting y Dominio</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
          Elige tu plan de <span class="gradient-text">hospedaje</span>
        </h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6" data-animate>
        {hostingPlans.map((plan) => (
          <div class={`relative rounded-2xl p-6 text-center transition-all duration-300 hover:-translate-y-2 ${plan.popular ? 'bg-gradient-to-br from-primary-600 via-accent-600 to-pink-600 text-white ring-2 ring-accent-400 shadow-2xl scale-105' : 'bg-gray-50 text-gray-900 border border-gray-200'}`}>
            {plan.popular && (<div class="absolute -top-3 left-1/2 -translate-x-1/2"><span class="bg-cyan-400 text-dark-900 text-xs font-bold px-3 py-1 rounded-full">Popular</span></div>)}
            <p class={`text-sm mb-2 ${plan.popular ? 'text-white/60' : 'text-gray-500'}`}>{plan.desc}</p>
            <p class="text-3xl font-extrabold mb-1">{plan.price}</p>
            <p class={`text-xs ${plan.popular ? 'text-white/50' : 'text-gray-400'}`}>MXN / anual</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================================================
       SECCION 4: Planes de diseno web
       ================================================ -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-cyan-500 via-primary-500 to-accent-600"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-cyan-200 font-medium text-sm uppercase tracking-widest mb-3">Diseño Web</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          Elige el tipo de <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 to-white">sitio web</span>
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6" data-animate>
        {webPlans.map((plan) => (
          <div class={`relative rounded-2xl p-7 transition-all duration-300 hover:-translate-y-2 ${plan.popular ? 'bg-white text-gray-900 ring-2 ring-cyan-400 shadow-2xl scale-105' : 'glass-card text-white'}`}>
            {plan.popular && (<div class="absolute -top-4 left-1/2 -translate-x-1/2"><span class="bg-cyan-400 text-dark-900 text-xs font-bold px-4 py-1.5 rounded-full">Más Popular</span></div>)}
            <h3 class={`text-lg font-bold mb-1 ${plan.popular ? 'text-gray-900' : ''}`}>{plan.name}</h3>
            <p class={`text-xs mb-4 ${plan.popular ? 'text-gray-500' : 'text-white/60'}`}>{plan.sections}</p>
            <div class="mb-6">
              <span class="text-3xl font-extrabold">{plan.price}</span>
              <span class={`text-xs ml-1 ${plan.popular ? 'text-gray-400' : 'text-white/50'}`}>MXN</span>
            </div>
            <ul class="space-y-2 mb-6">
              {plan.features.map((f) => (
                <li class="flex items-center gap-2 text-sm">
                  <svg class={`w-4 h-4 flex-shrink-0 ${plan.popular ? 'text-accent-500' : 'text-cyan-300'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <span class={plan.popular ? 'text-gray-600' : 'text-white/70'}>{f}</span>
                </li>
              ))}
            </ul>
            <a href="/contacto" class={`block text-center font-semibold py-3 px-5 rounded-full transition-all text-sm ${plan.popular ? 'gradient-bg text-white hover:opacity-90' : 'border-2 border-white/30 text-white hover:bg-white/10'}`}>¡Quiero mi Web!</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================================================
       SECCION 5: Integraciones
       ================================================ -->
  <section class="bg-white py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-accent-600 font-medium text-sm uppercase tracking-widest mb-3">Integraciones</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
          Módulos adicionales para <span class="gradient-text">tu sitio</span>
        </h2>
        <p class="text-gray-500 mt-4 max-w-2xl mx-auto">Potencia tu sitio web con funcionalidades avanzadas. Cada módulo se integra perfectamente con tu diseño.</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5" data-animate>
        {integrations.map((item) => (
          <div class={`relative rounded-2xl p-6 text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-lg ${item.popular ? 'bg-gradient-to-br from-primary-600 to-accent-600 text-white ring-2 ring-accent-400' : 'bg-gray-50 border border-gray-200'}`}>
            {item.popular && (<div class="absolute -top-3 left-1/2 -translate-x-1/2"><span class="bg-cyan-400 text-dark-900 text-xs font-bold px-3 py-1 rounded-full">Popular</span></div>)}
            <span class="text-3xl mb-3 block">{item.icon}</span>
            <h3 class={`text-sm font-bold mb-2 ${item.popular ? '' : 'text-gray-900'}`}>{item.name}</h3>
            <p class={`text-xl font-extrabold ${item.popular ? '' : 'text-gray-900'}`}>{item.price}</p>
            <p class={`text-xs mt-1 ${item.popular ? 'text-white/50' : 'text-gray-400'}`}>MXN</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================================================
       SECCION 6: Correo + Extras en 2 columnas
       ================================================ -->
  <section class="bg-dark-900 py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">
        <!-- Cuentas de correo -->
        <div data-animate>
          <p class="text-cyan-400 font-medium text-sm uppercase tracking-widest mb-3">Cuentas de Correo</p>
          <h3 class="text-2xl font-bold text-white mb-8">Email corporativo con tu <span class="gradient-text">dominio</span></h3>
          <div class="grid grid-cols-2 gap-4">
            {emailPlans.map((plan) => (
              <div class={`rounded-xl p-5 text-center transition-all duration-300 hover:-translate-y-1 ${plan.popular ? 'bg-gradient-to-br from-primary-600 to-accent-600 ring-1 ring-accent-400' : 'glass-card'}`}>
                {plan.popular && (<span class="inline-block bg-cyan-400 text-dark-900 text-xs font-bold px-2 py-0.5 rounded-full mb-2">Popular</span>)}
                <p class="text-white text-sm font-medium mb-1">{plan.name}</p>
                <p class="text-2xl font-extrabold text-white">{plan.price}</p>
                <p class="text-white/50 text-xs mt-1">MXN / anual</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Extras -->
        <div data-animate>
          <p class="text-pink-400 font-medium text-sm uppercase tracking-widest mb-3">Extras</p>
          <h3 class="text-2xl font-bold text-white mb-8">Complementos para <span class="gradient-text">tu web</span></h3>
          <div class="grid grid-cols-2 gap-4">
            {extras.map((item) => (
              <div class={`rounded-xl p-5 text-center transition-all duration-300 hover:-translate-y-1 ${item.popular ? 'bg-gradient-to-br from-pink-600 to-coral-500 ring-1 ring-pink-400' : 'glass-card'}`}>
                {item.popular && (<span class="inline-block bg-cyan-400 text-dark-900 text-xs font-bold px-2 py-0.5 rounded-full mb-2">Popular</span>)}
                <span class="text-2xl mb-2 block">{item.icon}</span>
                <p class="text-white text-sm font-medium mb-1">{item.name}</p>
                <p class="text-xl font-extrabold text-white">{item.price}</p>
                <p class="text-white/50 text-xs mt-1">MXN</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       SECCION 7: Diferenciadores
       ================================================ -->
  <section class="bg-white py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-accent-600 font-medium text-sm uppercase tracking-widest mb-3">¿Por qué elegirnos?</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
          Lo que nos hace <span class="gradient-text">diferentes</span>
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6" data-animate>
        {differentiators.map((d) => (
          <div class="bg-gray-50 rounded-2xl p-8 text-center hover:-translate-y-2 hover:shadow-lg transition-all duration-300 group">
            <span class="text-4xl mb-4 block group-hover:scale-110 transition-transform">{d.icon}</span>
            <h3 class="text-base font-bold text-gray-900 mb-2">{d.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================================================
       SECCION 8: CTA
       ================================================ -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-coral-500 via-coral-600 to-amber-500"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-animate>
      <div class="glass-card-light p-12 md:p-16">
        <h2 class="text-3xl md:text-4xl font-bold text-dark-900 mb-4">
          ¿Listo para <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-accent-600">vender más?</span>
        </h2>
        <p class="text-dark-700/70 text-lg mb-10 max-w-2xl mx-auto">
          Desarrollamos sitios que incrementan tráfico y posicionamiento para prospectar clientes y concretar ventas.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contacto" class="gradient-bg text-white font-semibold px-8 py-4 rounded-full text-lg hover:opacity-90 transition-all hover:scale-105">
            Solicitar Cotización
          </a>
          <a href="https://wa.me/5215561959724" target="_blank" rel="noopener" class="bg-dark-900 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-dark-800 transition-all">
            Hablar por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppWidget />
</Layout>
