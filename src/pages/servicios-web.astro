              </div>

              <!-- Badge -->
              <span class={`inline-flex items-center gap-1.5 ${s.badgeColor} text-xs font-bold px-3 py-1.5 rounded-full border mb-5`}>
                {s.badge}
              </span>

              <!-- Title -->
              <h3 class="text-xl font-bold text-white mb-3 group-hover:text-white/90">{s.title}</h3>

              <!-- Description -->
              <p class="text-gray-400 mb-6 leading-relaxed text-sm">{s.desc}</p>

              <!-- CTA Link -->
              <a href={s.link} class={`inline-flex items-center gap-2 font-semibold bg-gradient-to-r ${s.gradient} bg-clip-text text-transparent group-hover:gap-3 transition-all text-sm`}>
