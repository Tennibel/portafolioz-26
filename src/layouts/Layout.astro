---
/**
 * Layout.astro - Layout base del sitio Portafolio Z
 *
 * Responsabilidades:
 * - Carga la fuente Poppins desde Google Fonts (preconnect para performance)
 * - Inyecta meta tags globales (charset, viewport, description, Open Graph)
 * - View Transitions API para navegacion suave entre paginas
 * - Inicializa el IntersectionObserver para animaciones de scroll
 * - Importa los estilos globales (Tailwind + custom tokens)
 */
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import CotizadorModal from '../components/CotizadorModal.astro';
import LeadMagnetPopup from '../components/LeadMagnetPopup.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  showLeadMagnet?: boolean;
}

const {
  title,
  description = 'Agencia de Diseño Web con más de 12 años de experiencia. Especialistas en diseño y desarrollo web a la medida en México, EE.UU. y España.',
  ogImage = '/og-image.png',
  showLeadMagnet = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://portafolioz.com');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Portafolio Z" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/img/logo/logo-ico.png" />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Portafolio Z`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, 'https://portafolioz.com').href} />
    <meta property="og:locale" content="es_MX" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@PortafolioZ" />

    <!-- Google Fonts: Poppins (pesos usados) con preload para no bloquear render -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" /></noscript>

    <title>{title} | Portafolio Z</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/img/logo/logo-ico.png" />
    <link rel="apple-touch-icon" href="/img/logo/logo-ico.png" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Portafolio Z",
      "url": "https://portafolioz.com",
      "logo": "https://portafolioz.com/img/logo/logo-light.png",
      "description": "Agencia de Diseño Web con más de 12 años de experiencia. Especialistas en diseño y desarrollo web a la medida en México.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Dr. José María Vértiz 84BIS",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "addressCountry": "MX"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+52-1-56-4721-5472",
        "contactType": "sales",
        "availableLanguage": ["Spanish"]
      },
      "sameAs": [
        "https://www.facebook.com/portafolioz",
        "https://www.instagram.com/portafolioz"
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Portafolio Z",
      "url": "https://portafolioz.com",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://portafolioz.com/blog?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-M7ZTR6TP6K"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', 'G-M7ZTR6TP6K');
    </script>

    <!-- ClientRouter (Astro v6): navegacion SPA entre subpaginas -->
    <ClientRouter />
  </head>
  <body class="bg-white text-gray-900 overflow-x-hidden">
    <slot />

    <!-- Cotizador Modal (global, se abre con data-open-cotizador) -->
    <CotizadorModal />

    <!-- Lead Magnet Popup (solo en paginas de diseno web) -->
    {showLeadMagnet && <LeadMagnetPopup />}

    <!--
      IntersectionObserver para animaciones de scroll.
      Se re-ejecuta en cada navegacion gracias a astro:page-load
      (necesario con View Transitions habilitado).
    -->
    <script>
      function initAnimations() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('animate-fade-up');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
        );
        document.querySelectorAll('[data-animate]').forEach((el) => {
          el.style.opacity = '0';
          observer.observe(el);
        });
      }

      // Ejecutar en carga inicial
      initAnimations();

      // Re-ejecutar despues de cada navegacion con View Transitions
      document.addEventListener('astro:page-load', initAnimations);

      // Tracking global para eventos clave de conversion
      if (!window.__pzGaBound) {
        window.__pzGaBound = true;

        window.pzTrackEvent = (eventName, params = {}) => {
          if (typeof window.gtag === 'function') {
            window.gtag('event', eventName, params);
          }
        };

        document.addEventListener('click', (event) => {
          const target = event.target instanceof Element
            ? event.target.closest('a.wa-lead, a[href*="wa.me/"], a[href*="api.whatsapp.com"]')
            : null;

          if (!target) return;

          window.pzTrackEvent('whatsapp_click', {
            lead_channel: 'whatsapp',
            link_url: target.getAttribute('href') || '',
            page_path: window.location.pathname,
            plan: target.getAttribute('data-plan') || 'N/A',
            category: target.getAttribute('data-category') || 'General'
          });
        }, true);
      }
    </script>
  </body>
</html>
